                  <Border Style="{StaticResource MetricCard}" MinWidth="145" Margin="0 0 8 8">
                    <StackPanel>
                      <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"/>
                      <Button x:Name="btnQuickPreview" Content="Quick-Preview" Margin="0 4 0 0" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
                      <TextBlock Text="Schnelle ROM-Vorschau" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="145" Margin="0 0 8 8">
                    <StackPanel>
                      <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"/>
                      <Button x:Name="btnHealthScore" Content="Health-Score" Margin="0 4 0 0" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
                      <TextBlock Text="Sammlungsqualität prüfen" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="145" Margin="0 0 8 8">
                    <StackPanel>
                      <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"/>
                      <Button x:Name="btnCollectionDiff" Content="Collection-Diff" Margin="0 4 0 0" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
                      <TextBlock Text="Sammlungen vergleichen" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="145" Margin="0 0 8 8">
                    <StackPanel>
                      <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"/>
                      <Button x:Name="btnDuplicateInspector" Content="Duplikat-Inspektor" Margin="0 4 0 0" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
                      <TextBlock Text="Duplikate untersuchen" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </WrapPanel>

                <!-- Export -->
                <TextBlock Text="Export" Style="{StaticResource CategoryHeader}"/>
                <WrapPanel Margin="0 0 0 8">
                  <Button x:Name="btnDuplicateExport" Content="Duplikate exportieren" Width="155" Margin="0 0 8 4"/>
                  <Button x:Name="btnExportCsv" Content="CSV Export" Width="120" Margin="0 0 8 4"/>
                  <Button x:Name="btnExportExcel" Content="Excel Export" Width="120" Margin="0 0 8 4"/>
                </WrapPanel>

                <!-- Rückgängig / Rollback -->
                <TextBlock Text="Rückgängig" Style="{StaticResource CategoryHeader}"/>
                <WrapPanel Margin="0 0 0 8">
                  <Button x:Name="btnRollbackQuick" Content="Schnell-Rollback" Width="140" Margin="0 0 8 4"/>
                  <Button x:Name="btnRollbackUndo" Content="Rollback Undo" Width="140" Margin="0 0 8 4"/>
                  <Button x:Name="btnRollbackRedo" Content="Rollback Redo" Width="140" Margin="0 0 8 4"/>
                </WrapPanel>

                <!-- System -->
                <TextBlock Text="System" Style="{StaticResource CategoryHeader}"/>
                <WrapPanel Margin="0 0 0 8">
                  <CheckBox x:Name="chkWatchMode" Content="Watch-Mode" Margin="0 0 12 4" ToolTip="Überwacht ROM-Roots und startet bei Änderungen automatisch DryRun."/>
                  <Button x:Name="btnWatchApply" Content="Watch anwenden" Width="140" Margin="0 0 8 4"/>
                  <Button x:Name="btnThemeToggle" Content="☾ Dunkel" Width="120" Margin="0 0 8 4"/>
                  <ComboBox x:Name="cmbLocale" Width="120" Margin="0 0 8 4">
                    <ComboBoxItem Content="de" IsSelected="True"/>
                    <ComboBoxItem Content="en"/>
                    <ComboBoxItem Content="fr"/>
                  </ComboBox>
                  <Button x:Name="btnApplyLocale" Content="Sprache anwenden" Width="140" Margin="0 0 8 4"/>
                </WrapPanel>
                <WrapPanel Margin="0 0 0 8">
                  <Button x:Name="btnPluginManager" Content="Plugin-Manager" Width="140" Margin="0 0 8 4"/>
                  <Button x:Name="btnAutoProfile" Content="Auto-Profil" Width="140" Margin="0 0 8 4"/>
                  <Button x:Name="btnConflictPolicy" Content="Conflict-Policy" Width="140" Margin="0 0 8 4"/>
                </WrapPanel>
                <TextBlock x:Name="lblAdvancedStatus" Text="Advanced: bereit" Style="{StaticResource CaptionText}"/>
              </StackPanel>
            </Border>
            </Expander>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

        </TabControl>
      </TabItem>

      <!-- ── FORTSCHRITT / LOG ─────────────────────────────────────────── -->
      <TabItem x:Name="tabProgress" Header="Protokoll">
        <DockPanel Background="{DynamicResource BrushBackground}">
          <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="12 8" Margin="12" MaxHeight="300">
            <Border.Effect>
              <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
            </Border.Effect>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="ERGEBNIS-DASHBOARD" Style="{StaticResource SectionHeader}" Margin="0 0 0 8"/>
                <!-- Metric Cards Row -->
                <WrapPanel Margin="0 0 0 4">
                  <Border Style="{StaticResource MetricCard}" MinWidth="100" Margin="0 0 8 8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Modus" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="lblDashMode" Text="–" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Aktueller Modus" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0 0 8 8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Winner" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="lblDashWinners" Text="0" Foreground="{DynamicResource BrushSuccess}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Anzahl Winner" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0 0 8 8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Duplikate" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="lblDashDupes" Text="0" Foreground="{DynamicResource BrushWarning}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Anzahl Duplikate" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0 0 8 8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Junk" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="lblDashJunk" Text="0" Foreground="{DynamicResource BrushDanger}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Anzahl Junk" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0 0 8 8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Laufzeit" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="lblDashDuration" Text="00:00" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Laufzeit" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0 0 8 8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Health" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="lblHealthScore" Text="–" Foreground="{DynamicResource BrushAccentCyan}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Health-Score" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                </WrapPanel>
                <!-- Performance Row (collapsed by default, shown during/after run) -->
                <Expander Header="Performance-Details" IsExpanded="False" Margin="0 0 0 2">
                  <WrapPanel Margin="0 4 0 0">
                    <TextBlock x:Name="lblPerfProgress" Text="0%" Foreground="{DynamicResource BrushAccentCyan}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="lblPerfThroughput" Text="– grp/s" Foreground="{DynamicResource BrushAccentCyan}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="lblPerfEta" Text="ETA –" Foreground="{DynamicResource BrushTextMuted}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="lblPerfCache" Text="Cache: –" Foreground="{DynamicResource BrushTextMuted}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="lblPerfParallel" Text="Parallel: –" Foreground="{DynamicResource BrushTextMuted}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="lblPerfPhase" Text="Phase: –" Foreground="{DynamicResource BrushTextMuted}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="lblPerfFile" Text="Datei: –" Foreground="{DynamicResource BrushTextMuted}" TextTrimming="CharacterEllipsis" Width="240"/>
                  </WrapPanel>
                </Expander>
              </StackPanel>
              <Button Grid.Column="1" x:Name="btnOpenReportLog" Width="150" Height="28"
                      VerticalAlignment="Center" ToolTip="HTML-Bericht öffnen (Ctrl+R)"
                      AutomationProperties.Name="HTML-Bericht öffnen">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" Margin="0 0 8 0"/>
                  <TextBlock Text="Bericht öffnen"/>
                </StackPanel>
              </Button>
            </Grid>
          </Border>
          <Border DockPanel.Dock="Bottom" Background="{DynamicResource BrushSurfaceAlt}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0 1 0 0" Padding="12 8">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="btnClearLog"  Content="Log leeren"       Width="118" Margin="0 0 8 0"/>
              <Button x:Name="btnExportLog" Content="Log exportieren"  Width="130"/>
            </StackPanel>
          </Border>
          <Grid Margin="0" Background="{DynamicResource BrushBackground}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" MinWidth="200"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="*" MinWidth="120"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="listLog" Grid.Column="0"
                     Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushAccentCyan}"
                     FontFamily="Consolas" FontSize="11"
                     BorderThickness="0" Margin="12 12 0 12"
                     ItemTemplate="{StaticResource LogEntryTemplate}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"/>
            <!-- GUI-03: GridSplitter für veränderbare Spaltenbreite -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"
                          AutomationProperties.Name="Log und Vorschau Größe anpassen"/>
            <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0 12 12 12">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                  <TextBlock Text="REPORT-VORSCHAU" Style="{StaticResource SectionHeader}" Margin="0 0 8 0"/>
                  <Button x:Name="btnRefreshReportPreview" Width="120" Height="28" Content="Aktualisieren"
                     AutomationProperties.Name="Berichtsvorschau aktualisieren"/>
                </StackPanel>
                <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 0 8">
                  <StackPanel>
                    <TextBlock Text="FEHLER-SUMMARY" Style="{StaticResource SectionHeader}" Margin="0 0 0 4"/>
                    <ListBox x:Name="listErrorSummary" MinHeight="60"
                             Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushWarning}"
                             BorderThickness="0"
                             FontFamily="Consolas" FontSize="11"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                    </ListBox>
                  </StackPanel>
                </Border>
                <WebBrowser x:Name="webReportPreview" MinHeight="80"/>
              </DockPanel>
            </Border>
          </Grid>
        </DockPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>

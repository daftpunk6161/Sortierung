<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="ROM Cleanup"
    Width="960" Height="720"
    MinWidth="720" MinHeight="520"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="13"
    Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushTextPrimary}"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">
  <Window.Resources>
    <!-- ═══ DATA TEMPLATES ══════════════════════════════════════════════════ -->
    <!-- LogEntry: bullet + text colored by severity level -->
    <DataTemplate x:Key="LogEntryTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#x2022; " Foreground="{Binding Brush}"/>
        <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                   FontFamily="Consolas" FontSize="11"/>
      </StackPanel>
    </DataTemplate>
    <!-- RootItem: folder icon + path -->
    <DataTemplate x:Key="RootItemTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="14"
                   Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0 0 8 0"/>
        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>
  <DockPanel LastChildFill="True">

    <!-- ═══ TOP STATUS BAR (Toolbar-Style) ═════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0 0 0 1"
            Padding="12 8">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ComboBox x:Name="cmbQuickProfile" Width="160" Margin="4 0 4 0"
                    ToolTip="Konfigurationsprofil schnell wechseln" IsEditable="False"/>
          <Button x:Name="btnOpenReport" ToolTip="Letzten Bericht öffnen (Ctrl+R)" Margin="4 0 8 0"
                 AutomationProperties.Name="Letzten Bericht öffnen">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="14" Margin="0 0 8 0"/>
              <TextBlock Text="Bericht"/>
            </StackPanel>
          </Button>
        </StackPanel>
        <!-- GUI-02: ClipToBounds verhindert Ueberlauf bei schmalen Fenstern -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
          <TextBlock Text="ROM CLEANUP" Style="{StaticResource TitleText}"
                     VerticalAlignment="Center" Margin="8 0 24 0"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="0 0 8 0"/>
          <Ellipse x:Name="dotRoots" Width="12" Height="12" Fill="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" Margin="4 0 4 0"
                   ToolTip="ROM-Ordner: Grün = konfiguriert, Grau = fehlt"/>
          <TextBlock x:Name="lblStatusRoots" Text="Roots: –"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"
                     Margin="0 0 12 0" FontSize="11"/>
          <Ellipse x:Name="dotTools" Width="12" Height="12" Fill="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" Margin="4 0 4 0"
                   ToolTip="Tools: Grün = chdman/7z gefunden, Grau = fehlt"/>
          <TextBlock x:Name="lblStatusTools" Text="Tools: –"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"
                     Margin="0 0 12 0" FontSize="11"/>
          <Ellipse x:Name="dotDat" Width="12" Height="12" Fill="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" Margin="4 0 4 0"
                   ToolTip="DAT-Verifizierung: Grün = aktiv, Grau = deaktiviert"/>
          <TextBlock x:Name="lblStatusDat" Text="DAT: –"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="12 0 8 0"/>
          <Ellipse x:Name="dotReady" Width="14" Height="14" Fill="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" Margin="4 0 4 0"
                   ToolTip="Gesamtstatus: Grün = startbereit, Gelb = Warnung, Rot = blockiert"/>
          <TextBlock x:Name="lblStatusReady" Text="Status: –"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="12 0 8 0"/>
          <TextBlock x:Name="lblStatusRuntime" Text="Laufzeit: –"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══ FOOTER ACTION BAR (Ribbon-Style) ═══════════════════════════════ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0 1 0 0"
            Padding="12 8">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ProgressBar x:Name="progGlobal" MinWidth="120" Width="200" Height="8" Value="0" Maximum="100"
                       Margin="8 0 0 0" VerticalAlignment="Center"/>
          <TextBlock x:Name="lblProgressPct" Text="" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11" Margin="8 0 0 0"/>
        </StackPanel>
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Gruppe 1: Starten / Stoppen -->
          <Button x:Name="btnRunGlobal"
                  Style="{StaticResource PrimaryButton}"
                  Width="140" Height="52" Margin="0 0 4 0"
                  ToolTip="Sortierung starten (F5)"
                  AutomationProperties.Name="Sortierung starten"
                  TabIndex="1">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="20"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Starten" FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Center" Margin="0 2 0 0"/>
            </StackPanel>
          </Button>
          <Button x:Name="btnCancelGlobal"
                  Style="{StaticResource DangerButton}"
                  Width="60" Height="52" IsEnabled="False" Margin="0 0 4 0"
                  ToolTip="Lauf abbrechen (Esc)"
                  AutomationProperties.Name="Lauf abbrechen"
                  TabIndex="2">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="20"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Stopp" FontSize="11" HorizontalAlignment="Center" Margin="0 2 0 0"/>
            </StackPanel>
          </Button>
          <!-- Separator -->
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="8 0 8 0"/>
          <!-- Gruppe 2: Rückgängig -->
          <Button x:Name="btnRollback"
                  Width="110" Height="52" IsEnabled="False"
                  BorderBrush="{DynamicResource BrushAccentPurple}" Foreground="{DynamicResource BrushAccentPurple}" Margin="0 0 4 0"
                  Background="{DynamicResource BrushDangerBg}" BorderThickness="2"
                  ToolTip="Letzten Lauf rückgängig machen (Ctrl+Z)"
                  AutomationProperties.Name="Letzten Lauf rückgängig machen"
                  TabIndex="3">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE777;" FontSize="20"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Rückgängig" FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Center" Margin="0 2 0 0"/>
            </StackPanel>
          </Button>
          <!-- Separator -->
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="8 0 8 0"/>
          <!-- Hinweis -->
          <TextBlock x:Name="lblBusyHint" Text="" Style="{StaticResource CaptionText}"
                     VerticalAlignment="Center" Margin="4 0"/>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- ═══ MAIN TABCONTROL ════════════════════════════════════════════════ -->
    <TabControl x:Name="tabMain" Margin="0">

      <!-- ── SORTIEREN ──────────────────────────────────────────────────── -->
      <TabItem x:Name="tabSort" Header="Sortieren">
        <ScrollViewer x:Name="svSort" VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>

            <!-- UX-01: Visual Step Indicator -->
            <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16 12" Margin="0 0 0 12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Step 1: Ordner -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot1" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="Transparent" VerticalAlignment="Center" Margin="0 0 8 0"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="1 · Ordner" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock x:Name="stepLabel1" Text="Keine Ordner" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
                <!-- Connector 1→2 -->
                <Border Grid.Column="1" Height="2" Width="32" VerticalAlignment="Center"
                        Background="{DynamicResource BrushBorder}" Margin="4 0"/>
                <!-- Step 2: Konfiguration -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot2" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="Transparent" VerticalAlignment="Center" Margin="0 0 8 0"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="2 · Optionen" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock x:Name="stepLabel2" Text="Bereit" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
                <!-- Connector 2→3 -->
                <Border Grid.Column="3" Height="2" Width="32" VerticalAlignment="Center"
                        Background="{DynamicResource BrushBorder}" Margin="4 0"/>
                <!-- Step 3: Starten -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot3" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="Transparent" VerticalAlignment="Center" Margin="0 0 8 0"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="3 · Starten" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock x:Name="stepLabel3" Text="F5 drücken" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Quick-Start Presets -->
            <Border Style="{StaticResource SectionCard}" Margin="0 0 0 8">
              <StackPanel>
                <TextBlock Text="QUICK-START" Style="{StaticResource SectionHeader}"/>
                <WrapPanel>
                  <Button x:Name="btnPresetSafeDryRun" Width="190" Height="48" Margin="0 0 8 4"
                          ToolTip="Sicherer DryRun: Nur prüfen, nichts verschieben"
                          AutomationProperties.Name="Preset: Sicherer DryRun">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Sicherer DryRun" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Nur prüfen, nichts ändern" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="btnPresetFullSort" Width="190" Height="48" Margin="0 0 8 4"
                          ToolTip="Volle Sortierung: Alle Regionen, Standard-Regeln, DryRun aktiv"
                          AutomationProperties.Name="Preset: Volle Sortierung">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Volle Sortierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Alle Regionen, Standard-Regeln" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="btnPresetConvert" Width="190" Height="48" Margin="0 0 8 4"
                          ToolTip="Konvertierung: Formate nach Move optimieren (CHD/RVZ)"
                          AutomationProperties.Name="Preset: Konvertierung">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Konvertierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Formate optimieren (CHD/RVZ)" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Einfach/Experte Modus-Toggle -->
            <Border x:Name="brdModeToggle" CornerRadius="4" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" Margin="0 0 0 8" HorizontalAlignment="Left">
              <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="rbModeEinfach" Content="Einfach" GroupName="UiMode"
                             IsChecked="True" Padding="12,4" MinWidth="70" Cursor="Hand"
                             ToolTip="Vereinfachte Ansicht: nur die wichtigsten Optionen"/>
                <RadioButton x:Name="rbModeExperte" Content="Experte" GroupName="UiMode"
                             Padding="12,4" MinWidth="70" Cursor="Hand"
                             ToolTip="Alle Konfigurationsoptionen anzeigen"/>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
              <StackPanel>

            <TextBlock Text="ROM-VERZEICHNISSE" Style="{StaticResource SectionHeader}"/>
            <Grid Margin="0 0 0 4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid Grid.Column="0">
                <ListBox x:Name="listRoots" MinHeight="90" MaxHeight="200" Margin="0 0 8 0"
                         AllowDrop="True"
                         ItemTemplate="{StaticResource RootItemTemplate}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True"
                         ToolTip="ROM-Ordner hier hineinziehen (Drag &amp; Drop)"/>
                <!-- Empty-State Overlay (sichtbar wenn listRoots leer) -->
                <Border x:Name="pnlRootsEmptyState" Visibility="Visible"
                        IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0 0 8 0">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"
                               Margin="0 0 0 8" Opacity="0.6"/>
                    <TextBlock Text="ROM-Ordner hierher ziehen" FontSize="12"
                               Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                    <TextBlock Text="oder mit '+' hinzufügen" Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center" Margin="0 2 0 0"/>
                  </StackPanel>
                </Border>
              </Grid>
              <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="118">
                <Button x:Name="btnAddRoot"    Content="＋ Hinzufügen" Margin="0 0 0 4" HorizontalAlignment="Stretch"
                  ToolTip="Neuen ROM-Ordner zur Liste hinzufügen"
                  AutomationProperties.Name="ROM-Ordner hinzufügen"/>
                <Button x:Name="btnRemoveRoot" Content="－ Entfernen"  Margin="0 0 0 4" HorizontalAlignment="Stretch"
                  ToolTip="Ausgewählten ROM-Ordner entfernen (Entf)"
                  AutomationProperties.Name="ROM-Ordner entfernen"/>
              </StackPanel>
            </Grid>

              </StackPanel>
            </Border>

            <!-- Einfach-Modus: Schnellstart-Panel (visible when rbModeEinfach is checked) -->
            <Border x:Name="pnlEinfachModus" Style="{StaticResource SectionCard}">
              <StackPanel>
                <TextBlock Text="SCHNELLSTART" Style="{StaticResource SectionHeader}" Margin="0 0 0 8"/>
                <StackPanel Margin="0 0 0 8">
                  <TextBlock Text="Region:" Margin="0 0 0 4" FontWeight="SemiBold"
                             Foreground="{DynamicResource BrushTextMuted}"/>
                  <ComboBox x:Name="cmbEinfachRegion" Width="220" HorizontalAlignment="Left">
                    <ComboBoxItem Content="Europa (EU)" IsSelected="True"/>
                    <ComboBoxItem Content="Nordamerika (US)"/>
                    <ComboBoxItem Content="Japan (JP)"/>
                    <ComboBoxItem Content="Weltweit (Alle)"/>
                  </ComboBox>
                </StackPanel>
                <StackPanel Margin="0 0 0 8">
                  <TextBlock Text="Was soll passieren?" Margin="0 0 0 4" FontWeight="SemiBold"
                             Foreground="{DynamicResource BrushTextMuted}"/>
                  <CheckBox x:Name="chkEinfachDupes" Content="Duplikate erkennen und aussortieren"
                            IsChecked="True" Margin="0 2"/>
                  <CheckBox x:Name="chkEinfachJunk" Content="Junk-Dateien entfernen (Demos, Betas, Hacks)"
                            IsChecked="True" Margin="0 2"/>
                  <CheckBox x:Name="chkEinfachSort" Content="In Konsolen-Ordner sortieren"
                            IsChecked="True" Margin="0 2"/>
                </StackPanel>
                <TextBlock Text="Ordner oben hinzufügen, dann unten auf 'Sortierung starten' klicken."
                           Style="{StaticResource CaptionText}" Margin="0 4 0 0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Experte-Details: nur sichtbar im Experten-Modus -->
            <StackPanel x:Name="pnlExperteDetails" Visibility="Collapsed">

            <Border Style="{StaticResource SectionCard}">
              <StackPanel>

            <TextBlock Text="OPTIONEN" Style="{StaticResource SectionHeader}"/>
            <WrapPanel>
              <CheckBox x:Name="chkReportDryRun"   Content="Nur Vorschau (Dry Run)" Margin="0 4 24 4"
                        IsChecked="True" Foreground="{DynamicResource BrushWarning}"
                        ToolTip="Es werden keine Dateien verschoben; nur Analyse + Bericht."/>
              <CheckBox x:Name="chkConvert" Content="Winner nach Move konvertieren (CHD/RVZ/ZIP)" Margin="0 4 24 4"
                        ToolTip="Aktiviert Format-Konvertierung im Move-Lauf (z.B. BIN/CUE → CHD). Im DryRun nur als Vorschau im Report."/>
              <!-- DEAD-01: chkExpertMode entfernt - durch RadioButton Toggle (rbModeEinfach/rbModeExperte) ersetzt -->
            </WrapPanel>
            <Border x:Name="brdDryRunBanner" Margin="0 8 0 0" Padding="12 8"
                    Background="{DynamicResource BrushSuccessBg}" BorderBrush="{DynamicResource BrushSuccess}" BorderThickness="1"
                    CornerRadius="6" Visibility="Visible">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblDryRunBanner"
                           Text="DryRun aktiv: Es werden keine Dateien verschoben."
                           Foreground="{DynamicResource BrushSuccess}" FontWeight="SemiBold" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button x:Name="btnStartMove" Content="▶ Jetzt als Move ausführen"
                        Margin="16 0 0 0" Padding="12 4" FontWeight="SemiBold"
                        Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushDanger}" BorderBrush="{DynamicResource BrushDanger}"
                        BorderThickness="1" Cursor="Hand" Visibility="Collapsed"
                        ToolTip="Startet den Lauf erneut im Move-Modus. Duplikate werden verschoben."/>
              </StackPanel>
            </Border>
            <!-- UX-11: Rollback-Banner nach erfolgreicher Move-Operation -->
            <Border x:Name="brdMoveCompleteBanner" Margin="0 8 0 0" Padding="12 8"
                    Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1"
                    CornerRadius="6" Visibility="Collapsed">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblMoveCompleteInfo"
                           Text="Move abgeschlossen."
                           Foreground="{DynamicResource BrushAccentPurple}" FontWeight="SemiBold" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button x:Name="btnRollbackInline" Content="&#xE777; Rückgängig machen"
                        FontFamily="Segoe MDL2 Assets, Segoe UI"
                        Margin="16 0 0 0" Padding="12 4" FontWeight="SemiBold"
                        Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushAccentPurple}" BorderBrush="{DynamicResource BrushAccentPurple}"
                        BorderThickness="1" Cursor="Hand"
                        ToolTip="Letzten Move-Lauf rückgängig machen (Ctrl+Z)"
                        AutomationProperties.Name="Letzten Move-Lauf rückgängig machen"/>
              </StackPanel>
            </Border>
            <TextBlock Text="Tipp: Erweiterte Sortier- und Sicherheitsoptionen findest du im Tab 'Konfiguration'."
                       Style="{StaticResource CaptionText}" Margin="0 4 0 0" TextWrapping="Wrap"/>

              </StackPanel>
            </Border>

            <!-- Danger Zone (UX-02: collapsed — Move confirmation now via styled dialog) -->
            <Expander x:Name="expMoveDanger" Header="Move-Modus (Gefahr)" Foreground="{DynamicResource BrushDanger}" Margin="0 16 0 0"
                      Visibility="Collapsed">
              <Border Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushDanger}" BorderThickness="1"
                      CornerRadius="8" Padding="12" Margin="0 8 0 0">
                <StackPanel>
                  <TextBlock Text="⚠ GEFAHR: MOVE-MODUS" FontFamily="Consolas" FontWeight="Bold"
                             FontSize="10" Foreground="{DynamicResource BrushDanger}" Margin="0 0 0 8"/>
                  <TextBlock Text="Im Move-Modus werden Duplikate physisch verschoben. Stelle sicher, dass ein korrektes Backup existiert."
                             Foreground="{DynamicResource BrushDanger}" FontSize="11" TextWrapping="Wrap" Margin="0 0 0 8"/>
                  <CheckBox x:Name="chkConfirmMove" Content="Ich verstehe die Folgen – Move-Modus freischalten"
                            Foreground="{DynamicResource BrushDanger}"/>
                </StackPanel>
              </Border>
            </Expander>

            </StackPanel> <!-- /pnlExperteDetails -->

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ── KONFIGURATION (Tools + DAT + Einstellungen) ─────────────── -->
      <TabItem x:Name="tabConfig" Header="Konfiguration">
        <TabControl x:Name="tabConfigSub">

          <!-- ── REGELN (Sortierung, Regionen, Erweiterungen) ─────────── -->
          <TabItem x:Name="tabConfigBasis" Header="Regeln">
            <ScrollViewer x:Name="svConfigBasis" VerticalScrollBarVisibility="Auto" Padding="16">
              <StackPanel>
            <Expander x:Name="expCfgSort" Header="Sortieroptionen" IsExpanded="True" Margin="0 0 0 8">
            <Border Style="{StaticResource SectionCard}">
              <StackPanel>
            <TextBlock Text="SORTIEROPTIONEN" Style="{StaticResource SectionHeader}"/>
            <WrapPanel>
              <CheckBox x:Name="chkSortConsole"    Content="Ordner nach Konsole strukturieren"  Margin="0 4 24 4"
                        IsChecked="True"
                        ToolTip="Erstellt Unterordner pro Konsole im Zielverzeichnis (z.B. /PS1/, /SNES/, /GBA/)"/>
              <CheckBox x:Name="chkJunkAggressive" Content="Offensichtliche Junk-Dateien stärker filtern" Margin="0 4 24 4"
                        ToolTip="Entfernt zusätzliche Beta/Proto/Sample-Dateien. Kann streng sein."/>
              <CheckBox x:Name="chkAliasKeying"    Content="Spielnamen vereinheitlichen" Margin="0 4 24 4"
                        ToolTip="Gleicht bekannte Namensvarianten auf denselben Titel ab."/>
            </WrapPanel>
            <TextBlock Text="ℹ Diese Optionen sind optional. Für Standardläufe reicht der Sortieren-Tab."
                       Style="{StaticResource CaptionText}" Margin="0 4 0 0" TextWrapping="Wrap"/>

            <Expander Header="Erweiterte Sortierung &amp; Sicherheit" Margin="0 16 0 0" IsExpanded="False">
              <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                      CornerRadius="8" Padding="12" Margin="0 8 0 0">
                <StackPanel>
                  <!-- Region-Prio -->
                  <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Region-Prio:" VerticalAlignment="Top" Margin="0 2 0 0"/>
                    <StackPanel Grid.Column="1">
                      <WrapPanel>
                        <CheckBox x:Name="chkPreferEU"    Content="EU"     Margin="0 0 12 4" IsChecked="True" ToolTip="Europa (EUR/PAL)"/>
                        <CheckBox x:Name="chkPreferUS"    Content="US"     Margin="0 0 12 4" IsChecked="True" ToolTip="USA (NTSC)"/>
                        <CheckBox x:Name="chkPreferWORLD" Content="WORLD"  Margin="0 0 12 4" IsChecked="True" ToolTip="World- / Export-Versionen"/>
                        <CheckBox x:Name="chkPreferJP"    Content="JP"     Margin="0 0 12 4" IsChecked="True" ToolTip="Japan"/>
                      </WrapPanel>
                      <Expander Header="Weitere Regionen" IsExpanded="False" Margin="0 2 0 0">
                        <WrapPanel Margin="0 4 0 0">
                          <CheckBox x:Name="chkPreferDE"    Content="DE"     Margin="0 0 12 4" ToolTip="Deutschland"/>
                          <CheckBox x:Name="chkPreferFR"    Content="FR"     Margin="0 0 12 4" ToolTip="Frankreich"/>
                          <CheckBox x:Name="chkPreferIT"    Content="IT"     Margin="0 0 12 4" ToolTip="Italien"/>
                          <CheckBox x:Name="chkPreferES"    Content="ES"     Margin="0 0 12 4" ToolTip="Spanien"/>
                          <CheckBox x:Name="chkPreferAU"    Content="AU"     Margin="0 0 12 4" ToolTip="Australien"/>
                          <CheckBox x:Name="chkPreferASIA"  Content="ASIA"   Margin="0 0 12 4" ToolTip="Asien (inkl. Taiwan, Hongkong)"/>
                          <CheckBox x:Name="chkPreferKR"    Content="KR"     Margin="0 0 12 4" ToolTip="Südkorea"/>
                          <CheckBox x:Name="chkPreferCN"    Content="CN"     Margin="0 0 12 4" ToolTip="China"/>

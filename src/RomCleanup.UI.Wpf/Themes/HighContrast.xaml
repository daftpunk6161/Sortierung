<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
<!-- ═══ HIGH CONTRAST (WCAG AAA ≥ 7:1) ═══════════════════════════════════
     Colour palette + accessibility overrides (thicker borders, larger hit
     targets, no decorative shadows, 3px focus rings).
     Shared templates come from _ControlTemplates.xaml; any style redefined
     here wins because this dictionary loads AFTER _ControlTemplates. ═══════ -->

    <sys:Boolean x:Key="__HighContrastTheme">True</sys:Boolean>

    <!-- ── Core Surfaces ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushBackground"   Color="#000000"/>
    <SolidColorBrush x:Key="BrushSurface"      Color="#1A1A1A"/>
    <SolidColorBrush x:Key="BrushSurfaceAlt"   Color="#0D0D0D"/>
    <SolidColorBrush x:Key="BrushSurfaceLight" Color="#2A2A2A"/>

    <!-- ── Accent ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushAccentCyan"   Color="#FFFF00"/>
    <SolidColorBrush x:Key="BrushAccentPurple" Color="#FF00FF"/>

    <!-- ── Semantic ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDanger"       Color="#FF3333"/>
    <SolidColorBrush x:Key="BrushSuccess"      Color="#33FF33"/>
    <SolidColorBrush x:Key="BrushWarning"      Color="#FFCC00"/>

    <!-- ── Text ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushTextPrimary"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BrushTextMuted"    Color="#CCCCCC"/>
    <SolidColorBrush x:Key="BrushBorder"       Color="#FFFFFF"/>

    <!-- ── Semantic Backgrounds ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDangerBg"  Color="#330000"/>
    <SolidColorBrush x:Key="BrushSuccessBg" Color="#003300"/>
    <SolidColorBrush x:Key="BrushInfoBg"    Color="#000033"/>
    <SolidColorBrush x:Key="BrushWarningBg" Color="#332B00"/>

    <!-- ── Interaction ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushButtonPressed"   Color="#FFFF0044"/>
    <SolidColorBrush x:Key="BrushInputSelection"  Color="#FFFF0066"/>
    <SolidColorBrush x:Key="BrushBorderHover"     Color="#FFFF00"/>
    <SolidColorBrush x:Key="BrushPrimaryBg"       Color="#FFFF00"/>
    <SolidColorBrush x:Key="BrushTextOnAccent"    Color="#000000"/>
    <SolidColorBrush x:Key="BrushPrimaryHover"    Color="#CCCC00"/>
    <SolidColorBrush x:Key="BrushPrimaryActive"   Color="#999900"/>
    <SolidColorBrush x:Key="BrushDangerHover"     Color="#FF333333"/>
    <SolidColorBrush x:Key="BrushScrimOverlay"    Color="#DD000000"/>

    <!-- ═══ HC OVERRIDE: Focus ring 3 px ══════════════════════════════ -->
    <Style x:Key="FocusRing">
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate>
            <Border BorderBrush="{DynamicResource BrushAccentCyan}"
                    BorderThickness="3" CornerRadius="4"
                    Margin="-2" SnapsToDevicePixels="True"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══ HC OVERRIDE: Button 2 px border, 3 px focus, no shadow ═══ -->
    <Style TargetType="Button">
      <Setter Property="Background"       Value="{DynamicResource BrushSurface}"/>
      <Setter Property="Foreground"       Value="{DynamicResource BrushAccentCyan}"/>
      <Setter Property="BorderBrush"      Value="{DynamicResource BrushAccentCyan}"/>
      <Setter Property="BorderThickness"  Value="2"/>
      <Setter Property="Padding"          Value="12 6"/>
      <Setter Property="Cursor"           Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushSurfaceLight}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushButtonPressed}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
                <Setter TargetName="bd" Property="BorderThickness" Value="3"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══ HC OVERRIDE: TextBox 2 px border ═════════════════════════ -->
    <Style TargetType="TextBox">
      <Setter Property="Background"      Value="{DynamicResource BrushSurface}"/>
      <Setter Property="Foreground"      Value="{DynamicResource BrushTextPrimary}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="Padding"         Value="6 4"/>
      <Setter Property="CaretBrush"      Value="{DynamicResource BrushAccentCyan}"/>
      <Setter Property="SelectionBrush"  Value="{DynamicResource BrushInputSelection}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══ HC OVERRIDE: CheckBox 18 px, 2 px border ═════════════════ -->
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
      <Setter Property="Margin"     Value="0 3"/>
      <Setter Property="Cursor"     Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="checkBorder" Width="18" Height="18" Margin="0 0 8 0"
                      Background="{DynamicResource BrushSurface}"
                      BorderBrush="{DynamicResource BrushBorder}"
                      BorderThickness="2" CornerRadius="3">
                <Path x:Name="checkMark" Visibility="Collapsed"
                      Width="10" Height="8" Stretch="Uniform"
                      Fill="{DynamicResource BrushAccentCyan}"
                      Data="M 0 4 L 3 7 L 8 0"/>
              </Border>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══ HC OVERRIDE: NavButton ════════════════════════════════════ -->
    <Style x:Key="NavButton" TargetType="RadioButton">
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="44"/>
      <Setter Property="Margin" Value="4,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
      <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="navBd" Background="Transparent" CornerRadius="4"
                    Padding="4" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                    BorderThickness="0,0,0,0" BorderBrush="Transparent">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="navBd" Property="Background" Value="{DynamicResource BrushSurface}"/>
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="navBd" Property="Background" Value="{DynamicResource BrushSurface}"/>
                <Setter TargetName="navBd" Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
                <Setter TargetName="navBd" Property="BorderThickness" Value="3,0,0,0"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushAccentCyan}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

</ResourceDictionary>

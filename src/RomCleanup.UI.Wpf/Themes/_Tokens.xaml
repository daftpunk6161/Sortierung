<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
<!-- ═══ DESIGN TOKENS (theme-independent) ════════════════════════════ -->
<!-- These tokens are shared across all themes. Colors live in each      -->
<!-- theme file; structure/layout tokens live here.                       -->

    <!-- ═══ SPACING SCALE (8px base) ══════════════════════════════════ -->
    <sys:Double x:Key="SpaceXS">4</sys:Double>
    <sys:Double x:Key="SpaceSM">8</sys:Double>
    <sys:Double x:Key="SpaceMD">12</sys:Double>
    <sys:Double x:Key="SpaceLG">16</sys:Double>
    <sys:Double x:Key="SpaceXL">24</sys:Double>
    <sys:Double x:Key="SpaceXXL">32</sys:Double>
    <Thickness x:Key="SpaceBottomXS">0 0 0 4</Thickness>
    <Thickness x:Key="SpaceBottomSM">0 0 0 8</Thickness>
    <Thickness x:Key="SpaceBottomMD">0 0 0 12</Thickness>
    <Thickness x:Key="SpaceBottomLG">0 0 0 16</Thickness>
    <Thickness x:Key="SpaceBottomXL">0 0 0 24</Thickness>
    <Thickness x:Key="PaddingBar">12 6 12 6</Thickness>
    <Thickness x:Key="PaddingSection">16 16 16 16</Thickness>
    <Thickness x:Key="SpaceRightSM">0 0 8 0</Thickness>
    <Thickness x:Key="SpaceRightMD">0 0 12 0</Thickness>
    <Thickness x:Key="SpaceDotInline">4 0 4 0</Thickness>
    <Thickness x:Key="SpaceDivider">8 0 8 0</Thickness>
    <Thickness x:Key="SpaceLeftSM">8 0 0 0</Thickness>
    <Thickness x:Key="SpaceRightXS">0 0 4 0</Thickness>
    <Thickness x:Key="SpaceTopLG">0 16 0 0</Thickness>

    <!-- ═══ CORNER RADIUS SCALE ═══════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusSM">3</CornerRadius>
    <CornerRadius x:Key="RadiusMD">6</CornerRadius>
    <CornerRadius x:Key="RadiusLG">8</CornerRadius>
    <CornerRadius x:Key="RadiusXL">12</CornerRadius>

    <!-- ═══ TYPOGRAPHY SCALE ══════════════════════════════════════════ -->
    <sys:Double x:Key="TypeDisplay">22</sys:Double>
    <sys:Double x:Key="TypeHeading">16</sys:Double>
    <sys:Double x:Key="TypeBody">13</sys:Double>
    <sys:Double x:Key="TypeCaption">11</sys:Double>
    <sys:Double x:Key="TypeMono">11</sys:Double>
    <FontFamily x:Key="FontMono">Consolas</FontFamily>

    <!-- ═══ ANIMATION TIMING ══════════════════════════════════════════ -->
    <Duration x:Key="TimingFast">0:0:0.12</Duration>
    <Duration x:Key="TimingNormal">0:0:0.18</Duration>
    <Duration x:Key="TimingSlow">0:0:0.3</Duration>
</ResourceDictionary>

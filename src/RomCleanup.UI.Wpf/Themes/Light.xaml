<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<!-- ═══ LIGHT STUDIO ═════════════════════════════════════════════════════
     Clean, professional light palette. Colours only — templates in
     _ControlTemplates.xaml. ══════════════════════════════════════════════ -->

    <!-- ── Core Surfaces ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushBackground"   Color="#F4F6FF"/>
    <SolidColorBrush x:Key="BrushSurface"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BrushSurfaceAlt"   Color="#ECEFFC"/>
    <SolidColorBrush x:Key="BrushSurfaceLight" Color="#F7F8FF"/>

    <!-- ── Accent ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushAccentCyan"   Color="#005A9E"/>
    <SolidColorBrush x:Key="BrushAccentPurple" Color="#6E3FD6"/>

    <!-- ── Semantic ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDanger"       Color="#C62828"/>
    <SolidColorBrush x:Key="BrushSuccess"      Color="#1B8A5A"/>
    <SolidColorBrush x:Key="BrushWarning"      Color="#B26A00"/>

    <!-- ── Text ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushTextPrimary"  Color="#12142A"/>
    <SolidColorBrush x:Key="BrushTextMuted"    Color="#4C5478"/>
    <SolidColorBrush x:Key="BrushBorder"       Color="#C9CFE8"/>

    <!-- ── Semantic Backgrounds ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDangerBg"  Color="#FFF0F0"/>
    <SolidColorBrush x:Key="BrushSuccessBg" Color="#F0FFF4"/>
    <SolidColorBrush x:Key="BrushInfoBg"    Color="#F0F4FF"/>
    <SolidColorBrush x:Key="BrushWarningBg" Color="#FFF8E8"/>

    <!-- ── Interaction ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushButtonPressed"   Color="#D0D4ED"/>
    <SolidColorBrush x:Key="BrushInputSelection"  Color="#005A9E44"/>
    <SolidColorBrush x:Key="BrushBorderHover"     Color="#005A9E"/>
    <SolidColorBrush x:Key="BrushPrimaryBg"       Color="#005A9E"/>
    <SolidColorBrush x:Key="BrushTextOnAccent"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BrushPrimaryHover"    Color="#004C8C"/>
    <SolidColorBrush x:Key="BrushPrimaryActive"   Color="#003D73"/>
    <SolidColorBrush x:Key="BrushDangerHover"     Color="#C6282811"/>
    <SolidColorBrush x:Key="BrushScrimOverlay"    Color="#99000000"/>

</ResourceDictionary>

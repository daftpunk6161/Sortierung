<Window x:Class="RomCleanup.UI.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:views="clr-namespace:RomCleanup.UI.Wpf.Views"
    Title="ROM Cleanup"
    Icon="pack://application:,,,/Assets/app.ico"
    Width="960" Height="720"
    MinWidth="800" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="13"
    Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushTextPrimary}"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">


  <Window.InputBindings>
    <KeyBinding Key="F5" Command="{Binding RunCommand}"/>
    <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    <KeyBinding Key="R" Modifiers="Control" Command="{Binding OpenReportCommand}"/>
    <KeyBinding Key="Z" Modifiers="Control" Command="{Binding RollbackCommand}"/>
    <KeyBinding Key="O" Modifiers="Control" Command="{Binding AddRootCommand}"/>
    <KeyBinding Key="L" Modifiers="Control" Command="{Binding ClearLogCommand}"/>
    <KeyBinding Key="T" Modifiers="Control" Command="{Binding ThemeToggleCommand}"/>
    <KeyBinding Key="G" Modifiers="Control" Command="{Binding GameKeyPreviewCommand}"/>
    <KeyBinding Key="D1" Modifiers="Control" Command="{Binding PresetSafeDryRunCommand}"/>
    <KeyBinding Key="D2" Modifiers="Control" Command="{Binding PresetFullSortCommand}"/>
    <KeyBinding Key="D3" Modifiers="Control" Command="{Binding PresetConvertCommand}"/>
    <KeyBinding Key="D" Modifiers="Control" Command="{Binding QuickPreviewCommand}"/>
    <KeyBinding Key="M" Modifiers="Control" Command="{Binding StartMoveCommand}"/>
    <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveSettingsCommand}"/>
    <KeyBinding Key="W" Modifiers="Control" Command="{Binding WatchApplyCommand}"/>
    <!-- GUI-063: Navigation history -->
    <KeyBinding Key="Left" Modifiers="Control" Command="{Binding NavBackCommand}"/>
    <KeyBinding Key="Right" Modifiers="Control" Command="{Binding NavForwardCommand}"/>
    <!-- GUI-101: Shortcut cheatsheet -->
    <KeyBinding Key="F1" Command="{Binding ToggleShortcutSheetCommand}"/>
  </Window.InputBindings>

  <DockPanel LastChildFill="True">

    <!-- ═══ TOP STATUS BAR ════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,0,0,1" Padding="{DynamicResource PaddingBar}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ComboBox x:Name="cmbQuickProfile" Width="160" Margin="{DynamicResource SpaceDotInline}"
                    ToolTip="{Binding Loc[Profile.QuickSwitch]}" IsEditable="False"
                    SelectedIndex="{Binding QuickProfileIndex, Mode=TwoWay}"
                    AutomationProperties.Name="{Binding Loc[Profile.QuickSwitch]}">
            <ComboBoxItem Content="Standard" IsSelected="True"/>
            <ComboBoxItem Content="Disc (CHD)"/>
            <ComboBoxItem Content="Cartridge (ZIP)"/>
            <ComboBoxItem Content="Gemischt"/>
          </ComboBox>
          <Button Command="{Binding OpenReportCommand}" ToolTip="{Binding Loc[Report.OpenReportTip]}" Margin="4,0,8,0"
                  AutomationProperties.Name="{Binding Loc[Report.OpenReport]}"
                  AutomationProperties.AcceleratorKey="Ctrl+R">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="14" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Text="{Binding Loc[Report.OpenReportLog]}"/>
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
          <TextBlock Text="ROM CLEANUP" Style="{StaticResource TitleText}"
                     VerticalAlignment="Center" Margin="8,0,24,0"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
          <!-- Status dots bound to ViewModel StatusLevel via converter -->
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding RootsStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="{Binding Loc[Status.RootsTip]}"/>
          <TextBlock Text="{Binding StatusRoots}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" Margin="{DynamicResource SpaceRightMD}" FontSize="11"/>
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding ToolsStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="{Binding Loc[Status.ToolsTip]}"/>
          <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" Margin="{DynamicResource SpaceRightMD}" FontSize="11"/>
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding DatStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="{Binding Loc[Status.DatTip]}"/>
          <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <Ellipse Width="14" Height="14" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="{Binding Loc[Status.ReadyTip]}"/>
          <TextBlock Text="{Binding StatusReady}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"
                     AutomationProperties.Name="{Binding Loc[Status.ReadyLabel]}" AutomationProperties.LiveSetting="Polite"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <TextBlock Text="{Binding StatusRuntime}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══ FOOTER ACTION BAR ═════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,1,0,0" Padding="{DynamicResource PaddingBar}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ProgressBar MinWidth="120" Width="200" Height="8" Maximum="100"
                       Value="{Binding Progress}" Margin="{DynamicResource SpaceLeftSM}" VerticalAlignment="Center"
                       AutomationProperties.Name="Fortschritt" AutomationProperties.LiveSetting="Polite"/>
          <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"
                     AutomationProperties.Name="Fortschrittstext" AutomationProperties.LiveSetting="Polite"/>
        </StackPanel>
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Start -->
          <Button Command="{Binding RunCommand}" Style="{StaticResource PrimaryButton}"
                  Width="140" Height="52" Margin="{DynamicResource SpaceRightXS}"
                  ToolTip="{Binding Loc[Start.RunTip]}" AutomationProperties.Name="{Binding Loc[Start.RunButton]}"
                  AutomationProperties.AcceleratorKey="F5" TabIndex="1">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Loc[Start.RunButton]}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <!-- Cancel -->
          <Button Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}"
                  Width="60" Height="52" Margin="{DynamicResource SpaceRightXS}"
                  AutomationProperties.AcceleratorKey="Esc"
                  ToolTip="{Binding Loc[Start.CancelTip]}" AutomationProperties.Name="{Binding Loc[Start.CancelButton]}" TabIndex="2">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Loc[Start.CancelButton]}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <!-- Rollback -->
          <Button Command="{Binding RollbackCommand}"
                  Width="110" Height="52" Margin="{DynamicResource SpaceRightXS}"
                  BorderBrush="{DynamicResource BrushAccentPurple}" Foreground="{DynamicResource BrushAccentPurple}"
                  AutomationProperties.AcceleratorKey="Ctrl+Z"
                  Background="{DynamicResource BrushDangerBg}" BorderThickness="2"
                  ToolTip="{Binding Loc[Start.RollbackTip]}" AutomationProperties.Name="{Binding Loc[Start.RollbackButton]}" TabIndex="3">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE777;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Loc[Start.RollbackButton]}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <TextBlock Text="{Binding BusyHint}" Style="{StaticResource CaptionText}"
                     VerticalAlignment="Center" Margin="4,0"/>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- ═══ MAIN CONTENT: SIDEBAR + VIEWS ════════════════════════════════ -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="56"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ═══ GUI-061: Vertical Sidebar Navigation ═══════════════════════ -->
      <Border Grid.Column="0" Background="{DynamicResource BrushSurfaceAlt}"
              BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,1,0">
        <DockPanel LastChildFill="False">
          <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
            <!-- Start -->
            <RadioButton GroupName="Nav" IsChecked="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Start}"
                         Style="{StaticResource NavButton}" ToolTip="{Binding Loc[Nav.Start]}" TabIndex="50"
                         AutomationProperties.Name="{Binding Loc[Nav.Start]}">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="20" HorizontalAlignment="Center"/>
            </RadioButton>
            <!-- Analyse -->
            <RadioButton GroupName="Nav" IsChecked="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Analyse}"
                         Style="{StaticResource NavButton}" ToolTip="{Binding Loc[Nav.Analyse]}" TabIndex="51"
                         AutomationProperties.Name="{Binding Loc[Nav.Analyse]}">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="20" HorizontalAlignment="Center"/>
            </RadioButton>
            <!-- Setup -->
            <RadioButton GroupName="Nav" IsChecked="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Setup}"
                         Style="{StaticResource NavButton}" ToolTip="{Binding Loc[Nav.Setup]}" TabIndex="52"
                         AutomationProperties.Name="{Binding Loc[Nav.Setup]}">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="20" HorizontalAlignment="Center"/>
            </RadioButton>
            <!-- Tools -->
            <RadioButton GroupName="Nav" IsChecked="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Tools}"
                         Style="{StaticResource NavButton}" ToolTip="{Binding Loc[Nav.Tools]}" TabIndex="53"
                         AutomationProperties.Name="{Binding Loc[Nav.Tools]}">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE90F;" FontSize="20" HorizontalAlignment="Center"/>
            </RadioButton>
            <!-- Log -->
            <RadioButton GroupName="Nav" IsChecked="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Log}"
                         Style="{StaticResource NavButton}" ToolTip="{Binding Loc[Nav.Log]}" TabIndex="54"
                         AutomationProperties.Name="{Binding Loc[Nav.Log]}">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE81C;" FontSize="20" HorizontalAlignment="Center"/>
            </RadioButton>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ CONTENT AREA (view switching) ═════════════════════════════ -->
      <Grid Grid.Column="1">
        <!-- GUI-064: Auto-switch to Progress during run -->
        <views:ProgressView Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

        <!-- Normal screens (hidden during run) -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVis}}">
          <views:StartView Visibility="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Start}"/>
          <views:ResultView x:Name="resultView" Visibility="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Analyse}"/>
          <views:SortView Visibility="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Setup}"/>
          <views:ToolsView DataContext="{Binding Tools}" Visibility="{Binding DataContext.SelectedNavTag, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Tools}"/>
          <views:SettingsView Visibility="{Binding SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Log}"/>
        </Grid>
      </Grid>

      <!-- ═══ GUI-055: Toast/Notification overlay ═════════════════════════ -->
      <ItemsControl Grid.Column="1" ItemsSource="{Binding Notifications}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,16,16" IsHitTestVisible="True"
                    AutomationProperties.LiveSetting="Assertive">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,4" Padding="14,10" CornerRadius="{DynamicResource RadiusMD}"
                    MinWidth="280" MaxWidth="420"
                    AutomationProperties.Name="{Binding Message}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Background" Value="{DynamicResource BrushSuccessBg}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccess}"/>
                  <Setter Property="BorderThickness" Value="1"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Type}" Value="Warning">
                      <Setter Property="Background" Value="{DynamicResource BrushWarningBg}"/>
                      <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Type}" Value="Error">
                      <Setter Property="Background" Value="{DynamicResource BrushDangerBg}"/>
                      <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12"
                         Foreground="{DynamicResource BrushTextPrimary}"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- ═══ GUI-081: First-Run-Wizard overlay ═══════════════════════════ -->
      <views:WizardView Grid.Column="0" Grid.ColumnSpan="2"
                        Visibility="{Binding ShowFirstRunWizard, Converter={StaticResource BoolToVis}}"
                        AutomationProperties.Name="{Binding Loc[Wizard.Title]}"/>

      <!-- ═══ GUI-101: Shortcut Cheatsheet overlay ══════════════════════ -->
      <Border Grid.Column="0" Grid.ColumnSpan="2"
              Background="#CC181825" IsHitTestVisible="True"
              Visibility="{Binding ShowShortcutSheet, Converter={StaticResource BoolToVis}}"
              MouseDown="OnShortcutOverlayClick">
        <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushAccentCyan}"
                BorderThickness="2" CornerRadius="16" Padding="32,24"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="480" MaxWidth="640"
                AutomationProperties.Name="{Binding Loc[Shortcuts.Title]}">
          <StackPanel>
            <DockPanel Margin="0,0,0,16">
              <TextBlock Text="{Binding Loc[Shortcuts.Title]}" FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
              <Button DockPanel.Dock="Right" Content="✕" Padding="8,4"
                      Command="{Binding ToggleShortcutSheetCommand}" HorizontalAlignment="Right"
                      Background="Transparent" BorderThickness="0"
                      Foreground="{DynamicResource BrushTextMuted}"
                      AutomationProperties.Name="{Binding Loc[Shortcuts.Close]}"/>
            </DockPanel>
            <UniformGrid Columns="2">
              <StackPanel Margin="0,0,16,0">
                <TextBlock Text="{Binding Loc[Shortcuts.SectionRun]}" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="F5"/><Run Text="  Preview starten"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+M"/><Run Text="  Move ausführen"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+D"/><Run Text="  Quick Preview"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Esc"/><Run Text="  Abbrechen"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+Z"/><Run Text="  Rollback"/></TextBlock>
                <TextBlock Text="{Binding Loc[Shortcuts.SectionNav]}" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushAccentCyan}" Margin="0,12,0,8"/>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+←"/><Run Text="  Zurück"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+→"/><Run Text="  Vorwärts"/></TextBlock>
              </StackPanel>
              <StackPanel>
                <TextBlock Text="{Binding Loc[Shortcuts.SectionTools]}" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+O"/><Run Text="  Ordner hinzufügen"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+R"/><Run Text="  Report öffnen"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+G"/><Run Text="  GameKey-Preview"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+S"/><Run Text="  Settings speichern"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+T"/><Run Text="  Theme wechseln"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+W"/><Run Text="  Watch-Mode"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="Ctrl+L"/><Run Text="  Log leeren"/></TextBlock>
                <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2"><Run FontWeight="Bold" Text="F1"/><Run Text="  Diese Hilfe"/></TextBlock>
              </StackPanel>
            </UniformGrid>
          </StackPanel>
        </Border>
      </Border>
    </Grid>
  </DockPanel>
</Window>

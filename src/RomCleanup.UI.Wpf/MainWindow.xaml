<Window x:Class="RomCleanup.UI.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:conv="clr-namespace:RomCleanup.UI.Wpf.Converters"
    Title="ROM Cleanup"
    Width="960" Height="720"
    MinWidth="720" MinHeight="520"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="13"
    Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushTextPrimary}"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

  <Window.Resources>
    <!-- ═══ CONVERTERS ════════════════════════════════════════════════════ -->
    <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    <conv:StatusLevelToBrushConverter x:Key="StatusToBrush"/>
    <conv:LogLevelToBrushConverter x:Key="LogLevelToBrush"/>

    <!-- ═══ DATA TEMPLATES ════════════════════════════════════════════════ -->
    <DataTemplate x:Key="LogEntryTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#x2022; " Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"/>
        <TextBlock Text="{Binding Text}" Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                   FontFamily="Consolas" FontSize="11"/>
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="RootItemTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="14"
                   Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Window.InputBindings>
    <KeyBinding Key="F5" Command="{Binding RunCommand}"/>
    <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    <KeyBinding Key="R" Modifiers="Control" Command="{Binding OpenReportCommand}"/>
    <KeyBinding Key="Z" Modifiers="Control" Command="{Binding RollbackCommand}"/>
  </Window.InputBindings>

  <DockPanel LastChildFill="True">

    <!-- ═══ TOP STATUS BAR ════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,0,0,1" Padding="12,8">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ComboBox x:Name="cmbQuickProfile" Width="160" Margin="4,0,4,0"
                    ToolTip="Konfigurationsprofil schnell wechseln" IsEditable="False"/>
          <Button Command="{Binding OpenReportCommand}" ToolTip="Letzten Bericht öffnen (Ctrl+R)" Margin="4,0,8,0"
                  AutomationProperties.Name="Letzten Bericht öffnen">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="14" Margin="0,0,8,0"/>
              <TextBlock Text="Bericht"/>
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
          <TextBlock Text="ROM CLEANUP" Style="{StaticResource TitleText}"
                     VerticalAlignment="Center" Margin="8,0,24,0"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <!-- Status dots bound to ViewModel StatusLevel via converter -->
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="4,0,4,0"
                   Fill="{Binding RootsStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="ROM-Ordner: Grün = konfiguriert, Grau = fehlt"/>
          <TextBlock Text="{Binding StatusRoots}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="4,0,4,0"
                   Fill="{Binding ToolsStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="Tools: Grün = chdman/7z gefunden, Grau = fehlt"/>
          <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="4,0,4,0"
                   Fill="{Binding DatStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="DAT-Verifizierung: Grün = aktiv, Grau = deaktiviert"/>
          <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="12,0,8,0"/>
          <Ellipse Width="14" Height="14" VerticalAlignment="Center" Margin="4,0,4,0"
                   Fill="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="Gesamtstatus: Grün = startbereit, Gelb = Warnung, Rot = blockiert"/>
          <TextBlock Text="{Binding StatusReady}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="12,0,8,0"/>
          <TextBlock Text="{Binding StatusRuntime}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══ FOOTER ACTION BAR ═════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,1,0,0" Padding="12,8">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ProgressBar MinWidth="120" Width="200" Height="8" Maximum="100"
                       Value="{Binding Progress}" Margin="8,0,0,0" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>
        </StackPanel>
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Start -->
          <Button Command="{Binding RunCommand}" Style="{StaticResource PrimaryButton}"
                  Width="140" Height="52" Margin="0,0,4,0"
                  ToolTip="Sortierung starten (F5)" AutomationProperties.Name="Sortierung starten" TabIndex="1">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="Starten" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <!-- Cancel -->
          <Button Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}"
                  Width="60" Height="52" Margin="0,0,4,0"
                  ToolTip="Lauf abbrechen (Esc)" AutomationProperties.Name="Lauf abbrechen" TabIndex="2">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="Stopp" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="8,0,8,0"/>
          <!-- Rollback -->
          <Button Command="{Binding RollbackCommand}"
                  Width="110" Height="52" Margin="0,0,4,0"
                  BorderBrush="{DynamicResource BrushAccentPurple}" Foreground="{DynamicResource BrushAccentPurple}"
                  Background="{DynamicResource BrushDangerBg}" BorderThickness="2"
                  ToolTip="Letzten Lauf rückgängig machen (Ctrl+Z)" AutomationProperties.Name="Letzten Lauf rückgängig machen" TabIndex="3">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE777;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="Rückgängig" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="8,0,8,0"/>
          <TextBlock Text="{Binding BusyHint}" Style="{StaticResource CaptionText}"
                     VerticalAlignment="Center" Margin="4,0"/>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- ═══ MAIN TABCONTROL ═══════════════════════════════════════════════ -->
    <TabControl x:Name="tabMain" Margin="0">

      <!-- ═══ SORTIEREN ═══════════════════════════════════════════════════ -->
      <TabItem Header="Sortieren">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>

            <!-- Step Indicator -->
            <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot1" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="Transparent" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="1 · Ordner" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding StepLabel1}" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Height="2" Width="32" VerticalAlignment="Center"
                        Background="{DynamicResource BrushBorder}" Margin="4,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot2" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="Transparent" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="2 · Optionen" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding StepLabel2}" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
                <Border Grid.Column="3" Height="2" Width="32" VerticalAlignment="Center"
                        Background="{DynamicResource BrushBorder}" Margin="4,0"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot3" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="Transparent" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="3 · Starten" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding StepLabel3}" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Quick-Start Presets -->
            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,8">
              <StackPanel>
                <TextBlock Text="QUICK-START" Style="{StaticResource SectionHeader}"/>
                <WrapPanel>
                  <Button Command="{Binding PresetSafeDryRunCommand}" Width="190" Height="48" Margin="0,0,8,4"
                          ToolTip="Sicherer DryRun: Nur prüfen, nichts verschieben" AutomationProperties.Name="Preset: Sicherer DryRun">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Sicherer DryRun" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Nur prüfen, nichts ändern" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding PresetFullSortCommand}" Width="190" Height="48" Margin="0,0,8,4"
                          ToolTip="Volle Sortierung: Alle Regionen, Standard-Regeln, DryRun aktiv" AutomationProperties.Name="Preset: Volle Sortierung">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Volle Sortierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Alle Regionen, Standard-Regeln" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding PresetConvertCommand}" Width="190" Height="48" Margin="0,0,8,4"
                          ToolTip="Konvertierung: Formate nach Move optimieren (CHD/RVZ)" AutomationProperties.Name="Preset: Konvertierung">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Konvertierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Formate optimieren (CHD/RVZ)" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Mode Toggle -->
            <Border CornerRadius="4" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" Margin="0,0,0,8" HorizontalAlignment="Left">
              <StackPanel Orientation="Horizontal">
                <RadioButton Content="Einfach" GroupName="UiMode"
                             IsChecked="{Binding IsSimpleMode}" Padding="12,4" MinWidth="70" Cursor="Hand"
                             ToolTip="Vereinfachte Ansicht: nur die wichtigsten Optionen"/>
                <RadioButton Content="Experte" GroupName="UiMode"
                             IsChecked="{Binding IsExpertMode}" Padding="12,4" MinWidth="70" Cursor="Hand"
                             ToolTip="Alle Konfigurationsoptionen anzeigen"/>
              </StackPanel>
            </Border>

            <!-- ROM Directories -->
            <Border Style="{StaticResource SectionCard}">
              <StackPanel>
                <TextBlock Text="ROM-VERZEICHNISSE" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Grid Grid.Column="0">
                    <ListBox x:Name="listRoots" MinHeight="90" MaxHeight="200" Margin="0,0,8,0"
                             ItemsSource="{Binding Roots}"
                             SelectedItem="{Binding SelectedRoot}"
                             AllowDrop="True"
                             ItemTemplate="{StaticResource RootItemTemplate}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             ToolTip="ROM-Ordner hier hineinziehen (Drag &amp; Drop)"/>
                    <!-- Empty-State Overlay -->
                    <Border IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,0,8,0"
                            Visibility="{Binding RootsStatusLevel, Converter={StaticResource InverseBoolToVis}, ConverterParameter=Ok}">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Roots.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"
                                   Margin="0,0,0,8" Opacity="0.6"/>
                        <TextBlock Text="ROM-Ordner hierher ziehen" FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Text="oder mit '+' hinzufügen" Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                  <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="118">
                    <Button Command="{Binding AddRootCommand}" Content="＋ Hinzufügen" Margin="0,0,0,4" HorizontalAlignment="Stretch"
                            ToolTip="Neuen ROM-Ordner zur Liste hinzufügen" AutomationProperties.Name="ROM-Ordner hinzufügen"/>
                    <Button Command="{Binding RemoveRootCommand}" Content="－ Entfernen" Margin="0,0,0,4" HorizontalAlignment="Stretch"
                            ToolTip="Ausgewählten ROM-Ordner entfernen (Entf)" AutomationProperties.Name="ROM-Ordner entfernen"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Simple Mode Panel -->
            <Border Style="{StaticResource SectionCard}"
                    Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
              <StackPanel>
                <TextBlock Text="SCHNELLSTART" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,8">
                  <TextBlock Text="Region:" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
                  <ComboBox x:Name="cmbEinfachRegion" Width="220" HorizontalAlignment="Left"
                            SelectedIndex="{Binding SimpleRegionIndex}">
                    <ComboBoxItem Content="Europa (EU)"/>
                    <ComboBoxItem Content="Nordamerika (US)"/>
                    <ComboBoxItem Content="Japan (JP)"/>
                    <ComboBoxItem Content="Weltweit (Alle)"/>
                  </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,0,8">
                  <TextBlock Text="Was soll passieren?" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
                  <CheckBox Content="Duplikate erkennen und aussortieren" IsChecked="{Binding SimpleDupes}" Margin="0,2"/>
                  <CheckBox Content="Junk-Dateien entfernen (Demos, Betas, Hacks)" IsChecked="{Binding SimpleJunk}" Margin="0,2"/>
                  <CheckBox Content="In Konsolen-Ordner sortieren" IsChecked="{Binding SimpleSort}" Margin="0,2"/>
                </StackPanel>
                <TextBlock Text="Ordner oben hinzufügen, dann unten auf 'Sortierung starten' klicken."
                           Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Expert Mode Panel -->
            <StackPanel Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVis}}">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="OPTIONEN" Style="{StaticResource SectionHeader}"/>
                  <WrapPanel>
                    <CheckBox Content="Nur Vorschau (Dry Run)" Margin="0,4,24,4"
                              IsChecked="{Binding DryRun}" Foreground="{DynamicResource BrushWarning}"
                              ToolTip="Es werden keine Dateien verschoben; nur Analyse + Bericht."/>
                    <CheckBox Content="Winner nach Move konvertieren (CHD/RVZ/ZIP)" Margin="0,4,24,4"
                              IsChecked="{Binding ConvertEnabled}"
                              ToolTip="Aktiviert Format-Konvertierung im Move-Lauf."/>
                  </WrapPanel>
                  <!-- DryRun Banner -->
                  <Border Margin="0,8,0,0" Padding="12,8"
                          Background="{DynamicResource BrushSuccessBg}" BorderBrush="{DynamicResource BrushSuccess}" BorderThickness="1"
                          CornerRadius="6"
                          Visibility="{Binding DryRun, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="DryRun aktiv: Es werden keine Dateien verschoben."
                                 Foreground="{DynamicResource BrushSuccess}" FontWeight="SemiBold" TextWrapping="Wrap"
                                 VerticalAlignment="Center"/>
                      <Button x:Name="btnStartMove" Content="▶ Jetzt als Move ausführen"
                              Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                              Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushDanger}" BorderBrush="{DynamicResource BrushDanger}"
                              BorderThickness="1" Cursor="Hand" Visibility="Collapsed"
                              ToolTip="Startet den Lauf erneut im Move-Modus."/>
                    </StackPanel>
                  </Border>
                  <!-- Move Complete Banner -->
                  <Border Margin="0,8,0,0" Padding="12,8"
                          Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1"
                          CornerRadius="6"
                          Visibility="{Binding ShowMoveCompleteBanner, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="Move abgeschlossen."
                                 Foreground="{DynamicResource BrushAccentPurple}" FontWeight="SemiBold" TextWrapping="Wrap"
                                 VerticalAlignment="Center"/>
                      <Button Command="{Binding RollbackCommand}" Content="&#xE777; Rückgängig machen"
                              FontFamily="Segoe MDL2 Assets, Segoe UI"
                              Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                              Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushAccentPurple}"
                              BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1" Cursor="Hand"
                              ToolTip="Letzten Move-Lauf rückgängig machen (Ctrl+Z)"
                              AutomationProperties.Name="Letzten Move-Lauf rückgängig machen"/>
                    </StackPanel>
                  </Border>
                  <TextBlock Text="Tipp: Erweiterte Sortier- und Sicherheitsoptionen findest du im Tab 'Konfiguration'."
                             Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <!-- Danger Zone (collapsed — Move confirmation via styled dialog) -->
              <Expander Header="Move-Modus (Gefahr)" Foreground="{DynamicResource BrushDanger}" Margin="0,16,0,0"
                        Visibility="Collapsed">
                <Border Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushDanger}" BorderThickness="1"
                        CornerRadius="8" Padding="12" Margin="0,8,0,0">
                  <StackPanel>
                    <TextBlock Text="⚠ GEFAHR: MOVE-MODUS" FontFamily="Consolas" FontWeight="Bold"
                               FontSize="10" Foreground="{DynamicResource BrushDanger}" Margin="0,0,0,8"/>
                    <TextBlock Text="Im Move-Modus werden Duplikate physisch verschoben. Stelle sicher, dass ein korrektes Backup existiert."
                               Foreground="{DynamicResource BrushDanger}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <CheckBox Content="Ich verstehe die Folgen – Move-Modus freischalten"
                              IsChecked="{Binding ConfirmMove}" Foreground="{DynamicResource BrushDanger}"/>
                  </StackPanel>
                </Border>
              </Expander>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ═══ KONFIGURATION ═══════════════════════════════════════════════ -->
      <TabItem Header="Konfiguration">
        <TabControl>

          <!-- ── REGELN ─────────────────────────────────────────────────── -->
          <TabItem Header="Regeln">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
              <StackPanel>
                <Expander Header="Sortieroptionen" IsExpanded="True" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <TextBlock Text="SORTIEROPTIONEN" Style="{StaticResource SectionHeader}"/>
                      <WrapPanel>
                        <CheckBox Content="Ordner nach Konsole strukturieren" Margin="0,4,24,4"
                                  IsChecked="{Binding SortConsole}" ToolTip="Erstellt Unterordner pro Konsole"/>
                        <CheckBox Content="Offensichtliche Junk-Dateien stärker filtern" Margin="0,4,24,4"
                                  IsChecked="{Binding AggressiveJunk}" ToolTip="Entfernt zusätzliche Beta/Proto/Sample-Dateien"/>
                        <CheckBox Content="Spielnamen vereinheitlichen" Margin="0,4,24,4"
                                  IsChecked="{Binding AliasKeying}" ToolTip="Gleicht bekannte Namensvarianten auf denselben Titel ab"/>
                      </WrapPanel>
                      <TextBlock Text="ℹ Diese Optionen sind optional. Für Standardläufe reicht der Sortieren-Tab."
                                 Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>

                      <Expander Header="Erweiterte Sortierung &amp; Sicherheit" Margin="0,16,0,0" IsExpanded="False">
                        <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                                CornerRadius="8" Padding="12" Margin="0,8,0,0">
                          <StackPanel>
                            <!-- Region Priority -->
                            <Grid Margin="0,0,0,8">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                              </Grid.ColumnDefinitions>
                              <Label Grid.Column="0" Content="Region-Prio:" VerticalAlignment="Top" Margin="0,2,0,0"/>
                              <StackPanel Grid.Column="1">
                                <WrapPanel>
                                  <CheckBox Content="EU"    Margin="0,0,12,4" IsChecked="{Binding PreferEU}"    ToolTip="Europa (EUR/PAL)"/>
                                  <CheckBox Content="US"    Margin="0,0,12,4" IsChecked="{Binding PreferUS}"    ToolTip="USA (NTSC)"/>
                                  <CheckBox Content="WORLD" Margin="0,0,12,4" IsChecked="{Binding PreferWORLD}" ToolTip="World-/Export-Versionen"/>
                                  <CheckBox Content="JP"    Margin="0,0,12,4" IsChecked="{Binding PreferJP}"    ToolTip="Japan"/>
                                </WrapPanel>
                                <Expander Header="Weitere Regionen" IsExpanded="False" Margin="0,2,0,0">
                                  <WrapPanel Margin="0,4,0,0">
                                    <CheckBox Content="DE"   Margin="0,0,12,4" IsChecked="{Binding PreferDE}"   ToolTip="Deutschland"/>
                                    <CheckBox Content="FR"   Margin="0,0,12,4" IsChecked="{Binding PreferFR}"   ToolTip="Frankreich"/>
                                    <CheckBox Content="IT"   Margin="0,0,12,4" IsChecked="{Binding PreferIT}"   ToolTip="Italien"/>
                                    <CheckBox Content="ES"   Margin="0,0,12,4" IsChecked="{Binding PreferES}"   ToolTip="Spanien"/>
                                    <CheckBox Content="AU"   Margin="0,0,12,4" IsChecked="{Binding PreferAU}"   ToolTip="Australien"/>
                                    <CheckBox Content="ASIA" Margin="0,0,12,4" IsChecked="{Binding PreferASIA}" ToolTip="Asien"/>
                                    <CheckBox Content="KR"   Margin="0,0,12,4" IsChecked="{Binding PreferKR}"   ToolTip="Südkorea"/>
                                    <CheckBox Content="CN"   Margin="0,0,12,4" IsChecked="{Binding PreferCN}"   ToolTip="China"/>
                                    <CheckBox Content="BR"   Margin="0,0,12,4" IsChecked="{Binding PreferBR}"   ToolTip="Brasilien"/>
                                    <CheckBox Content="NL"   Margin="0,0,12,4" IsChecked="{Binding PreferNL}"   ToolTip="Niederlande"/>
                                    <CheckBox Content="SE"   Margin="0,0,12,4" IsChecked="{Binding PreferSE}"   ToolTip="Schweden"/>
                                    <CheckBox Content="SCAN" Margin="0,0,12,4" IsChecked="{Binding PreferSCAN}" ToolTip="Skandinavien"/>
                                  </WrapPanel>
                                </Expander>
                              </StackPanel>
                            </Grid>
                            <TextBlock Text="Aktivierte Regionen werden bevorzugt behalten. Nicht aktivierte Regionen werden als Duplikat behandelt."
                                       Style="{StaticResource CaptionText}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- File type filters -->
                            <TextBlock Text="Dateitypen (keine Auswahl = alle Dateitypen scannen):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
                            <StackPanel Margin="0,0,0,8">
                              <TextBlock Text="Disc-Images" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkExtChd" Content=".chd" Margin="0,0,12,4" ToolTip="CHD Disk-Image"/>
                                <CheckBox x:Name="chkExtIso" Content=".iso" Margin="0,0,12,4" ToolTip="ISO-Abbild"/>
                                <CheckBox x:Name="chkExtCue" Content=".cue" Margin="0,0,12,4" ToolTip="CUE Steuerdatei"/>
                                <CheckBox x:Name="chkExtGdi" Content=".gdi" Margin="0,0,12,4" ToolTip="GDI (Dreamcast)"/>
                                <CheckBox x:Name="chkExtImg" Content=".img" Margin="0,0,12,4" ToolTip="IMG Disk-Image"/>
                                <CheckBox x:Name="chkExtBin" Content=".bin" Margin="0,0,12,4" ToolTip="BIN (CD-Image)"/>
                                <CheckBox x:Name="chkExtCso" Content=".cso" Margin="0,0,12,4" ToolTip="Compressed ISO (PSP)"/>
                                <CheckBox x:Name="chkExtPbp" Content=".pbp" Margin="0,0,12,4" ToolTip="PBP-Paket (PSP)"/>
                              </WrapPanel>
                              <TextBlock Text="Archive" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkExtZip" Content=".zip" Margin="0,0,12,4" ToolTip="ZIP-Archiv"/>
                                <CheckBox x:Name="chkExt7z"  Content=".7z"  Margin="0,0,12,4" ToolTip="7-Zip-Archiv"/>
                                <CheckBox x:Name="chkExtRar" Content=".rar" Margin="0,0,12,4" ToolTip="RAR-Archiv"/>
                              </WrapPanel>
                              <TextBlock Text="Cartridge / Modern" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkExtNes"  Content=".nes"  Margin="0,0,12,4" ToolTip="NES ROM"/>
                                <CheckBox x:Name="chkExtGba"  Content=".gba"  Margin="0,0,12,4" ToolTip="Game Boy Advance ROM"/>
                                <CheckBox x:Name="chkExtNds"  Content=".nds"  Margin="0,0,12,4" ToolTip="Nintendo DS ROM"/>
                                <CheckBox x:Name="chkExtNsp"  Content=".nsp"  Margin="0,0,12,4" ToolTip="NSP (Nintendo Switch)"/>
                                <CheckBox x:Name="chkExtXci"  Content=".xci"  Margin="0,0,12,4" ToolTip="XCI Cartridge-Image"/>
                                <CheckBox x:Name="chkExtWbfs" Content=".wbfs" Margin="0,0,12,4" ToolTip="WBFS (Wii Backup)"/>
                                <CheckBox x:Name="chkExtRvz"  Content=".rvz"  Margin="0,0,12,4" ToolTip="RVZ (GC/Wii, Dolphin)"/>
                              </WrapPanel>
                            </StackPanel>

                            <!-- Console filters -->
                            <TextBlock Text="Konsolen (keine Auswahl = alle Konsolen):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
                            <StackPanel Margin="0,0,0,4">
                              <TextBlock Text="Sony" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkConsPS1"  Content="PlayStation"   Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsPS2"  Content="PlayStation 2" Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsPS3"  Content="PlayStation 3" Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsPSP"  Content="PSP"           Margin="0,0,12,4"/>
                              </WrapPanel>
                              <TextBlock Text="Nintendo" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkConsNES"    Content="NES / Famicom"        Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsSNES"   Content="SNES / Super Famicom" Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsN64"    Content="Nintendo 64"          Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsGC"     Content="GameCube"             Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsWII"    Content="Wii"                  Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsWIIU"   Content="Wii U"                Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsSWITCH" Content="Nintendo Switch"      Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsGB"     Content="Game Boy"             Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsGBC"    Content="Game Boy Color"       Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsGBA"    Content="Game Boy Advance"     Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsNDS"    Content="Nintendo DS"          Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkCons3DS"    Content="Nintendo 3DS"         Margin="0,0,12,4"/>
                              </WrapPanel>
                              <TextBlock Text="Sega" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkConsMD"  Content="Mega Drive / Genesis" Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsSCD" Content="Mega-CD / Sega CD"    Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsSAT" Content="Saturn"               Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsDC"  Content="Dreamcast"            Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsSMS" Content="Master System"        Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsGG"  Content="Game Gear"            Margin="0,0,12,4"/>
                              </WrapPanel>
                              <TextBlock Text="Andere" Style="{StaticResource CategoryHeader}"/>
                              <WrapPanel>
                                <CheckBox x:Name="chkConsARCADE" Content="Arcade / MAME / FBNeo"     Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsNEOGEO" Content="Neo Geo"                    Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsNEOCD"  Content="Neo Geo CD"                 Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsPCE"    Content="PC Engine / TurboGrafx-16"  Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsPCECD"  Content="PC Engine CD"               Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsDOS"    Content="DOS / PC"                   Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkCons3DO"    Content="3DO"                        Margin="0,0,12,4"/>
                                <CheckBox x:Name="chkConsJAG"    Content="Atari Jaguar"               Margin="0,0,12,4"/>
                              </WrapPanel>
                            </StackPanel>

                            <!-- Safety mode -->
                            <TextBlock Text="SICHERHEITSMODUS" Style="{StaticResource SectionHeader}" Margin="0,12,0,8"/>
                            <CheckBox Content="Sicherheitsmodus aktiv (strikt + Rückfragen)" Margin="0,0,0,8"
                                      IsChecked="{Binding SafetyStrict}"
                                      ToolTip="Kombiniert strikte Sicherheitsregeln und zusätzliche Move-Bestätigungen."/>
                            <Grid Margin="0,2,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                              </Grid.ColumnDefinitions>
                              <Label Grid.Column="0" Content="Sicherheitsbereich:" VerticalAlignment="Center"/>
                              <TextBox Grid.Column="1" Text="{Binding ProtectedPaths, UpdateSourceTrigger=PropertyChanged}"
                                       ToolTip="Semikolon-getrennte Pfade für geschützte Bereiche"/>
                            </Grid>
                            <CheckBox Content="JP-Keep nur für ausgewählte Konsolen" Margin="0,4,0,0"
                                      IsChecked="{Binding JpOnlySelected}"
                                      ToolTip="JP-Versionen nur für die unten definierten Konsolen bevorzugen."/>
                            <Grid Margin="0,8,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                              </Grid.ColumnDefinitions>
                              <Label Grid.Column="0" Content="JP-Keep-Konsolen:" VerticalAlignment="Center"/>
                              <TextBox Grid.Column="1" Text="{Binding JpKeepConsoles, UpdateSourceTrigger=PropertyChanged}"
                                       ToolTip="Kommagetrennt: PS1,PS2"/>
                            </Grid>
                          </StackPanel>
                        </Border>
                      </Expander>
                    </StackPanel>
                  </Border>
                </Expander>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ── TOOLS &amp; DAT ──────────────────────────────────────────── -->
          <TabItem Header="Tools &amp; DAT">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
              <StackPanel>

                <!-- Tools -->
                <Expander Header="Tools" IsExpanded="False" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <Expander Header="Externe Tools (optional)" IsExpanded="False">
                        <StackPanel Margin="0,8,0,0">
                          <TextBlock Text="EXTERNE TOOLS" Style="{StaticResource SectionHeader}"/>
                          <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="100"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="38"/>
                              <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto"/>
                              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="chdman:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ToolChdman, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                            <Button x:Name="btnBrowseChdman" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                    AutomationProperties.Name="chdman durchsuchen"/>
                            <TextBlock x:Name="lblChdmanStatus" Grid.Row="0" Grid.Column="3" Text="–"
                                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="dolphintool:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ToolDolphin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                            <Button x:Name="btnBrowseDolphin" Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                    AutomationProperties.Name="dolphintool durchsuchen"/>
                            <TextBlock x:Name="lblDolphinStatus" Grid.Row="2" Grid.Column="3" Text="–"
                                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="7-Zip (7z):" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Tool7z, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                            <Button x:Name="btnBrowse7z" Grid.Row="4" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                    AutomationProperties.Name="7-Zip durchsuchen"/>
                            <TextBlock x:Name="lbl7zStatus" Grid.Row="4" Grid.Column="3" Text="–"
                                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>

                            <Label Grid.Row="6" Grid.Column="0" Content="psxtract:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ToolPsxtract, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                            <Button x:Name="btnBrowsePsxtract" Grid.Row="6" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                    AutomationProperties.Name="psxtract durchsuchen"/>
                            <TextBlock x:Name="lblPsxtractStatus" Grid.Row="6" Grid.Column="3" Text="–"
                                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>

                            <Label Grid.Row="8" Grid.Column="0" Content="ciso:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding ToolCiso, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                            <Button x:Name="btnBrowseCiso" Grid.Row="8" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                    AutomationProperties.Name="ciso durchsuchen"/>
                            <TextBlock x:Name="lblCisoStatus" Grid.Row="8" Grid.Column="3" Text="–"
                                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>
                          </Grid>
                          <Button x:Name="btnAutoFindTools" Content="Tools auto-entdecken"
                                  ToolTip="Sucht bekannte Konvertierungstools automatisch im System"
                                  Width="200" HorizontalAlignment="Left" Margin="0,16,0,0"
                                  AutomationProperties.Name="Externe Tools automatisch suchen"/>
                        </StackPanel>
                      </Expander>
                    </StackPanel>
                  </Border>
                </Expander>

                <!-- DAT Settings -->
                <Expander Header="DAT &amp; Hashes" IsExpanded="False" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <TextBlock Text="DAT-EINSTELLUNGEN" Style="{StaticResource SectionHeader}"/>
                      <CheckBox Content="DAT-Verifikation aktivieren" Margin="0,0,0,12"
                                IsChecked="{Binding UseDat}"
                                ToolTip="Vergleicht Dateien mit DAT-Datenbankeinträgen (Hashes)."/>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="120"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="6"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="DAT-Root:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DatRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <Button x:Name="btnBrowseDat" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                AutomationProperties.Name="DAT-Verzeichnis durchsuchen"/>
                        <Label Grid.Row="2" Grid.Column="0" Content="Hash-Typ:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbDatHash" Grid.Row="2" Grid.Column="1">
                          <ComboBoxItem Content="sha1" IsSelected="True"/>
                          <ComboBoxItem Content="md5"/>
                          <ComboBoxItem Content="crc32"/>
                        </ComboBox>
                      </Grid>
                      <WrapPanel Margin="0,12,0,0">
                        <CheckBox Content="DAT-Fallback aktivieren" Margin="0,0,24,0"
                                  IsChecked="{Binding DatFallback}"
                                  ToolTip="Wenn kein exakter Treffer gefunden wird, alternative DAT-Zuordnung versuchen."/>
                        <CheckBox Content="Basis-CRC bei Scan/Konvertierung" Margin="0,0,24,0"
                                  IsChecked="{Binding CrcVerifyScan}"
                                  ToolTip="Basis-CRC-Prüfung auf Datei-Ebene (unabhängig von DAT)."/>
                      </WrapPanel>
                      <TextBlock Text="ℹ DAT + CRC erhöhen Genauigkeit, können den Lauf aber deutlich verlangsamen."
                                 Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </Expander>

                <!-- DAT Mapping -->
                <Expander Header="DAT-Mapping" IsExpanded="False" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <TextBlock Text="KONSOLEN → DAT-MAPPING" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                      <TextBlock Text="Ordnet Konsolen manuell ihren DAT-Dateien zu. Ohne Zuordnung wird Auto-Erkennung verwendet."
                                 Style="{StaticResource CaptionText}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                      <DataGrid MinHeight="200" MaxHeight="400"
                                ItemsSource="{Binding DatMappings}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="True" CanUserDeleteRows="True"
                                SelectionMode="Single"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Recycling"
                                ScrollViewer.CanContentScroll="True">
                        <DataGrid.Resources>
                          <x:Array x:Key="DatConsoleItems" Type="{x:Type sys:String}">
                            <sys:String>PS1</sys:String>
                            <sys:String>PS2</sys:String>
                            <sys:String>PSP</sys:String>
                            <sys:String>DC</sys:String>
                            <sys:String>SAT</sys:String>
                            <sys:String>GC</sys:String>
                            <sys:String>WII</sys:String>
                          </x:Array>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                          <DataGridComboBoxColumn Header="Konsole"
                                                  SelectedItemBinding="{Binding Console}"
                                                  ItemsSource="{StaticResource DatConsoleItems}"
                                                  Width="130"/>
                          <DataGridTextColumn Header="DAT-Datei" Binding="{Binding DatFile}" Width="*"/>
                        </DataGrid.Columns>
                      </DataGrid>
                    </StackPanel>
                  </Border>
                </Expander>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ── PROFILE ──────────────────────────────────────────────────── -->
          <TabItem Header="Profile">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
              <StackPanel>
                <Expander Header="Profile" IsExpanded="False" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <TextBlock Text="PROFILE" Style="{StaticResource SectionHeader}"/>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="130"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Profilname:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbConfigProfile" Grid.Column="1" IsEditable="True"/>
                      </Grid>
                      <WrapPanel Margin="0,4,0,0">
                        <Button x:Name="btnProfileSave"   Content="Speichern"   Width="110" Margin="0,0,4,4" ToolTip="Aktuelle Einstellungen speichern"/>
                        <Button x:Name="btnProfileLoad"   Content="Laden"       Width="110" Margin="0,0,4,4" ToolTip="Gespeichertes Profil laden"/>
                        <Button x:Name="btnProfileDelete" Content="Löschen"     Width="110" Style="{StaticResource DangerButton}" Margin="0,0,4,4" ToolTip="Profil löschen"/>
                        <Button x:Name="btnProfileImport" Content="Importieren" Width="110" Margin="0,0,4,4" ToolTip="Profil importieren"/>
                        <Button x:Name="btnConfigDiff"    Content="Config-Diff" Width="110" Margin="0,0,4,4" ToolTip="Unterschiede anzeigen"/>
                      </WrapPanel>
                      <TextBlock Text="Profile speichern alle Einstellungen und können zwischen verschiedenen Sammlungen gewechselt werden."
                                 Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </Expander>

                <Expander Header="Allgemein" IsExpanded="False" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <TextBlock Text="ALLGEMEIN" Style="{StaticResource SectionHeader}"/>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="130"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="6"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Papierkorb:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TrashRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"
                                 ToolTip="Verzeichnis in das Duplikate verschoben werden (_TRASH)"/>
                        <Button x:Name="btnBrowseTrash" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                AutomationProperties.Name="Papierkorb-Ordner durchsuchen"/>
                        <Label Grid.Row="2" Grid.Column="0" Content="Log-Level:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbLogLevel" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2">
                          <ComboBoxItem Content="Debug"/>
                          <ComboBoxItem Content="Info" IsSelected="True"/>
                          <ComboBoxItem Content="Warning"/>
                          <ComboBoxItem Content="Error"/>
                        </ComboBox>
                      </Grid>
                    </StackPanel>
                  </Border>
                </Expander>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ── ERWEITERT ──────────────────────────────────────────────── -->
          <TabItem Header="Erweitert">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
              <StackPanel>
                <Expander Header="Audit &amp; System" IsExpanded="False" Margin="0,0,0,8">
                  <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                      <TextBlock Text="AUDIT &amp; SYSTEM" Style="{StaticResource SectionHeader}"/>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="130"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="6"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Audit-Root:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AuditRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <Button x:Name="btnBrowseAudit" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                AutomationProperties.Name="Audit-Verzeichnis durchsuchen"/>
                        <Label Grid.Row="2" Grid.Column="0" Content="PS3 Dupes-Root:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Ps3DupesRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <Button x:Name="btnBrowsePs3" Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                                AutomationProperties.Name="PS3 Dupes-Verzeichnis durchsuchen"/>
                      </Grid>

                      <TextBlock Text="GAMEKEY-VORSCHAU" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="130"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="6"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Titel:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GameKeyPreviewInput, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0" ToolTip="Beispieltitel für die GameKey-Normalisierung"/>
                        <Button Grid.Row="0" Grid.Column="2" Command="{Binding GameKeyPreviewCommand}" Content="Vorschau" Width="110"
                                AutomationProperties.Name="GameKey-Vorschau berechnen"/>
                        <Label Grid.Row="2" Grid.Column="0" Content="GameKey:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding GameKeyPreviewOutput}" Foreground="{DynamicResource BrushAccentCyan}" TextTrimming="CharacterEllipsis"/>
                      </Grid>

                      <TextBlock Text="KONFIGURATION" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
                      <WrapPanel>

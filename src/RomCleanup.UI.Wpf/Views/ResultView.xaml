<UserControl x:Class="RomCleanup.UI.Wpf.Views.ResultView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">

  <!-- ResultView: now only Dashboard (Library > Results).
       Protokoll → SystemActivityView, Report-Vorschau → LibraryReportView -->

  <Grid>
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16"
                Background="{DynamicResource BrushBackground}"
                Visibility="{Binding Run.HasRunData, Converter={StaticResource BoolToVis}}">
    <StackPanel>

          <!-- Run status summary banner -->
          <Border Padding="14,10" CornerRadius="8" Margin="0,0,0,16"
                  Visibility="{Binding Run.HasRunSummary, Converter={StaticResource BoolToVis}}">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BrushInfoBg}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Run.RunSummarySeverity}" Value="Warning">
                    <Setter Property="Background" Value="{DynamicResource BrushWarningBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Run.RunSummarySeverity}" Value="Error">
                    <Setter Property="Background" Value="{DynamicResource BrushDangerBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Run.RunSummarySeverity}" Value="Blocked">
                    <Setter Property="Background" Value="{DynamicResource BrushDangerBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="{Binding Run.RunSummaryText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextPrimary}" FontSize="14" FontWeight="SemiBold"/>
          </Border>

          <!-- GUI-070: 4 Large Primary MetricCards -->
          <UniformGrid Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource MetricCard}" MinHeight="100" Margin="0,0,8,0"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricGames]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Run.DashGames}" Foreground="{DynamicResource BrushAccentCyan}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricGames]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricGames]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinHeight="100" Margin="0,0,8,0"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricDupes]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Run.DashDupes}" Foreground="{DynamicResource BrushWarning}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricDupes]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricDupes]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinHeight="100" Margin="0,0,8,0"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricJunk]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushDanger}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Run.DashJunk}" Foreground="{DynamicResource BrushDanger}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricJunk]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricJunk]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinHeight="100"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricHealth]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Run.HealthScore}" Foreground="{DynamicResource BrushSuccess}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricHealth]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricHealth]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
          </UniformGrid>

          <!-- Secondary Metrics (expandable) -->
          <Expander Header="{Binding Loc[Result.PerfDetails], Mode=OneWay}" IsExpanded="{Binding Run.IsResultPerfDetailsExpanded, Mode=TwoWay}" Margin="0,0,0,12"
                   AutomationProperties.Name="{Binding Loc[Result.PerfDetails]}">
            <WrapPanel Margin="0,8,0,0" MaxWidth="1200">
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricMode]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Run.DashMode}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricWinners]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Run.DashWinners}" Foreground="{DynamicResource BrushSuccess}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricDuration]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Run.DashDuration}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricVerified]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Run.DashDatHits}" Foreground="{DynamicResource BrushSuccess}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricDedupeRate]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Run.DedupeRate}" Foreground="{DynamicResource BrushWarning}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
            </WrapPanel>
          </Expander>

          <!-- GUI-071 + GUI-104: Console Distribution — Bars + Pie side by side -->
          <Grid Margin="0,0,0,12"
                Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Bars (left) -->
            <Border Grid.Column="0" Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
              <StackPanel>
                <TextBlock Text="{Binding Loc[Result.ConsoleDistribution]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
                <ItemsControl ItemsSource="{Binding Run.ConsoleDistribution}" Margin="0,4,0,0"
                              AutomationProperties.Name="{Binding Loc[Result.ConsoleDistribution]}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,2" Height="24">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="100"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Foreground="{DynamicResource BrushTextPrimary}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource BrushSurface}" CornerRadius="3" Height="14" VerticalAlignment="Center">
                          <Border CornerRadius="3" Height="14" Background="{DynamicResource BrushAccentCyan}"
                                  HorizontalAlignment="Left">
                            <Border.Width>
                              <MultiBinding Converter="{StaticResource FractionToWidth}" ConverterParameter="bar">
                                <Binding Path="Fraction"/>
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                              </MultiBinding>
                            </Border.Width>
                          </Border>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding FileCount}" Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Pie Chart (right) -->
            <Border Grid.Column="1" Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="6,0,0,0"
                    Width="620">
              <StackPanel>
                <TextBlock Text="{Binding Loc[Result.ChartConsole]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
                <scott:WpfPlot x:Name="chartConsolePie" Height="520"
                               AutomationProperties.Name="{Binding Loc[Result.ChartConsole]}"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- GUI-106: Before/After Summary -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Result.BeforeAfter]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
              <scott:WpfPlot x:Name="chartBeforeAfter" Height="220"
                             AutomationProperties.Name="{Binding Loc[Result.BeforeAfter]}"/>
            </StackPanel>
          </Border>

          <!-- GUI-072/073: Dedup Decision Browser -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Result.DedupeDecisions]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
              <TreeView ItemsSource="{Binding Run.DedupeGroupItems}" MaxHeight="400" BorderThickness="0"
                        Background="Transparent" AutomationProperties.Name="{Binding Loc[Result.DedupeDecisions]}"
                        VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <TreeView.ItemTemplate>
                  <HierarchicalDataTemplate ItemsSource="{Binding Losers}">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                      <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                 Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                      <TextBlock Text="{Binding GameKey}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                      <TextBlock Text=" — " Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                      <TextBlock Text="&#x2605; " Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Winner.FileName}" Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
                      <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="R:{0} F:{1} V:{2}">
                            <Binding Path="Winner.RegionScore"/>
                            <Binding Path="Winner.FormatScore"/>
                            <Binding Path="Winner.VersionScore"/>
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </StackPanel>
                    <HierarchicalDataTemplate.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                          <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                     Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                          <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                          <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"
                                     Opacity="0.7">
                            <TextBlock.Text>
                              <MultiBinding StringFormat="[{0}] R:{1} F:{2} V:{3}">
                                <Binding Path="Region"/>
                                <Binding Path="RegionScore"/>
                                <Binding Path="FormatScore"/>
                                <Binding Path="VersionScore"/>
                              </MultiBinding>
                            </TextBlock.Text>
                          </TextBlock>
                        </StackPanel>
                      </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                  </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </StackPanel>
          </Border>

          <!-- GUI-074: Move CTA with consequence text -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushDanger}"
                  BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12"
                  Visibility="{Binding ShowStartMoveButton, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding Loc[Result.ApplyWarningTitle]}" FontSize="15" FontWeight="Bold"
               Foreground="{DynamicResource BrushDanger}" HorizontalAlignment="Center"
               Margin="0,0,0,6"/>
                <TextBlock Text="{Binding MoveApplyGateText}" FontSize="12" TextWrapping="Wrap"
               Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
               TextAlignment="Center" Margin="0,0,0,8" MaxWidth="520"/>
              <TextBlock Text="{Binding Run.MoveConsequenceText}" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              <!-- GUI-075: Trust signal -->
              <TextBlock Text="{Binding Loc[Result.TrustSignal]}" Style="{StaticResource CaptionText}"
                         HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.8"
                         Foreground="{DynamicResource BrushSuccess}"/>
            </StackPanel>
          </Border>

          <!-- Open Report Button -->
          <Button Command="{Binding OpenReportCommand}" HorizontalAlignment="Right" Padding="16,8"
                  ToolTip="{Binding Loc[Result.OpenReportTip]}"
                  AutomationProperties.Name="{Binding Loc[Result.OpenReportTip]}"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Text="{Binding Loc[Result.OpenReport]}"/>
            </StackPanel>
          </Button>

        </StackPanel>
      </ScrollViewer>

      <!-- Empty state: no analysis data yet -->
      <StackPanel Visibility="{Binding Run.HasRunData, Converter={StaticResource InverseBoolToVis}}"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
        <TextBlock Text="Noch keine Analyse-Daten" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Text="Starte eine Vorschau mit F5 um die Ergebnisse zu sehen."
                   Foreground="{DynamicResource BrushTextMuted}" FontSize="12" HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Protokoll → SystemActivityView, Report-Vorschau → LibraryReportView -->
  </Grid>
</UserControl>

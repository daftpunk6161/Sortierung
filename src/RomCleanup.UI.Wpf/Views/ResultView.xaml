<UserControl x:Class="RomCleanup.UI.Wpf.Views.ResultView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">
  <UserControl.Resources>
    <DataTemplate x:Key="LogEntryTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#x2022; " Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"/>
        <TextBlock Text="{Binding Text}" Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                   FontFamily="Consolas" FontSize="11"/>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Background="{DynamicResource BrushBackground}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180" MinWidth="140" MaxWidth="240"/>
      <ColumnDefinition Width="1"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══ SIDEBAR NAVIGATION ═══════════════════════════════════════════ -->
    <Border Grid.Column="0" Background="{DynamicResource BrushSurface}" Padding="0,12">
      <ListBox Background="Transparent" BorderThickness="0"
               SelectedValue="{Binding SelectedResultSection, Mode=TwoWay}"
               SelectedValuePath="Tag"
               ItemContainerStyle="{DynamicResource SidebarNavItem}"
               AutomationProperties.Name="{Binding Loc[Result.NavCategories]}">
        <ListBoxItem Tag="Dashboard" Content="{Binding Loc[Result.NavDashboard]}" AutomationProperties.Name="{Binding Loc[Result.NavDashboard]}"/>
        <ListBoxItem Tag="Protokoll" Content="{Binding Loc[Result.NavLog]}" AutomationProperties.Name="{Binding Loc[Result.NavLog]}"/>
        <ListBoxItem Tag="Report-Vorschau" Content="{Binding Loc[Result.NavReport]}" AutomationProperties.Name="{Binding Loc[Result.NavReport]}"/>
      </ListBox>
    </Border>

    <!-- Divider -->
    <Border Grid.Column="1" Background="{DynamicResource BrushBorder}"/>

    <!-- ═══ CONTENT AREA ═══════════════════════════════════════════════ -->
    <Grid Grid.Column="2">

      <!-- ── Dashboard ── -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16"
                    Visibility="{Binding SelectedResultSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Dashboard}">
        <StackPanel>

          <!-- GUI-070: 4 Large Primary MetricCards -->
          <UniformGrid Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource MetricCard}" MinHeight="100" Margin="0,0,8,0"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricGames]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding DashGames}" Foreground="{DynamicResource BrushAccentCyan}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricGames]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricGames]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinHeight="100" Margin="0,0,8,0"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricDupes]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding DashDupes}" Foreground="{DynamicResource BrushWarning}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricDupes]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricDupes]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinHeight="100" Margin="0,0,8,0"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricJunk]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushDanger}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding DashJunk}" Foreground="{DynamicResource BrushDanger}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricJunk]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricJunk]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinHeight="100"
                    Focusable="True" AutomationProperties.Name="{Binding Loc[Result.MetricHealth]}">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                           Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding HealthScore}" Foreground="{DynamicResource BrushSuccess}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="{Binding Loc[Result.MetricHealth]}" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding Loc[Result.MetricHealth]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
          </UniformGrid>

          <!-- Secondary Metrics (expandable) -->
          <Expander Header="{Binding Loc[Result.PerfDetails]}" IsExpanded="False" Margin="0,0,0,12">
            <WrapPanel Margin="0,8,0,0" MaxWidth="1200">
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricMode]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding DashMode}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricWinners]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding DashWinners}" Foreground="{DynamicResource BrushSuccess}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricDuration]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding DashDuration}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricVerified]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding DashDatHits}" Foreground="{DynamicResource BrushSuccess}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Loc[Result.MetricDedupeRate]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding DedupeRate}" Foreground="{DynamicResource BrushWarning}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
            </WrapPanel>
          </Expander>

          <!-- GUI-071: Console Distribution Bars -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Result.ConsoleDistribution]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
              <ItemsControl ItemsSource="{Binding ConsoleDistribution}" Margin="0,4,0,0"
                            AutomationProperties.Name="{Binding Loc[Result.ConsoleDistribution]}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,2" Height="24">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Foreground="{DynamicResource BrushTextPrimary}"
                                 FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Background="{DynamicResource BrushSurface}" CornerRadius="3" Height="14" VerticalAlignment="Center">
                        <Border CornerRadius="3" Height="14" Background="{DynamicResource BrushAccentCyan}"
                                HorizontalAlignment="Left">
                          <Border.Width>
                            <MultiBinding Converter="{StaticResource FractionToWidth}" ConverterParameter="bar">
                              <Binding Path="Fraction"/>
                              <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                            </MultiBinding>
                          </Border.Width>
                        </Border>
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding FileCount}" Foreground="{DynamicResource BrushTextMuted}"
                                 FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- GUI-104: Console Distribution Pie Chart -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Result.ChartConsole]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
              <scott:WpfPlot x:Name="chartConsolePie" Height="280"
                             AutomationProperties.Name="{Binding Loc[Result.ChartConsole]}"/>
            </StackPanel>
          </Border>

          <!-- GUI-106: Before/After Summary -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Result.BeforeAfter]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
              <scott:WpfPlot x:Name="chartBeforeAfter" Height="220"
                             AutomationProperties.Name="{Binding Loc[Result.BeforeAfter]}"/>
            </StackPanel>
          </Border>

          <!-- GUI-072/073: Dedup Decision Browser -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                  BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Result.DedupeDecisions]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
              <TreeView ItemsSource="{Binding DedupeGroupItems}" MaxHeight="400" BorderThickness="0"
                        Background="Transparent" AutomationProperties.Name="{Binding Loc[Result.DedupeDecisions]}"
                        VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <TreeView.ItemTemplate>
                  <HierarchicalDataTemplate ItemsSource="{Binding Losers}">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                      <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                 Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                      <TextBlock Text="{Binding GameKey}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                      <TextBlock Text=" — " Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                      <TextBlock Text="&#x2605; " Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Winner.FileName}" Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
                      <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="R:{0} F:{1} V:{2}">
                            <Binding Path="Winner.RegionScore"/>
                            <Binding Path="Winner.FormatScore"/>
                            <Binding Path="Winner.VersionScore"/>
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </StackPanel>
                    <HierarchicalDataTemplate.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                          <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                     Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                          <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                          <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"
                                     Opacity="0.7">
                            <TextBlock.Text>
                              <MultiBinding StringFormat="[{0}] R:{1} F:{2} V:{3}">
                                <Binding Path="Region"/>
                                <Binding Path="RegionScore"/>
                                <Binding Path="FormatScore"/>
                                <Binding Path="VersionScore"/>
                              </MultiBinding>
                            </TextBlock.Text>
                          </TextBlock>
                        </StackPanel>
                      </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                  </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </StackPanel>
          </Border>

          <!-- GUI-074: Move CTA with consequence text -->
          <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushDanger}"
                  BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12"
                  Visibility="{Binding ShowStartMoveButton, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Danger-Zone: Apply (Move)" FontSize="15" FontWeight="Bold"
               Foreground="{DynamicResource BrushDanger}" HorizontalAlignment="Center"
               Margin="0,0,0,6"/>
                <TextBlock Text="{Binding MoveApplyGateText}" FontSize="12" TextWrapping="Wrap"
               Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
               TextAlignment="Center" Margin="0,0,0,8" MaxWidth="520"/>
              <TextBlock Text="{Binding MoveConsequenceText}" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              <Button Command="{Binding StartMoveCommand}" MinWidth="260" Height="44" Cursor="Hand"
                      Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushDanger}"
                      BorderBrush="{DynamicResource BrushDanger}" BorderThickness="2" FontSize="16" FontWeight="Bold"
                  ToolTip="{Binding MoveApplyGateText}"
                      AutomationProperties.Name="{Binding Loc[Result.BtnCleanup]}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBlock Text="{Binding Loc[Result.BtnCleanup]}" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <!-- GUI-075: Trust signal -->
              <TextBlock Text="{Binding Loc[Result.TrustSignal]}" Style="{StaticResource CaptionText}"
                         HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.8"
                         Foreground="{DynamicResource BrushSuccess}"/>
            </StackPanel>
          </Border>

          <!-- Open Report Button -->
          <Button Command="{Binding OpenReportCommand}" HorizontalAlignment="Right" Padding="16,8"
                  ToolTip="{Binding Loc[Result.OpenReportTip]}"
                  AutomationProperties.Name="{Binding Loc[Result.OpenReportTip]}"
                  Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Text="{Binding Loc[Result.OpenReport]}"/>
            </StackPanel>
          </Button>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Protokoll ── -->
      <DockPanel Visibility="{Binding SelectedResultSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Protokoll}">
        <!-- Log Footer -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BrushSurfaceAlt}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="12,8">
          <StackPanel Orientation="Horizontal">
            <Button Command="{Binding ClearLogCommand}" Content="{Binding Loc[Result.ClearLog]}" MinWidth="118" Padding="8,2" Margin="{DynamicResource SpaceRightSM}" AutomationProperties.Name="{Binding Loc[Result.ClearLog]}"/>
            <Button Content="{Binding Loc[Result.ExportLog]}" MinWidth="130" Padding="8,2"
                    Command="{Binding FeatureCommands[ExportLog]}" AutomationProperties.Name="{Binding Loc[Result.ExportLog]}"/>
          </StackPanel>
        </Border>
        <ListBox x:Name="listLog"
                 ItemsSource="{Binding LogEntries}"
                 Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushAccentCyan}"
                 FontFamily="Consolas" FontSize="11"
                 BorderThickness="0" Margin="12"
                 ItemTemplate="{StaticResource LogEntryTemplate}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 AutomationProperties.Name="{Binding Loc[Result.LogEntries]}"/>
      </DockPanel>

      <!-- ── Report-Vorschau ── -->
      <DockPanel Visibility="{Binding SelectedResultSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Report-Vorschau}">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,16,20,8">
          <TextBlock Text="{Binding Loc[Result.ReportPreviewHeader]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceRightSM}"/>
          <Button x:Name="btnRefreshReportPreview" Width="120" Height="28" Content="{Binding Loc[Result.Refresh]}"
                  AutomationProperties.Name="{Binding Loc[Result.RefreshReportTip]}"/>
        </StackPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1" CornerRadius="6" Padding="8" Margin="20,0,20,8">
          <StackPanel>
            <TextBlock Text="{Binding Loc[Result.ErrorSummary]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomXS}"/>
            <ListBox MinHeight="60"
                     ItemsSource="{Binding ErrorSummaryItems}"
                     DisplayMemberPath="DisplayText"
                     Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushWarning}"
                     BorderThickness="0" FontFamily="Consolas" FontSize="11"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     AutomationProperties.Name="{Binding Loc[Result.ErrorSummary]}"
                     AutomationProperties.LiveSetting="Assertive"/>
          </StackPanel>
        </Border>
        <wv2:WebView2 x:Name="webReportPreview" Margin="20,0,20,16" MinHeight="80"
                     AutomationProperties.Name="{Binding Loc[Result.ReportPreviewLabel]}"
                     AutomationProperties.HelpText="{Binding Loc[Result.ReportPreviewHelp]}"/>
      </DockPanel>

    </Grid>
  </Grid>
</UserControl>

<UserControl x:Class="RomCleanup.UI.Wpf.Views.SystemActivityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- Extracted from ResultView "Protokoll" section -->
  <UserControl.Resources>
    <DataTemplate x:Key="LogEntryTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#x2022; " Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"/>
        <TextBlock Text="{Binding Text}" Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                   FontFamily="Consolas" FontSize="11"/>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <DockPanel Background="{DynamicResource BrushBackground}">
    <!-- Log Footer -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource BrushSurfaceAlt}"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="12,8">
      <StackPanel Orientation="Horizontal">
        <Button Command="{Binding ClearLogCommand}" Content="{Binding Loc[Result.ClearLog]}" MinWidth="118" Padding="8,2" Margin="{DynamicResource SpaceRightSM}" AutomationProperties.Name="{Binding Loc[Result.ClearLog]}"/>
        <Button Content="{Binding Loc[Result.ExportLog]}" MinWidth="130" Padding="8,2"
                Command="{Binding FeatureCommands[ExportLog]}" AutomationProperties.Name="{Binding Loc[Result.ExportLog]}"/>
      </StackPanel>
    </Border>
    <Grid>
      <ListBox x:Name="listLog"
               ItemsSource="{Binding LogEntries}"
               Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushAccentCyan}"
               FontFamily="Consolas" FontSize="11"
               BorderThickness="0" Margin="12"
               ItemTemplate="{StaticResource LogEntryTemplate}"
               VirtualizingPanel.IsVirtualizing="True"
               VirtualizingPanel.VirtualizationMode="Recycling"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.CanContentScroll="True"
               AutomationProperties.Name="{Binding Loc[Result.LogEntries]}"/>
      <!-- Empty state -->
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                  IsHitTestVisible="False" x:Name="LogEmptyState">
        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="Noch keine Protokoll-Einträge" FontSize="14"
                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
      </StackPanel>
    </Grid>
  </DockPanel>
</UserControl>

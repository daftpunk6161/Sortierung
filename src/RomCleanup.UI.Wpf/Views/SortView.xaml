<UserControl x:Class="RomCleanup.UI.Wpf.Views.SortView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <UserControl.Resources>
    <DataTemplate x:Key="RootItemTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="14"
                   Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsIdle}">
    <StackPanel Margin="20,16">

      <!-- ── Quick-Start Presets ── -->
      <TextBlock Text="{Binding Loc[Sort.QuickStart]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
        <StackPanel>
          <TextBlock Text="{Binding Loc[Sort.Presets]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" Margin="{DynamicResource SpaceBottomXS}"/>
          <Border CornerRadius="6" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                  Background="{DynamicResource BrushSurface}" HorizontalAlignment="Left" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
              <RadioButton GroupName="Preset" Padding="14,10" MinWidth="180" Cursor="Hand"
                           IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=SafeDryRun}"
                           Command="{Binding PresetSafeDryRunCommand}"
                           ToolTip="{Binding Loc[Sort.PresetSafeDryRunTip]}"
                           TabIndex="20"
                           AutomationProperties.Name="{Binding Loc[Sort.PresetSafeDryRun]}">
                <StackPanel>
                  <TextBlock Text="{Binding Loc[Sort.PresetSafeDryRun]}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Loc[Sort.PresetSafeDryRunDesc]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <Border Width="1" Background="{DynamicResource BrushBorder}" Margin="0,4"/>
              <RadioButton GroupName="Preset" Padding="14,10" MinWidth="180" Cursor="Hand"
                           IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=FullSort}"
                           Command="{Binding PresetFullSortCommand}"
                           ToolTip="Volle Sortierung: Alle Regionen, Standard-Regeln, Vorschau aktiv"
                           TabIndex="21"
                           AutomationProperties.Name="{Binding Loc[Sort.PresetFullSort]}">
                <StackPanel>
                  <TextBlock Text="{Binding Loc[Sort.PresetFullSort]}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Loc[Sort.PresetFullSortDesc]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <Border Width="1" Background="{DynamicResource BrushBorder}" Margin="0,4"/>
              <RadioButton GroupName="Preset" Padding="14,10" MinWidth="180" Cursor="Hand"
                           IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Convert}"
                           Command="{Binding PresetConvertCommand}"
                           ToolTip="{Binding Loc[Sort.PresetConvertTip]}"
                           TabIndex="22"
                           AutomationProperties.Name="{Binding Loc[Sort.PresetConvert]}">
                <StackPanel>
                  <TextBlock Text="{Binding Loc[Sort.PresetConvert]}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding Loc[Sort.PresetConvertDesc]}" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Simple Mode Panel -->
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}"
              Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <TextBlock Text="{Binding Loc[Sort.SimpleQuickStart]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
          <StackPanel Margin="{DynamicResource SpaceBottomSM}">
            <TextBlock Text="{Binding Loc[Sort.LabelRegion]}" Margin="{DynamicResource SpaceBottomXS}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
            <WrapPanel>
              <CheckBox Content="EU"    Margin="0,0,12,4" IsChecked="{Binding PreferEU}"    ToolTip="{Binding Loc[Sort.RegionToolTipEU]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipEU]}" TabIndex="30"/>
              <CheckBox Content="US"    Margin="0,0,12,4" IsChecked="{Binding PreferUS}"    ToolTip="{Binding Loc[Sort.RegionToolTipUS]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipUS]}" TabIndex="31"/>
              <CheckBox Content="WORLD" Margin="0,0,12,4" IsChecked="{Binding PreferWORLD}" ToolTip="{Binding Loc[Sort.RegionToolTipWORLD]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipWORLD]}" TabIndex="32"/>
              <CheckBox Content="JP"    Margin="0,0,12,4" IsChecked="{Binding PreferJP}"    ToolTip="{Binding Loc[Sort.RegionToolTipJP]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipJP]}" TabIndex="33"/>
            </WrapPanel>
          </StackPanel>
          <StackPanel Margin="{DynamicResource SpaceBottomSM}">
            <TextBlock Text="{Binding Loc[Sort.WhatAction]}" Margin="{DynamicResource SpaceBottomXS}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
            <CheckBox Content="{Binding Loc[Sort.ActionDupes]}" IsChecked="{Binding SimpleDupes}" Margin="0,2"
                      ToolTip="{Binding Loc[Sort.ActionDupesTip]}" TabIndex="31"/>
            <CheckBox Content="{Binding Loc[Sort.ActionJunk]}" IsChecked="{Binding SimpleJunk}" Margin="0,2"
                      ToolTip="{Binding Loc[Sort.ActionJunkTip]}" TabIndex="32"/>
            <CheckBox Content="{Binding Loc[Sort.ActionSort]}" IsChecked="{Binding SimpleSort}" Margin="0,2"
                      ToolTip="{Binding Loc[Sort.ActionSortTip]}" TabIndex="33"/>
          </StackPanel>
          <TextBlock Text="{Binding Loc[Sort.SimpleHint]}"
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- ── ROM-Verzeichnisse ── -->
      <TextBlock Text="{Binding Loc[Sort.RomDirectories]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
        <Grid Margin="{DynamicResource SpaceBottomXS}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0">
            <ListBox x:Name="listRoots" MinHeight="60" MaxHeight="280" Margin="{DynamicResource SpaceRightSM}"
                     ItemsSource="{Binding Roots}"
                     SelectedItem="{Binding SelectedRoot}"
                     AllowDrop="True"
                     ItemTemplate="{StaticResource RootItemTemplate}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     ToolTip="{Binding Loc[Sort.RootsDragTip]}"
                     TabIndex="10"
                     AutomationProperties.Name="{Binding Loc[Sort.RootsListName]}">
              <ListBox.InputBindings>
                <KeyBinding Key="Delete" Command="{Binding RemoveRootCommand}"/>
              </ListBox.InputBindings>
            </ListBox>
            <!-- Empty-State Overlay -->
            <Border IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="{DynamicResource SpaceRightSM}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Roots.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"
                           Margin="{DynamicResource SpaceBottomSM}" Opacity="0.6"/>
                <TextBlock Text="{Binding Loc[Sort.RootsEmptyDrag]}" FontSize="12"
                           Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Loc[Sort.RootsEmptyAdd]}" Style="{StaticResource CaptionText}"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
              </StackPanel>
            </Border>
          </Grid>
          <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="118">
            <Button Command="{Binding AddRootCommand}" Content="{Binding Loc[Sort.AddRoot]}" Margin="{DynamicResource SpaceBottomXS}" HorizontalAlignment="Stretch"
                    ToolTip="{Binding Loc[Sort.AddRootTip]}" AutomationProperties.Name="{Binding Loc[Sort.AddRootTip]}"
                    TabIndex="11"/>
            <Button Command="{Binding RemoveRootCommand}" Content="{Binding Loc[Sort.RemoveRoot]}" Margin="{DynamicResource SpaceBottomXS}" HorizontalAlignment="Stretch"
                    ToolTip="{Binding Loc[Sort.RemoveRootTip]}" AutomationProperties.Name="{Binding Loc[Sort.RemoveRootTip]}"
                    TabIndex="12"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── Optionen ── -->
      <TextBlock Text="{Binding Loc[Sort.Options]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
        <StackPanel>
          <WrapPanel>
            <CheckBox Content="{Binding Loc[Sort.DryRunOption]}" Margin="0,4,24,4"
                      IsChecked="{Binding DryRun}" Foreground="{DynamicResource BrushWarning}"
                      ToolTip="{Binding Loc[Sort.DryRunOptionTip]}" TabIndex="40"/>
            <CheckBox Content="{Binding Loc[Sort.ConvertOption]}" Margin="0,4,24,4"
                      IsChecked="{Binding ConvertEnabled}"
                      ToolTip="{Binding Loc[Sort.ConvertOptionTip]}" TabIndex="41"/>
          </WrapPanel>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
            <TextBlock Text="{Binding Loc[Sort.LabelConflict]}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
            <ComboBox Width="160" SelectedIndex="{Binding ConflictPolicyIndex, Mode=TwoWay}"
                      ToolTip="{Binding Loc[Sort.ConflictTip]}"
                      AutomationProperties.Name="{Binding Loc[Sort.ConflictLabel]}">
              <ComboBoxItem Content="{Binding Loc[Sort.ConflictRename]}"/>
              <ComboBoxItem Content="{Binding Loc[Sort.ConflictSkip]}"/>
              <ComboBoxItem Content="{Binding Loc[Sort.ConflictOverwrite]}"/>
            </ComboBox>
          </StackPanel>
          <!-- DryRun Banner -->
          <Border Margin="0,8,0,0" Padding="12,8"
                  Background="{DynamicResource BrushInfoBg}" BorderBrush="{DynamicResource BrushAccentCyan}" BorderThickness="1"
                  CornerRadius="6"
                  Visibility="{Binding DryRun, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Sort.DryRunBanner]}"
                         Foreground="{DynamicResource BrushAccentCyan}" FontWeight="SemiBold" TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding MoveApplyGateText}" Margin="0,6,0,0" TextWrapping="Wrap"
                         Foreground="{DynamicResource BrushTextPrimary}"/>
            </StackPanel>
          </Border>
          <!-- Move Complete Banner -->
          <Border Margin="0,8,0,0" Padding="12,8"
              Background="{DynamicResource BrushWarningBg}" BorderBrush="{DynamicResource BrushWarning}" BorderThickness="1"
                  CornerRadius="6"
                  Visibility="{Binding ShowMoveCompleteBanner, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding Loc[Sort.MoveComplete]}"
               Foreground="{DynamicResource BrushWarning}" FontWeight="SemiBold" TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
              <Button Command="{Binding RollbackCommand}"
                      Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                  Background="{DynamicResource BrushWarningBg}" Foreground="{DynamicResource BrushWarning}"
                  BorderBrush="{DynamicResource BrushWarning}" BorderThickness="1" Cursor="Hand"
                      ToolTip="{Binding Loc[Sort.RollbackTip]}"
                      AutomationProperties.Name="{Binding Loc[Sort.RollbackTip]}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Loc[Sort.RollbackLabel]}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
          <TextBlock Text="{Binding Loc[Sort.OptionsTip]}"
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- ── Regionen (Expert) ── -->
      <TextBlock Text="{Binding Loc[Sort.RegionPriority]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"
                 Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVis}}"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}"
              Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <TextBlock Text="{Binding Loc[Sort.RegionPriorityDesc]}"
                     Style="{StaticResource CaptionText}" Margin="{DynamicResource SpaceBottomSM}" TextWrapping="Wrap"/>
          <WrapPanel>
            <CheckBox Content="EU"    Margin="0,0,12,4" IsChecked="{Binding PreferEU}"    ToolTip="{Binding Loc[Sort.RegionToolTipEU]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipEU]}"/>
            <CheckBox Content="US"    Margin="0,0,12,4" IsChecked="{Binding PreferUS}"    ToolTip="{Binding Loc[Sort.RegionToolTipUS]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipUS]}"/>
            <CheckBox Content="WORLD" Margin="0,0,12,4" IsChecked="{Binding PreferWORLD}" ToolTip="{Binding Loc[Sort.RegionToolTipWORLD]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipWORLD]}"/>
            <CheckBox Content="JP"    Margin="0,0,12,4" IsChecked="{Binding PreferJP}"    ToolTip="{Binding Loc[Sort.RegionToolTipJP]}" AutomationProperties.Name="{Binding Loc[Sort.RegionToolTipJP]}"/>
          </WrapPanel>
          <Expander Header="{Binding Loc[Sort.MoreRegions], Mode=OneWay}" IsExpanded="False" Margin="0,2,0,0">
            <WrapPanel Margin="0,4,0,0">
              <CheckBox Content="DE"   Margin="0,0,12,4" IsChecked="{Binding PreferDE}"   ToolTip="Deutschland" AutomationProperties.Name="Region Deutschland bevorzugen"/>
              <CheckBox Content="FR"   Margin="0,0,12,4" IsChecked="{Binding PreferFR}"   ToolTip="Frankreich" AutomationProperties.Name="Region Frankreich bevorzugen"/>
              <CheckBox Content="IT"   Margin="0,0,12,4" IsChecked="{Binding PreferIT}"   ToolTip="Italien" AutomationProperties.Name="Region Italien bevorzugen"/>
              <CheckBox Content="ES"   Margin="0,0,12,4" IsChecked="{Binding PreferES}"   ToolTip="Spanien" AutomationProperties.Name="Region Spanien bevorzugen"/>
              <CheckBox Content="AU"   Margin="0,0,12,4" IsChecked="{Binding PreferAU}"   ToolTip="Australien" AutomationProperties.Name="Region Australien bevorzugen"/>
              <CheckBox Content="ASIA" Margin="0,0,12,4" IsChecked="{Binding PreferASIA}" ToolTip="Asien" AutomationProperties.Name="Region Asien bevorzugen"/>
              <CheckBox Content="KR"   Margin="0,0,12,4" IsChecked="{Binding PreferKR}"   ToolTip="Südkorea" AutomationProperties.Name="Region Südkorea bevorzugen"/>
              <CheckBox Content="CN"   Margin="0,0,12,4" IsChecked="{Binding PreferCN}"   ToolTip="China" AutomationProperties.Name="Region China bevorzugen"/>
              <CheckBox Content="BR"   Margin="0,0,12,4" IsChecked="{Binding PreferBR}"   ToolTip="Brasilien" AutomationProperties.Name="Region Brasilien bevorzugen"/>
              <CheckBox Content="NL"   Margin="0,0,12,4" IsChecked="{Binding PreferNL}"   ToolTip="Niederlande" AutomationProperties.Name="Region Niederlande bevorzugen"/>
              <CheckBox Content="SE"   Margin="0,0,12,4" IsChecked="{Binding PreferSE}"   ToolTip="Schweden" AutomationProperties.Name="Region Schweden bevorzugen"/>
              <CheckBox Content="SCAN" Margin="0,0,12,4" IsChecked="{Binding PreferSCAN}" ToolTip="Skandinavien" AutomationProperties.Name="Region Skandinavien bevorzugen"/>
            </WrapPanel>
          </Expander>

          <!-- TASK-117: Region Priority Ranker with Drag & Drop reordering -->
          <TextBlock Text="Prioritätsreihenfolge (Drag &amp; Drop)" Style="{StaticResource CaptionText}"
                     Margin="0,8,0,4" FontWeight="SemiBold"/>
          <ListBox x:Name="regionRankerList" ItemsSource="{Binding RegionPriorities}"
                   AllowDrop="True" MaxHeight="300"
                   HorizontalContentAlignment="Stretch"
                   PreviewMouseLeftButtonDown="OnRegionDragStart"
                   Drop="OnRegionDrop" DragOver="OnRegionDragOver"
                   AutomationProperties.Name="Region Priority Ranker">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                             Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" Cursor="SizeAll"
                             ToolTip="Ziehen zum Umsortieren"/>
                  <TextBlock Grid.Column="1" Text="{Binding Position}" Foreground="{DynamicResource BrushTextMuted}"
                             FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                  <TextBlock Grid.Column="2" VerticalAlignment="Center">
                    <Run Text="{Binding Code, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text=" — "/>
                    <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                  </TextBlock>
                  <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Command="{Binding DataContext.MoveRegionUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}" Content="&#xE70E;" FontFamily="Segoe MDL2 Assets"
                            Width="24" Height="24" Padding="0" FontSize="10" ToolTip="Nach oben"
                            AutomationProperties.Name="Region nach oben"/>
                    <Button Command="{Binding DataContext.MoveRegionDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}" Content="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                            Width="24" Height="24" Padding="0" FontSize="10" ToolTip="Nach unten"
                            AutomationProperties.Name="Region nach unten"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>

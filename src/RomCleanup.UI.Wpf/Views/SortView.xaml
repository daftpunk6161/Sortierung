<UserControl x:Class="RomCleanup.UI.Wpf.Views.SortView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RomCleanup.UI.Wpf.Converters">
  <UserControl.Resources>
    <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    <conv:PipelinePhaseBrushConverter x:Key="PhaseBrush"/>
    <conv:PhaseDetailConverter x:Key="PhaseDetail"/>
    <conv:StringEqualsToBoolConverter x:Key="StrEqualsToBool"/>
    <DataTemplate x:Key="RootItemTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="14"
                   Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsIdle}">
    <StackPanel Margin="20,16">

      <!-- ── Pipeline ── -->
      <TextBlock Text="PIPELINE" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="{DynamicResource SpaceBottomMD}">
        <ItemsControl>
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="13"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=1}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=1}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Preflight" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
          <Border Height="2" VerticalAlignment="Center" Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=2}" Margin="2,0"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=2}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=2}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Scan" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
          <Border Height="2" VerticalAlignment="Center" Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=3}" Margin="2,0"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=3}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=3}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Dedupe" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
          <Border Height="2" VerticalAlignment="Center" Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=4}" Margin="2,0"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=4}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=4}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Sort" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
          <Border Height="2" VerticalAlignment="Center" Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=5}" Margin="2,0"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=5}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=5}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Move" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
          <Border Height="2" VerticalAlignment="Center" Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=6}" Margin="2,0"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=6}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=6}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Convert" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
          <Border Height="2" VerticalAlignment="Center" Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=7}" Margin="2,0"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                      ToolTip="{Binding CurrentRunState, Converter={StaticResource PhaseDetail}, ConverterParameter=7}">
            <Ellipse Width="18" Height="18" Stroke="{DynamicResource BrushBorder}" StrokeThickness="2"
                     Fill="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=7}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="Fertig" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>
        </ItemsControl>
      </Border>

      <!-- ── Quick-Start Presets ── -->
      <TextBlock Text="QUICK-START" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
        <StackPanel>
          <TextBlock Text="Presets" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" Margin="{DynamicResource SpaceBottomXS}"/>
          <Border CornerRadius="6" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                  Background="{DynamicResource BrushSurface}" HorizontalAlignment="Left" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
              <RadioButton GroupName="Preset" Padding="14,10" MinWidth="180" Cursor="Hand"
                           IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=SafeDryRun}"
                           Command="{Binding PresetSafeDryRunCommand}"
                           ToolTip="Sichere Vorschau: Nur prüfen, nichts verschieben"
                           AutomationProperties.Name="Preset: Sichere Vorschau">
                <StackPanel>
                  <TextBlock Text="Sichere Vorschau" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="Nur prüfen, nichts ändern" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <Border Width="1" Background="{DynamicResource BrushBorder}" Margin="0,4"/>
              <RadioButton GroupName="Preset" Padding="14,10" MinWidth="180" Cursor="Hand"
                           IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=FullSort}"
                           Command="{Binding PresetFullSortCommand}"
                           ToolTip="Volle Sortierung: Alle Regionen, Standard-Regeln, Vorschau aktiv"
                           AutomationProperties.Name="Preset: Volle Sortierung">
                <StackPanel>
                  <TextBlock Text="Volle Sortierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="Alle Regionen, Standard-Regeln" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <Border Width="1" Background="{DynamicResource BrushBorder}" Margin="0,4"/>
              <RadioButton GroupName="Preset" Padding="14,10" MinWidth="180" Cursor="Hand"
                           IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Convert}"
                           Command="{Binding PresetConvertCommand}"
                           ToolTip="Konvertierung: Formate nach Move optimieren (CHD/RVZ)"
                           AutomationProperties.Name="Preset: Konvertierung">
                <StackPanel>
                  <TextBlock Text="Konvertierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  <TextBlock Text="Formate optimieren (CHD/RVZ)" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Mode Toggle -->
      <Border CornerRadius="6" BorderBrush="{DynamicResource BrushAccentCyan}"
              BorderThickness="1.5" Margin="{DynamicResource SpaceBottomSM}" HorizontalAlignment="Left"
              Background="{DynamicResource BrushSurface}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <RadioButton Grid.Column="0" GroupName="UiMode"
                       IsChecked="{Binding IsSimpleMode}" Padding="16,8" MinWidth="120" Cursor="Hand"
                       ToolTip="Vereinfachte Ansicht: nur die wichtigsten 4 Optionen (Alt+I)"
                       AutomationProperties.Name="Einfacher Modus" TabIndex="20">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FC;" FontSize="14"
                         VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <AccessText Text="E_infach" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
          </RadioButton>
          <RadioButton Grid.Column="1" GroupName="UiMode"
                       IsChecked="{Binding IsExpertMode, Mode=OneWay}" Padding="16,8" MinWidth="120" Cursor="Hand"
                       ToolTip="Alle Konfigurationsoptionen anzeigen (Regionen, Filter, Konvertierung) (Alt+E)"
                       AutomationProperties.Name="Experten-Modus" TabIndex="21">
            <StackPanel Orientation="Horizontal">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="14"
                         VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <AccessText Text="_Experte" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
          </RadioButton>
        </Grid>
      </Border>

      <!-- Simple Mode Panel -->
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}"
              Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <TextBlock Text="SCHNELLSTART" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
          <StackPanel Margin="{DynamicResource SpaceBottomSM}">
            <TextBlock Text="Region:" Margin="{DynamicResource SpaceBottomXS}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
            <ComboBox Width="220" HorizontalAlignment="Left"
                      SelectedIndex="{Binding SimpleRegionIndex}"
                      ToolTip="Bevorzugte Region: ROMs dieser Region werden bei Duplikaten bevorzugt."
                      AutomationProperties.Name="Bevorzugte Region" TabIndex="30">
              <ComboBoxItem Content="Europa (EU)"/>
              <ComboBoxItem Content="Nordamerika (US)"/>
              <ComboBoxItem Content="Japan (JP)"/>
              <ComboBoxItem Content="Weltweit (Alle)"/>
            </ComboBox>
          </StackPanel>
          <StackPanel Margin="{DynamicResource SpaceBottomSM}">
            <TextBlock Text="Was soll passieren?" Margin="{DynamicResource SpaceBottomXS}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
            <CheckBox Content="Duplikate erkennen und aussortieren" IsChecked="{Binding SimpleDupes}" Margin="0,2"
                      ToolTip="Erkennt ROMs mit gleichem Spielnamen und behält nur die beste Version (Region, Format, Revision)." TabIndex="31"/>
            <CheckBox Content="Junk-Dateien entfernen (Demos, Betas, Hacks)" IsChecked="{Binding SimpleJunk}" Margin="0,2"
                      ToolTip="Verschiebt Demos, Betas, Prototypen, Hacks und Homebrew in den Papierkorb-Ordner." TabIndex="32"/>
            <CheckBox Content="In Konsolen-Ordner sortieren" IsChecked="{Binding SimpleSort}" Margin="0,2"
                      ToolTip="Sortiert ROMs automatisch in Unterordner nach erkannter Konsole (z.B. SNES, PS1, GBA)." TabIndex="33"/>
          </StackPanel>
          <TextBlock Text="Ordner oben hinzufügen, dann unten auf 'Sortierung starten' klicken."
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- ── ROM-Verzeichnisse ── -->
      <TextBlock Text="ROM-VERZEICHNISSE" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
        <Grid Margin="{DynamicResource SpaceBottomXS}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0">
            <ListBox x:Name="listRoots" MinHeight="60" MaxHeight="280" Margin="{DynamicResource SpaceRightSM}"
                     ItemsSource="{Binding Roots}"
                     SelectedItem="{Binding SelectedRoot}"
                     AllowDrop="True"
                     ItemTemplate="{StaticResource RootItemTemplate}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     ToolTip="ROM-Ordner hier hineinziehen (Drag &amp; Drop)"
                     TabIndex="10"
                     AutomationProperties.Name="ROM-Verzeichnisliste">
              <ListBox.InputBindings>
                <KeyBinding Key="Delete" Command="{Binding RemoveRootCommand}"/>
              </ListBox.InputBindings>
            </ListBox>
            <!-- Empty-State Overlay -->
            <Border IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="{DynamicResource SpaceRightSM}">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Roots.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"
                           Margin="{DynamicResource SpaceBottomSM}" Opacity="0.6"/>
                <TextBlock Text="ROM-Ordner hierher ziehen" FontSize="12"
                           Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                <TextBlock Text="oder mit '+' hinzufügen" Style="{StaticResource CaptionText}"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
              </StackPanel>
            </Border>
          </Grid>
          <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="118">
            <Button Command="{Binding AddRootCommand}" Content="＋ Hinzufügen" Margin="{DynamicResource SpaceBottomXS}" HorizontalAlignment="Stretch"
                    ToolTip="Neuen ROM-Ordner zur Liste hinzufügen" AutomationProperties.Name="ROM-Ordner hinzufügen"
                    TabIndex="11"/>
            <Button Command="{Binding RemoveRootCommand}" Content="－ Entfernen" Margin="{DynamicResource SpaceBottomXS}" HorizontalAlignment="Stretch"
                    ToolTip="Ausgewählten ROM-Ordner entfernen (Entf)" AutomationProperties.Name="ROM-Ordner entfernen"
                    TabIndex="12"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── Optionen ── -->
      <TextBlock Text="OPTIONEN" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
        <StackPanel>
          <WrapPanel>
            <CheckBox Content="Nur Vorschau (Dry Run)" Margin="0,4,24,4"
                      IsChecked="{Binding DryRun}" Foreground="{DynamicResource BrushWarning}"
                      ToolTip="Es werden keine Dateien verschoben; nur Analyse + Bericht." TabIndex="40"/>
            <CheckBox Content="Winner nach Move konvertieren (CHD/RVZ/ZIP)" Margin="0,4,24,4"
                      IsChecked="{Binding ConvertEnabled}"
                      ToolTip="Aktiviert Format-Konvertierung im Move-Lauf." TabIndex="41"/>
          </WrapPanel>
          <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
            <TextBlock Text="Namenskollision:" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
            <ComboBox Width="160" SelectedIndex="{Binding ConflictPolicyIndex, Mode=TwoWay}"
                      ToolTip="Wie Dateinamenkollisionen beim Verschieben behandelt werden sollen."
                      AutomationProperties.Name="Namenskollisions-Strategie">
              <ComboBoxItem Content="Umbenennen (_1, _2 …)"/>
              <ComboBoxItem Content="Überspringen"/>
              <ComboBoxItem Content="Überschreiben"/>
            </ComboBox>
          </StackPanel>
          <!-- DryRun Banner -->
          <Border Margin="0,8,0,0" Padding="12,8"
                  Background="{DynamicResource BrushSuccessBg}" BorderBrush="{DynamicResource BrushSuccess}" BorderThickness="1"
                  CornerRadius="6"
                  Visibility="{Binding DryRun, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="DryRun aktiv: Es werden keine Dateien verschoben."
                         Foreground="{DynamicResource BrushSuccess}" FontWeight="SemiBold" TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
              <Button Content="▶ Jetzt als Move ausführen"
                      Command="{Binding StartMoveCommand}"
                      Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                      Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushDanger}" BorderBrush="{DynamicResource BrushDanger}"
                      BorderThickness="1" Cursor="Hand"
                      Visibility="{Binding ShowStartMoveButton, Converter={StaticResource BoolToVis}}"
                      ToolTip="Startet den Lauf erneut im Move-Modus."
                      AutomationProperties.Name="Jetzt als Move ausführen"/>
            </StackPanel>
          </Border>
          <!-- Move Complete Banner -->
          <Border Margin="0,8,0,0" Padding="12,8"
                  Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1"
                  CornerRadius="6"
                  Visibility="{Binding ShowMoveCompleteBanner, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Move abgeschlossen."
                         Foreground="{DynamicResource BrushAccentPurple}" FontWeight="SemiBold" TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
              <Button Command="{Binding RollbackCommand}"
                      Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                      Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushAccentPurple}"
                      BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1" Cursor="Hand"
                      ToolTip="Letzten Move-Lauf rückgängig machen (Ctrl+Z)"
                      AutomationProperties.Name="Letzten Move-Lauf rückgängig machen">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                  <TextBlock Text=" Rückgängig machen" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
          <TextBlock Text="Tipp: Erweiterte Optionen findest du im Tab 'Einstellungen'."
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- ── Regionen ── -->
      <TextBlock Text="REGION-PRIORITÄT" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
        <StackPanel>
          <TextBlock Text="Aktivierte Regionen werden bei Duplikaten bevorzugt behalten."
                     Style="{StaticResource CaptionText}" Margin="{DynamicResource SpaceBottomSM}" TextWrapping="Wrap"/>
          <WrapPanel>
            <CheckBox Content="EU"    Margin="0,0,12,4" IsChecked="{Binding PreferEU}"    ToolTip="Europa (EUR/PAL)" AutomationProperties.Name="Region Europa bevorzugen"/>
            <CheckBox Content="US"    Margin="0,0,12,4" IsChecked="{Binding PreferUS}"    ToolTip="USA (NTSC)" AutomationProperties.Name="Region USA bevorzugen"/>
            <CheckBox Content="WORLD" Margin="0,0,12,4" IsChecked="{Binding PreferWORLD}" ToolTip="World-/Export-Versionen" AutomationProperties.Name="Region World bevorzugen"/>
            <CheckBox Content="JP"    Margin="0,0,12,4" IsChecked="{Binding PreferJP}"    ToolTip="Japan" AutomationProperties.Name="Region Japan bevorzugen"/>
          </WrapPanel>
          <Expander Header="Weitere Regionen" IsExpanded="False" Margin="0,2,0,0">
            <WrapPanel Margin="0,4,0,0">
              <CheckBox Content="DE"   Margin="0,0,12,4" IsChecked="{Binding PreferDE}"   ToolTip="Deutschland" AutomationProperties.Name="Region Deutschland bevorzugen"/>
              <CheckBox Content="FR"   Margin="0,0,12,4" IsChecked="{Binding PreferFR}"   ToolTip="Frankreich" AutomationProperties.Name="Region Frankreich bevorzugen"/>
              <CheckBox Content="IT"   Margin="0,0,12,4" IsChecked="{Binding PreferIT}"   ToolTip="Italien" AutomationProperties.Name="Region Italien bevorzugen"/>
              <CheckBox Content="ES"   Margin="0,0,12,4" IsChecked="{Binding PreferES}"   ToolTip="Spanien" AutomationProperties.Name="Region Spanien bevorzugen"/>
              <CheckBox Content="AU"   Margin="0,0,12,4" IsChecked="{Binding PreferAU}"   ToolTip="Australien" AutomationProperties.Name="Region Australien bevorzugen"/>
              <CheckBox Content="ASIA" Margin="0,0,12,4" IsChecked="{Binding PreferASIA}" ToolTip="Asien" AutomationProperties.Name="Region Asien bevorzugen"/>
              <CheckBox Content="KR"   Margin="0,0,12,4" IsChecked="{Binding PreferKR}"   ToolTip="Südkorea" AutomationProperties.Name="Region Südkorea bevorzugen"/>
              <CheckBox Content="CN"   Margin="0,0,12,4" IsChecked="{Binding PreferCN}"   ToolTip="China" AutomationProperties.Name="Region China bevorzugen"/>
              <CheckBox Content="BR"   Margin="0,0,12,4" IsChecked="{Binding PreferBR}"   ToolTip="Brasilien" AutomationProperties.Name="Region Brasilien bevorzugen"/>
              <CheckBox Content="NL"   Margin="0,0,12,4" IsChecked="{Binding PreferNL}"   ToolTip="Niederlande" AutomationProperties.Name="Region Niederlande bevorzugen"/>
              <CheckBox Content="SE"   Margin="0,0,12,4" IsChecked="{Binding PreferSE}"   ToolTip="Schweden" AutomationProperties.Name="Region Schweden bevorzugen"/>
              <CheckBox Content="SCAN" Margin="0,0,12,4" IsChecked="{Binding PreferSCAN}" ToolTip="Skandinavien" AutomationProperties.Name="Region Skandinavien bevorzugen"/>
            </WrapPanel>
          </Expander>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl x:Class="RomCleanup.UI.Wpf.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:conv="clr-namespace:RomCleanup.UI.Wpf.Converters">
  <UserControl.Resources>
    <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <conv:StringEqualsToVisibilityConverter x:Key="StrEqualsToVis"/>
  </UserControl.Resources>

  <Grid IsEnabled="{Binding IsIdle}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180" MinWidth="140" MaxWidth="240"/>
      <ColumnDefinition Width="1"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══ SIDEBAR NAVIGATION ═══════════════════════════════════════════ -->
    <Border Grid.Column="0" Background="{DynamicResource BrushSurface}" Padding="0,12">
      <ListBox Background="Transparent" BorderThickness="0"
               SelectedValue="{Binding SelectedSettingsSection, Mode=TwoWay}"
               SelectedValuePath="Content"
               ItemContainerStyle="{DynamicResource SidebarNavItem}"
               AutomationProperties.Name="Einstellungskategorien">
        <ListBoxItem Content="Sortieroptionen" AutomationProperties.Name="Navigation: Sortieroptionen"/>
        <ListBoxItem Content="Filter" AutomationProperties.Name="Navigation: Filter"/>
        <ListBoxItem Content="Sicherheit" AutomationProperties.Name="Navigation: Sicherheit"/>
        <ListBoxItem Content="Externe Tools" AutomationProperties.Name="Navigation: Externe Tools"/>
        <ListBoxItem Content="DAT &amp; Hashes" AutomationProperties.Name="Navigation: DAT und Hashes"/>
        <ListBoxItem Content="Profile" AutomationProperties.Name="Navigation: Profile"/>
        <ListBoxItem Content="Allgemein" AutomationProperties.Name="Navigation: Allgemein"/>
        <ListBoxItem Content="System" AutomationProperties.Name="Navigation: System"/>
      </ListBox>
    </Border>

    <!-- Divider -->
    <Border Grid.Column="1" Background="{DynamicResource BrushBorder}"/>

    <!-- ═══ CONTENT AREA ═══════════════════════════════════════════════ -->
    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="20,16">
      <Grid>

        <!-- ── Sortieroptionen ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Sortieroptionen}">
          <TextBlock Text="SORTIEROPTIONEN" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <WrapPanel>
            <CheckBox Content="Ordner nach Konsole strukturieren" Margin="0,4,24,4"
                      IsChecked="{Binding SortConsole}" ToolTip="Erstellt Unterordner pro Konsole"/>
            <CheckBox Content="Offensichtliche Junk-Dateien stärker filtern" Margin="0,4,24,4"
                      IsChecked="{Binding AggressiveJunk}" ToolTip="Entfernt zusätzliche Beta/Proto/Sample-Dateien"/>
            <CheckBox Content="Spielnamen vereinheitlichen" Margin="0,4,24,4"
                      IsChecked="{Binding AliasKeying}" ToolTip="Gleicht bekannte Namensvarianten auf denselben Titel ab"/>
          </WrapPanel>
        </StackPanel>

        <!-- ── Filter ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Filter}">
          <TextBlock Text="DATEITYP- &amp; KONSOLEN-FILTER" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <TextBlock Text="Dateitypen (keine Auswahl = alle Dateitypen scannen):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
          <ItemsControl ItemsSource="{Binding ExtensionFiltersView}" Margin="0,0,0,16">
            <ItemsControl.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
                <GroupStyle.Panel>
                  <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </GroupStyle.Panel>
              </GroupStyle>
            </ItemsControl.GroupStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding Extension}" IsChecked="{Binding IsChecked}"
                          ToolTip="{Binding ToolTip}" Margin="0,0,12,4"
                          AutomationProperties.Name="{Binding Extension, StringFormat='Dateityp {0} filtern'}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="Konsolen (keine Auswahl = alle Konsolen):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
          <ItemsControl ItemsSource="{Binding ConsoleFiltersView}">
            <ItemsControl.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
                <GroupStyle.Panel>
                  <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </GroupStyle.Panel>
              </GroupStyle>
            </ItemsControl.GroupStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding DisplayName}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Margin="0,0,12,4"
                          AutomationProperties.Name="{Binding DisplayName, StringFormat='Konsole {0} filtern'}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- ── Sicherheit ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Sicherheit}">
          <TextBlock Text="SICHERHEITSMODUS" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <CheckBox Content="Sicherheitsmodus aktiv (strikt + Rückfragen)" Margin="0,0,0,12"
                    IsChecked="{Binding SafetyStrict}"
                    ToolTip="Kombiniert strikte Sicherheitsregeln und zusätzliche Move-Bestätigungen."/>
          <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Sicherheitsbereich:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding ProtectedPaths, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Semikolon-getrennte Pfade für geschützte Bereiche"
                     AutomationProperties.Name="Geschützte Pfade"/>
          </Grid>
          <CheckBox Content="JP-Keep nur für ausgewählte Konsolen" Margin="0,4,0,0"
                    IsChecked="{Binding JpOnlySelected}"
                    ToolTip="JP-Versionen nur für die unten definierten Konsolen bevorzugen."/>
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="JP-Keep-Konsolen:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding JpKeepConsoles, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Kommagetrennt: PS1,PS2"
                     AutomationProperties.Name="JP-Keep-Konsolen"/>
          </Grid>
        </StackPanel>

        <!-- ── Externe Tools ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Externe Tools}">
          <TextBlock Text="EXTERNE TOOLS" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
              <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="chdman:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ToolChdman, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="chdman-Pfad"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Chdman"
                    AutomationProperties.Name="chdman durchsuchen"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ChdmanStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="2" Grid.Column="0" Content="dolphintool:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ToolDolphin, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="dolphintool-Pfad"/>
            <Button Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Dolphin"
                    AutomationProperties.Name="dolphintool durchsuchen"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DolphinStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="4" Grid.Column="0" Content="7-Zip (7z):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Tool7z, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="7-Zip-Pfad"/>
            <Button Grid.Row="4" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="7z"
                    AutomationProperties.Name="7-Zip durchsuchen"/>
            <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding SevenZipStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="6" Grid.Column="0" Content="psxtract:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ToolPsxtract, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="psxtract-Pfad"/>
            <Button Grid.Row="6" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Psxtract"
                    AutomationProperties.Name="psxtract durchsuchen"/>
            <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding PsxtractStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="8" Grid.Column="0" Content="ciso:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding ToolCiso, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="ciso-Pfad"/>
            <Button Grid.Row="8" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Ciso"
                    AutomationProperties.Name="ciso durchsuchen"/>
            <TextBlock Grid.Row="8" Grid.Column="3" Text="{Binding CisoStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>
          </Grid>
          <Button Content="Tools auto-entdecken" Command="{Binding FeatureCommands[AutoFindTools]}"
                  ToolTip="Sucht bekannte Konvertierungstools automatisch im System"
                  Width="200" HorizontalAlignment="Left" Margin="0,16,0,0"
                  AutomationProperties.Name="Externe Tools automatisch suchen"/>
        </StackPanel>

        <!-- ── DAT & Hashes ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=DAT &amp; Hashes}">
          <TextBlock Text="DAT &amp; HASHES" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <CheckBox Content="DAT-Verifikation aktivieren" Margin="0,0,0,12"
                    IsChecked="{Binding UseDat}"
                    ToolTip="Vergleicht Dateien mit DAT-Datenbankeinträgen (Hashes)."/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="DAT-Root:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DatRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="DAT-Root-Verzeichnis"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Dat"
                    AutomationProperties.Name="DAT-Verzeichnis durchsuchen"/>
            <Label Grid.Row="2" Grid.Column="0" Content="Hash-Typ:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1"
                      SelectedValue="{Binding DatHashType, Mode=TwoWay}"
                      SelectedValuePath="Content"
                      AutomationProperties.Name="Hash-Typ">
              <ComboBoxItem Content="SHA1"/>
              <ComboBoxItem Content="MD5"/>
              <ComboBoxItem Content="CRC32"/>
            </ComboBox>
          </Grid>
          <WrapPanel Margin="0,12,0,0">
            <CheckBox Content="DAT-Fallback aktivieren" Margin="0,0,24,0"
                      IsChecked="{Binding DatFallback}"
                      ToolTip="Wenn kein exakter Treffer gefunden wird, alternative DAT-Zuordnung versuchen."/>
            <CheckBox Content="Basis-CRC bei Scan/Konvertierung" Margin="0,0,24,0"
                      IsChecked="{Binding CrcVerifyScan}"
                      ToolTip="Basis-CRC-Prüfung auf Datei-Ebene (unabhängig von DAT)."/>
          </WrapPanel>
          <TextBlock Text="ℹ DAT + CRC erhöhen Genauigkeit, können den Lauf aber deutlich verlangsamen."
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>

          <!-- DAT-Mapping (inline, statt eigenem Expander) -->
          <TextBlock Text="DAT-MAPPING" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <TextBlock Text="Ordnet Konsolen manuell ihren DAT-Dateien zu. Ohne Zuordnung wird Auto-Erkennung verwendet."
                     Style="{StaticResource CaptionText}" Margin="0,0,0,8" TextWrapping="Wrap"/>
          <DataGrid MinHeight="200" MaxHeight="400"
                    ItemsSource="{Binding DatMappings}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="True" CanUserDeleteRows="True"
                    SelectionMode="Single"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    ScrollViewer.CanContentScroll="True"
                    AutomationProperties.Name="DAT-Konsolen-Zuordnung">
            <DataGrid.Resources>
              <x:Array x:Key="DatConsoleItems" Type="{x:Type sys:String}">
                <sys:String>PS1</sys:String>
                <sys:String>PS2</sys:String>
                <sys:String>PSP</sys:String>
                <sys:String>DC</sys:String>
                <sys:String>SAT</sys:String>
                <sys:String>GC</sys:String>
                <sys:String>WII</sys:String>
              </x:Array>
            </DataGrid.Resources>
            <DataGrid.Columns>
              <DataGridComboBoxColumn Header="Konsole"
                                      SelectedItemBinding="{Binding Console}"
                                      ItemsSource="{StaticResource DatConsoleItems}"
                                      Width="130"/>
              <DataGridTextColumn Header="DAT-Datei" Binding="{Binding DatFile}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>

        <!-- ── Profile ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Profile}">
          <TextBlock Text="PROFILE" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Profilname:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" IsEditable="True"
                      Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                      AutomationProperties.Name="Profilname"/>
          </Grid>
          <WrapPanel Margin="0,4,0,0">
            <Button Content="Speichern"   MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="Aktuelle Einstellungen speichern"
                    Command="{Binding SaveSettingsCommand}" AutomationProperties.Name="Profil speichern"/>
            <Button Content="Laden"       MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="Gespeichertes Profil laden"
                    Command="{Binding LoadSettingsCommand}" AutomationProperties.Name="Profil laden"/>
            <Button Content="Löschen"     MinWidth="110" Padding="8,2" Style="{StaticResource DangerButton}" Margin="0,0,4,4" ToolTip="Profil löschen"
                    Command="{Binding FeatureCommands[ProfileDelete]}" AutomationProperties.Name="Profil löschen"/>
            <Button Content="Importieren" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="Profil importieren"
                    Command="{Binding FeatureCommands[ProfileImport]}" AutomationProperties.Name="Profil importieren"/>
            <Button Content="Config-Diff" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="Unterschiede anzeigen"
                    Command="{Binding FeatureCommands[ConfigDiff]}" AutomationProperties.Name="Config-Diff anzeigen"/>
          </WrapPanel>
          <TextBlock Text="Profile speichern alle Einstellungen und können zwischen verschiedenen Sammlungen gewechselt werden."
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Allgemein ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Allgemein}">
          <TextBlock Text="ALLGEMEIN" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="Papierkorb:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TrashRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                     ToolTip="Verzeichnis in das Duplikate verschoben werden (_TRASH)"
                     AutomationProperties.Name="Papierkorb-Verzeichnis"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Trash"
                    AutomationProperties.Name="Papierkorb-Ordner durchsuchen"/>
            <Label Grid.Row="2" Grid.Column="0" Content="Log-Level:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                      SelectedValue="{Binding LogLevel, Mode=TwoWay}"
                      SelectedValuePath="Content"
                      AutomationProperties.Name="Log-Level">
              <ComboBoxItem Content="Debug"/>
              <ComboBoxItem Content="Info"/>
              <ComboBoxItem Content="Warning"/>
              <ComboBoxItem Content="Error"/>
            </ComboBox>
          </Grid>
          <WrapPanel Margin="0,12,0,0">
            <Button Command="{Binding ThemeToggleCommand}" Content="{Binding ThemeToggleText}" MinWidth="120" Padding="8,2" Margin="0,0,8,4" AutomationProperties.Name="Theme umschalten"/>
            <ComboBox Width="120" Margin="0,0,8,4"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding Locale, Mode=TwoWay}"
                      AutomationProperties.Name="Sprache"
                      ToolTip="Aktuell nur Deutsch vollständig unterstützt. Weitere Sprachen geplant.">
              <ComboBoxItem Content="de"/>
              <ComboBoxItem Content="en"/>
              <ComboBoxItem Content="fr"/>
            </ComboBox>
            <Button Content="Sprache anwenden" MinWidth="140" Padding="8,2" Margin="0,0,8,4"
                    Command="{Binding FeatureCommands[ApplyLocale]}" AutomationProperties.Name="Sprache anwenden"/>
          </WrapPanel>
        </StackPanel>

        <!-- ── System (Audit, GameKey-Vorschau, Export/Import) ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=System}">
          <TextBlock Text="AUDIT &amp; SYSTEM" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="Audit-Root:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AuditRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                     AutomationProperties.Name="Audit-Root-Verzeichnis"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Audit"
                    AutomationProperties.Name="Audit-Verzeichnis durchsuchen"/>
            <Label Grid.Row="2" Grid.Column="0" Content="PS3 Dupes-Root:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Ps3DupesRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                     AutomationProperties.Name="PS3 Dupes-Verzeichnis"/>
            <Button Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Ps3"
                    AutomationProperties.Name="PS3 Dupes-Verzeichnis durchsuchen"/>
          </Grid>

          <TextBlock Text="GAMEKEY-VORSCHAU" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="Titel:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GameKeyPreviewInput, UpdateSourceTrigger=PropertyChanged}"
                     Margin="{DynamicResource SpaceRightSM}" ToolTip="Beispieltitel für die GameKey-Normalisierung"
                     AutomationProperties.Name="GameKey-Vorschau Titel"/>
            <Button Grid.Row="0" Grid.Column="2" Command="{Binding GameKeyPreviewCommand}" Content="Vorschau" Width="110"
                    AutomationProperties.Name="GameKey-Vorschau berechnen"/>
            <Label Grid.Row="2" Grid.Column="0" Content="GameKey:" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                       Text="{Binding GameKeyPreviewOutput}" Foreground="{DynamicResource BrushAccentCyan}" TextTrimming="CharacterEllipsis"/>
          </Grid>

          <TextBlock Text="KONFIGURATION" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <WrapPanel>
            <Button Content="Exportieren…" MinWidth="160" Padding="8,2" Margin="0,0,8,4" ToolTip="Exportiert Profil oder Gesamtkonfiguration"
                    Command="{Binding FeatureCommands[ExportUnified]}" AutomationProperties.Name="Konfiguration exportieren"/>
            <Button Content="Konfig importieren" MinWidth="160" Padding="8,2" Margin="0,0,8,4"
                    Command="{Binding FeatureCommands[ConfigImport]}" AutomationProperties.Name="Konfiguration importieren"/>
          </WrapPanel>
        </StackPanel>

      </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>

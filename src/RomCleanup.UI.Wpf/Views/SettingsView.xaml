<UserControl x:Class="RomCleanup.UI.Wpf.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
>

  <Grid IsEnabled="{Binding IsIdle}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180" MinWidth="140" MaxWidth="240"/>
      <ColumnDefinition Width="1"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══ SIDEBAR NAVIGATION ═══════════════════════════════════════════ -->
    <Border Grid.Column="0" Background="{DynamicResource BrushSurface}" Padding="0,12">
      <ListBox Background="Transparent" BorderThickness="0"
               SelectedValue="{Binding SelectedSettingsSection, Mode=TwoWay}"
               SelectedValuePath="Tag"
               ItemContainerStyle="{DynamicResource SidebarNavItem}"
               AutomationProperties.Name="{Binding Loc[Settings.NavCategoriesLabel]}">
        <ListBoxItem Tag="Sortieroptionen" Content="{Binding Loc[Settings.NavSorting]}" AutomationProperties.Name="{Binding Loc[Settings.NavSorting]}"/>
        <ListBoxItem Tag="Filter" Content="{Binding Loc[Settings.NavFilters]}" AutomationProperties.Name="{Binding Loc[Settings.NavFilters]}"/>
        <ListBoxItem Tag="Sicherheit" Content="{Binding Loc[Settings.NavSecurity]}" AutomationProperties.Name="{Binding Loc[Settings.NavSecurity]}"/>
        <ListBoxItem Tag="Externe Tools" Content="{Binding Loc[Settings.NavTools]}" AutomationProperties.Name="{Binding Loc[Settings.NavTools]}"/>
        <ListBoxItem Tag="DAT &amp; Hashes" Content="{Binding Loc[Settings.NavDat]}" AutomationProperties.Name="{Binding Loc[Settings.NavDat]}"/>
        <ListBoxItem Tag="Profile" Content="{Binding Loc[Settings.NavProfiles]}" AutomationProperties.Name="{Binding Loc[Settings.NavProfiles]}"/>
        <ListBoxItem Tag="Allgemein" Content="{Binding Loc[Settings.NavGeneral]}" AutomationProperties.Name="{Binding Loc[Settings.NavGeneral]}"/>
        <ListBoxItem Tag="System" Content="{Binding Loc[Settings.NavSystem]}" AutomationProperties.Name="{Binding Loc[Settings.NavSystem]}"/>
      </ListBox>
    </Border>

    <!-- Divider -->
    <Border Grid.Column="1" Background="{DynamicResource BrushBorder}"/>

    <!-- ═══ CONTENT AREA ═══════════════════════════════════════════════ -->
    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="20,16">
      <Grid>

        <!-- ── Sortieroptionen ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Sortieroptionen}">
          <TextBlock Text="{Binding Loc[Settings.SectionSorting]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <WrapPanel>
            <CheckBox Content="{Binding Loc[Settings.SortConsole]}" Margin="0,4,24,4"
                      IsChecked="{Binding SortConsole}" ToolTip="{Binding Loc[Settings.SortConsoleTip]}"/>
            <CheckBox Content="{Binding Loc[Settings.AggressiveJunk]}" Margin="0,4,24,4"
                      IsChecked="{Binding AggressiveJunk}" ToolTip="{Binding Loc[Settings.AggressiveJunkTip]}"/>
            <CheckBox Content="{Binding Loc[Settings.AliasKeying]}" Margin="0,4,24,4"
                      IsChecked="{Binding AliasKeying}" ToolTip="{Binding Loc[Settings.AliasKeyingTip]}"/>
            <CheckBox Content="{Binding Loc[Settings.OnlyGames]}" Margin="0,4,24,4"
                      IsChecked="{Binding OnlyGames}" ToolTip="{Binding Loc[Settings.OnlyGamesTip]}"/>
            <CheckBox Content="{Binding Loc[Settings.KeepUnknownWhenOnlyGames]}" Margin="0,4,24,4"
                      IsChecked="{Binding KeepUnknownWhenOnlyGames}" ToolTip="{Binding Loc[Settings.KeepUnknownWhenOnlyGamesTip]}"/>
          </WrapPanel>
        </StackPanel>

        <!-- ── Filter ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Filter}">
          <TextBlock Text="{Binding Loc[Settings.SectionFilters]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <TextBlock Text="{Binding Loc[Settings.LabelFileTypes]}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
          <ItemsControl ItemsSource="{Binding ExtensionFiltersView}" Margin="0,0,0,16">
            <ItemsControl.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
                <GroupStyle.Panel>
                  <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </GroupStyle.Panel>
              </GroupStyle>
            </ItemsControl.GroupStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding Extension}" IsChecked="{Binding IsChecked}"
                          ToolTip="{Binding ToolTip}" Margin="0,0,12,4"
                          AutomationProperties.Name="{Binding Extension, StringFormat='Dateityp {0} filtern'}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{Binding Loc[Settings.LabelConsoles]}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
          <!-- GUI-087: Search field for console filter -->
          <TextBox Text="{Binding ConsoleFilterText, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,8"
                   Padding="6,4"
                   AutomationProperties.Name="{Binding Loc[Settings.ConsoleSearchLabel]}"
                   ToolTip="{Binding Loc[Settings.ConsoleSearchTip]}"/>
          <ListBox ItemsSource="{Binding ConsoleFiltersView}"
                   MaxHeight="260"
                   VirtualizingPanel.IsVirtualizing="True"
                   VirtualizingPanel.VirtualizationMode="Recycling"
                   ScrollViewer.CanContentScroll="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   BorderThickness="0" Background="Transparent"
                   AutomationProperties.Name="{Binding Loc[Settings.LabelConsoles]}">
            <ListBox.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
              </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding DisplayName}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Margin="0,0,12,4"
                          AutomationProperties.Name="{Binding DisplayName, StringFormat='Konsole {0} filtern'}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>

        <!-- ── Sicherheit ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Sicherheit}">
          <TextBlock Text="{Binding Loc[Settings.SectionSecurity]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <CheckBox Content="{Binding Loc[Settings.SafetyStrict]}" Margin="0,0,0,12"
                    IsChecked="{Binding SafetyStrict}"
                    ToolTip="{Binding Loc[Settings.SafetyStrictTip]}"/>
          <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{Binding Loc[Settings.LabelProtectedPaths]}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding ProtectedPaths, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding Loc[Settings.ProtectedPathsTip]}"
                     AutomationProperties.Name="{Binding Loc[Settings.ProtectedPathsName]}"/>
          </Grid>
          <CheckBox Content="{Binding Loc[Settings.JpKeepSelected]}" Margin="0,4,0,0"
                    IsChecked="{Binding JpOnlySelected}"
                    ToolTip="{Binding Loc[Settings.JpKeepSelectedTip]}"/>
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{Binding Loc[Settings.JpKeepConsolesLabel]}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding JpKeepConsoles, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding Loc[Settings.JpKeepConsolesTip]}"
                     AutomationProperties.Name="{Binding Loc[Settings.JpKeepConsolesLabel]}"/>
          </Grid>
        </StackPanel>

        <!-- ── Externe Tools ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Externe Tools}">
          <TextBlock Text="{Binding Loc[Settings.SectionTools]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
              <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
              <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="chdman:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ToolChdman, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="chdman-Pfad"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Chdman"
                    AutomationProperties.Name="chdman durchsuchen"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ChdmanStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="2" Grid.Column="0" Content="dolphintool:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ToolDolphin, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="dolphintool-Pfad"/>
            <Button Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Dolphin"
                    AutomationProperties.Name="dolphintool durchsuchen"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DolphinStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="4" Grid.Column="0" Content="7-Zip (7z):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Tool7z, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="7-Zip-Pfad"/>
            <Button Grid.Row="4" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="7z"
                    AutomationProperties.Name="7-Zip durchsuchen"/>
            <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding SevenZipStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="6" Grid.Column="0" Content="psxtract:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ToolPsxtract, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="psxtract-Pfad"/>
            <Button Grid.Row="6" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Psxtract"
                    AutomationProperties.Name="psxtract durchsuchen"/>
            <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding PsxtractStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

            <Label Grid.Row="8" Grid.Column="0" Content="ciso:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding ToolCiso, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="ciso-Pfad"/>
            <Button Grid.Row="8" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseToolPathCommand}" CommandParameter="Ciso"
                    AutomationProperties.Name="ciso durchsuchen"/>
            <TextBlock Grid.Row="8" Grid.Column="3" Text="{Binding CisoStatusText}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>
          </Grid>
          <Button Content="{Binding Loc[Settings.BtnAutoDetect]}" Command="{Binding FeatureCommands[AutoFindTools]}"
                  ToolTip="{Binding Loc[Settings.AutoDetectTip]}"
                  Width="200" HorizontalAlignment="Left" Margin="0,16,0,0"
                  AutomationProperties.Name="{Binding Loc[Settings.AutoDetectTip]}"/>
        </StackPanel>

        <!-- ── DAT & Hashes ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=DAT &amp; Hashes}">
          <TextBlock Text="{Binding Loc[Settings.SectionDat]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <CheckBox Content="{Binding Loc[Settings.UseDat]}" Margin="0,0,0,12"
                    IsChecked="{Binding UseDat}"
                    ToolTip="{Binding Loc[Settings.UseDatTip]}"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="{Binding Loc[Settings.DatRootLabel]}" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DatRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                    AutomationProperties.Name="{Binding Loc[Settings.DatRootName]}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Dat"
                    AutomationProperties.Name="{Binding Loc[Settings.DatRootBrowse]}"/>
            <Label Grid.Row="2" Grid.Column="0" Content="{Binding Loc[Settings.HashTypeLabel]}" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1"
                      SelectedValue="{Binding DatHashType, Mode=TwoWay}"
                      SelectedValuePath="Content"
                      AutomationProperties.Name="{Binding Loc[Settings.HashTypeLabel]}">
              <ComboBoxItem Content="SHA1"/>
              <ComboBoxItem Content="MD5"/>
              <ComboBoxItem Content="CRC32"/>
            </ComboBox>
          </Grid>
          <WrapPanel Margin="0,12,0,0">
            <CheckBox Content="{Binding Loc[Settings.DatFallback]}" Margin="0,0,24,0"
                      IsChecked="{Binding DatFallback}"
                      ToolTip="{Binding Loc[Settings.DatFallbackTip]}"/>
            <CheckBox Content="{Binding Loc[Settings.CrcVerify]}" Margin="0,0,24,0"
                      IsChecked="{Binding CrcVerifyScan}"
                      ToolTip="{Binding Loc[Settings.CrcVerifyTip]}"/>
          </WrapPanel>
          <TextBlock Text="{Binding Loc[Settings.DatPerfNote]}"
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>

          <!-- DAT-Mapping (inline, statt eigenem Expander) -->
          <TextBlock Text="{Binding Loc[Settings.SectionDatMapping]}" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <TextBlock Text="{Binding Loc[Settings.DatMappingDesc]}"
                     Style="{StaticResource CaptionText}" Margin="0,0,0,8" TextWrapping="Wrap"/>
          <DataGrid MinHeight="200" MaxHeight="400"
                    ItemsSource="{Binding DatMappings}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="True" CanUserDeleteRows="True"
                    SelectionMode="Single"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    ScrollViewer.CanContentScroll="True"
                    AutomationProperties.Name="{Binding Loc[Settings.DatMappingName]}">
            <DataGrid.Resources>
              <x:Array x:Key="DatConsoleItems" Type="{x:Type sys:String}">
                <sys:String>PS1</sys:String>
                <sys:String>PS2</sys:String>
                <sys:String>PSP</sys:String>
                <sys:String>DC</sys:String>
                <sys:String>SAT</sys:String>
                <sys:String>GC</sys:String>
                <sys:String>WII</sys:String>
              </x:Array>
            </DataGrid.Resources>
            <DataGrid.Columns>
              <DataGridComboBoxColumn Header="Console"
                                      SelectedItemBinding="{Binding Console}"
                                      ItemsSource="{StaticResource DatConsoleItems}"
                                      Width="130"/>
              <DataGridTextColumn Header="DAT File" Binding="{Binding DatFile}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>

        <!-- ── Profile ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Profile}">
          <TextBlock Text="{Binding Loc[Settings.SectionProfiles]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{Binding Loc[Settings.ProfileNameLabel]}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" IsEditable="True"
                      Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                      AutomationProperties.Name="{Binding Loc[Settings.ProfileNameLabel]}"/>
          </Grid>
          <WrapPanel Margin="0,4,0,0">
            <Button Content="{Binding Loc[Settings.ProfileSave]}"   MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.ProfileSaveTip]}"
                    Command="{Binding SaveSettingsCommand}" AutomationProperties.Name="{Binding Loc[Settings.ProfileSaveTip]}"/>
            <Button Content="{Binding Loc[Settings.ProfileLoad]}"       MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.ProfileLoadTip]}"
                    Command="{Binding LoadSettingsCommand}" AutomationProperties.Name="{Binding Loc[Settings.ProfileLoadTip]}"/>
            <Button Content="{Binding Loc[Settings.ProfileDelete]}"     MinWidth="110" Padding="8,2" Style="{StaticResource DangerButton}" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.ProfileDeleteTip]}"
                    Command="{Binding FeatureCommands[ProfileDelete]}" AutomationProperties.Name="{Binding Loc[Settings.ProfileDeleteTip]}"/>
            <Button Content="{Binding Loc[Settings.ProfileImport]}" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.ProfileImportTip]}"
                    Command="{Binding FeatureCommands[ProfileImport]}" AutomationProperties.Name="{Binding Loc[Settings.ProfileImportTip]}"/>
            <Button Content="{Binding Loc[Settings.ProfileShare]}" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.ProfileShareTip]}"
                    Command="{Binding FeatureCommands[ProfileShare]}" AutomationProperties.Name="{Binding Loc[Settings.ProfileShareTip]}"/>
            <Button Content="{Binding Loc[Settings.ProfileDiff]}" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.ProfileDiffTip]}"
                    Command="{Binding FeatureCommands[ConfigDiff]}" AutomationProperties.Name="{Binding Loc[Settings.ProfileDiffTip]}"/>
            <Button Content="{Binding Loc[Settings.CliCommandCopy]}" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="{Binding Loc[Settings.CliCommandCopyTip]}"
                    Command="{Binding FeatureCommands[CliCommandCopy]}" AutomationProperties.Name="{Binding Loc[Settings.CliCommandCopyTip]}"/>
          </WrapPanel>
          <TextBlock Text="{Binding Loc[Settings.ProfilesInfo]}"
                     Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Allgemein ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Allgemein}">
          <TextBlock Text="{Binding Loc[Settings.SectionGeneral]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="{Binding Loc[Settings.TrashLabel]}" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TrashRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                     ToolTip="{Binding Loc[Settings.TrashTip]}"
                     AutomationProperties.Name="{Binding Loc[Settings.TrashName]}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Trash"
                    AutomationProperties.Name="{Binding Loc[Settings.TrashBrowse]}"/>
            <Label Grid.Row="2" Grid.Column="0" Content="{Binding Loc[Settings.LogLevelLabel]}" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                      SelectedValue="{Binding LogLevel, Mode=TwoWay}"
                      SelectedValuePath="Content"
                      AutomationProperties.Name="{Binding Loc[Settings.LogLevelLabel]}">
              <ComboBoxItem Content="Debug"/>
              <ComboBoxItem Content="Info"/>
              <ComboBoxItem Content="Warning"/>
              <ComboBoxItem Content="Error"/>
            </ComboBox>
          </Grid>
          <WrapPanel Margin="0,12,0,0">
            <Button Command="{Binding ThemeToggleCommand}" Content="{Binding ThemeToggleText}" MinWidth="120" Padding="8,2" Margin="0,0,8,4" AutomationProperties.Name="{Binding Loc[Settings.ThemeName]}"/>
            <ComboBox Width="120" Margin="0,0,8,4"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding Locale, Mode=TwoWay}"
                      AutomationProperties.Name="{Binding Loc[Settings.LocaleName]}"
                      ToolTip="{Binding Loc[Settings.LocaleTip]}">
              <ComboBoxItem Content="de"/>
              <ComboBoxItem Content="en"/>
              <ComboBoxItem Content="fr"/>
            </ComboBox>
            <Button Content="{Binding Loc[Settings.BtnApplyLocale]}" MinWidth="140" Padding="8,2" Margin="0,0,8,4"
                    Command="{Binding FeatureCommands[ApplyLocale]}" AutomationProperties.Name="{Binding Loc[Settings.BtnApplyLocale]}"/>
          </WrapPanel>
        </StackPanel>

        <!-- ── System (Audit, GameKey-Vorschau, Export/Import) ── -->
        <StackPanel Visibility="{Binding SelectedSettingsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=System}">
          <TextBlock Text="{Binding Loc[Settings.SectionAudit]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="{Binding Loc[Settings.AuditRootLabel]}" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AuditRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                     AutomationProperties.Name="{Binding Loc[Settings.AuditRootName]}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Audit"
                    AutomationProperties.Name="{Binding Loc[Settings.AuditRootBrowse]}"/>
            <Label Grid.Row="2" Grid.Column="0" Content="{Binding Loc[Settings.Ps3DupesLabel]}" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Ps3DupesRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                     AutomationProperties.Name="{Binding Loc[Settings.Ps3DupesName]}"/>
            <Button Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                    Command="{Binding BrowseFolderPathCommand}" CommandParameter="Ps3"
                    AutomationProperties.Name="{Binding Loc[Settings.Ps3DupesBrowse]}"/>
          </Grid>

          <TextBlock Text="{Binding Loc[Settings.SectionGameKey]}" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="6"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="{Binding Loc[Settings.GameKeyTitleLabel]}" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GameKeyPreviewInput, UpdateSourceTrigger=PropertyChanged}"
                     Margin="{DynamicResource SpaceRightSM}" ToolTip="{Binding Loc[Settings.GameKeyTitleTip]}"
                     AutomationProperties.Name="{Binding Loc[Settings.GameKeyTitleName]}"/>
            <Button Grid.Row="0" Grid.Column="2" Command="{Binding GameKeyPreviewCommand}" Content="{Binding Loc[Settings.GameKeyPreview]}" Width="110"
                    AutomationProperties.Name="{Binding Loc[Settings.GameKeyPreviewName]}"/>
            <Label Grid.Row="2" Grid.Column="0" Content="{Binding Loc[Settings.GameKeyLabel]}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                       Text="{Binding GameKeyPreviewOutput}" Foreground="{DynamicResource BrushAccentCyan}" TextTrimming="CharacterEllipsis"/>
          </Grid>

          <!-- GUI-109: Scheduler -->
          <TextBlock Text="{Binding Loc[Settings.SectionScheduler]}" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{Binding Loc[Settings.SchedulerLabel]}"/>
            <ComboBox Grid.Column="1" SelectedValue="{Binding SchedulerIntervalMinutes}" SelectedValuePath="Tag" MinWidth="120"
                      AutomationProperties.Name="{Binding Loc[Settings.SchedulerLabel]}">
              <ComboBoxItem Tag="0" Content="{Binding Loc[Settings.SchedulerOff]}"/>
              <ComboBoxItem Tag="30" Content="30 min"/>
              <ComboBoxItem Tag="60" Content="1 h"/>
              <ComboBoxItem Tag="240" Content="4 h"/>
              <ComboBoxItem Tag="720" Content="12 h"/>
              <ComboBoxItem Tag="1440" Content="24 h"/>
            </ComboBox>
            <Button Grid.Column="2" Content="{Binding Loc[Settings.SchedulerApply]}" Margin="8,0,0,0" MinHeight="30"
                    Command="{Binding FeatureCommands[SchedulerApply]}"
                    AutomationProperties.Name="{Binding Loc[Settings.SchedulerApply]}"/>
          </Grid>

          <!-- GUI-110: MinimizeToTray -->
          <CheckBox Content="{Binding Loc[Settings.MinimizeToTray]}" IsChecked="{Binding MinimizeToTray}" Margin="0,12,0,0"
                    ToolTip="{Binding Loc[Settings.MinimizeToTrayTip]}"
                    AutomationProperties.Name="{Binding Loc[Settings.MinimizeToTray]}"/>

          <TextBlock Text="{Binding Loc[Settings.SectionConfig]}" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
          <WrapPanel>
            <Button Content="{Binding Loc[Settings.BtnExportConfig]}" MinWidth="160" Padding="8,2" Margin="0,0,8,4" ToolTip="{Binding Loc[Settings.ExportConfigTip]}"
                    Command="{Binding FeatureCommands[ExportUnified]}" AutomationProperties.Name="{Binding Loc[Settings.ExportConfigTip]}"/>
            <Button Content="{Binding Loc[Settings.BtnImportConfig]}" MinWidth="160" Padding="8,2" Margin="0,0,8,4"
                    Command="{Binding FeatureCommands[ConfigImport]}" AutomationProperties.Name="{Binding Loc[Settings.ImportConfigTip]}"/>
          </WrapPanel>
        </StackPanel>

      </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>

<UserControl x:Class="RomCleanup.UI.Wpf.Views.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="clr-namespace:RomCleanup.UI.Wpf.Views"
>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20">

      <!-- GUI-093: Screen-reader live announcement for drop actions -->
      <TextBlock x:Name="dropAnnouncement" Visibility="Collapsed"
                 AutomationProperties.LiveSetting="Assertive"/>

      <!-- ── GUI-065: Hero Drop-Zone ── -->
      <Border x:Name="heroDropZone" AllowDrop="True"
              MinHeight="160" CornerRadius="{DynamicResource RadiusXL}" Margin="{DynamicResource SpaceBottomLG}"
              Background="{DynamicResource BrushSurface}"
              BorderBrush="{DynamicResource BrushBorder}" BorderThickness="2"
              Cursor="Hand"
              Drop="OnHeroDrop" DragEnter="OnHeroDragEnter" DragLeave="OnHeroDragLeave"
              AutomationProperties.Name="{Binding Loc[Start.DropZoneLabel]}">
        <Grid>
          <!-- Empty state -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{Binding HasNoRoots, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
              <Border Width="34" Height="34" CornerRadius="8" BorderBrush="{DynamicResource BrushAccentCyan}" BorderThickness="1.5" Background="#0B2230" Margin="0,0,8,0">
                <views:RomulusLogoMark Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="{Binding Loc[App.Title]}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"
                       Margin="{DynamicResource SpaceBottomSM}" Opacity="0.7"/>
            <TextBlock Text="{Binding Loc[Start.DropHero]}" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                       Margin="{DynamicResource SpaceBottomXS}"/>
            <TextBlock Text="{Binding Loc[Start.DropHeroSub]}" Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center"/>
            <Button Command="{Binding AddRootCommand}" Content="{Binding Loc[Start.BrowseButton]}"
                    Margin="0,12,0,0" Padding="20,8" HorizontalAlignment="Center"
                    AutomationProperties.Name="{Binding Loc[Start.BrowseButton]}"/>
          </StackPanel>
          <!-- Has roots -->
          <StackPanel Visibility="{Binding HasNoRoots, Converter={StaticResource InverseBoolToVis}}"
                      Margin="20,16">
            <DockPanel Margin="{DynamicResource SpaceBottomSM}">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Command="{Binding AddRootCommand}" Content="{Binding Loc[Sort.AddRoot]}"
                        Margin="{DynamicResource SpaceRightXS}" Padding="12,6"
                        AutomationProperties.Name="{Binding Loc[Sort.AddRootTip]}"/>
                <Button Command="{Binding RemoveRootCommand}" Content="{Binding Loc[Sort.RemoveRoot]}"
                        Padding="12,6" AutomationProperties.Name="{Binding Loc[Sort.RemoveRootTip]}"/>
              </StackPanel>
              <TextBlock Text="{Binding Loc[Start.RootsConfigured]}" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
            </DockPanel>
            <ListBox ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedRoot}"
                     MaxHeight="140" AllowDrop="True"
                     Drop="OnHeroDrop" DragEnter="OnHeroDragEnter" DragLeave="OnHeroDragLeave"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                     AutomationProperties.Name="{Binding Loc[Sort.RootsListName]}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                    <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
              <ListBox.InputBindings>
                <KeyBinding Key="Delete" Command="{Binding RemoveRootCommand}"/>
              </ListBox.InputBindings>
            </ListBox>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── GUI-066: Intent Cards ── -->
      <TextBlock Text="{Binding Loc[Start.WhatToDo]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
      <UniformGrid Columns="3" Margin="{DynamicResource SpaceBottomLG}">
        <!-- Aufräumen -->
        <RadioButton GroupName="Intent" Margin="{DynamicResource SpaceRightSM}" Cursor="Hand"
                     IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=SafeDryRun}"
                     Command="{Binding PresetSafeDryRunCommand}"
                     Style="{StaticResource {x:Type RadioButton}}"
                     AutomationProperties.Name="{Binding Loc[Start.IntentClean]}">
          <Border Background="{DynamicResource BrushSurface}" CornerRadius="{DynamicResource RadiusLG}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="16,20" MinHeight="120">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                         Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center"
                         Margin="{DynamicResource SpaceBottomSM}"/>
              <TextBlock Text="{Binding Loc[Start.IntentClean]}" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                         Margin="{DynamicResource SpaceBottomXS}"/>
              <TextBlock Text="{Binding Loc[Start.IntentCleanDesc]}" Style="{StaticResource CaptionText}"
                         HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
          </Border>
        </RadioButton>
        <!-- Sortieren -->
        <RadioButton GroupName="Intent" Margin="{DynamicResource SpaceRightSM}" Cursor="Hand"
                     IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=FullSort}"
                     Command="{Binding PresetFullSortCommand}"
                     Style="{StaticResource {x:Type RadioButton}}"
                     AutomationProperties.Name="{Binding Loc[Start.IntentSort]}">
          <Border Background="{DynamicResource BrushSurface}" CornerRadius="{DynamicResource RadiusLG}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="16,20" MinHeight="120">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                         Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"
                         Margin="{DynamicResource SpaceBottomSM}"/>
              <TextBlock Text="{Binding Loc[Start.IntentSort]}" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                         Margin="{DynamicResource SpaceBottomXS}"/>
              <TextBlock Text="{Binding Loc[Start.IntentSortDesc]}" Style="{StaticResource CaptionText}"
                         HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
          </Border>
        </RadioButton>
        <!-- Konvertieren -->
        <RadioButton GroupName="Intent" Cursor="Hand"
                     IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Convert}"
                     Command="{Binding PresetConvertCommand}"
                     Style="{StaticResource {x:Type RadioButton}}"
                     AutomationProperties.Name="{Binding Loc[Start.IntentConvert]}">
          <Border Background="{DynamicResource BrushSurface}" CornerRadius="{DynamicResource RadiusLG}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="16,20" MinHeight="120">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                         Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center"
                         Margin="{DynamicResource SpaceBottomSM}"/>
              <TextBlock Text="{Binding Loc[Start.IntentConvert]}" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                         Margin="{DynamicResource SpaceBottomXS}"/>
              <TextBlock Text="{Binding Loc[Start.IntentConvertDesc]}" Style="{StaticResource CaptionText}"
                         HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
          </Border>
        </RadioButton>
      </UniformGrid>

      <!-- ── GUI-067: CTA Button ── -->
      <Button Command="{Binding RunCommand}" Style="{StaticResource PrimaryButton}"
              Height="56" HorizontalAlignment="Stretch" Margin="{DynamicResource SpaceBottomMD}"
              AutomationProperties.Name="{Binding Loc[Start.CtaPreview]}"
              AutomationProperties.AcceleratorKey="F5">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="22" VerticalAlignment="Center"
                     Margin="{DynamicResource SpaceRightSM}"/>
          <TextBlock Text="{Binding Loc[Start.CtaPreview]}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Guided workflow redesigned: compact stepper cards -->
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
        <StackPanel>
          <TextBlock Text="{Binding Loc[Start.FlowTitle]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
          <TextBlock Text="{Binding Loc[Start.FlowDesc]}" Style="{StaticResource CaptionText}" Margin="0,0,0,10" TextWrapping="Wrap"/>

          <UniformGrid Columns="2" Margin="0,4,0,0">
            <Border Style="{StaticResource SectionCard}" Margin="0,0,6,6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top">
                  <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Loc[Start.FlowStep1]}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Loc[Start.StepRootsHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Roots.Count, StringFormat='{}{0}'}" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="6,0,0,6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top">
                  <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Loc[Start.FlowStep2]}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Loc[Start.StepSetupHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding GoToSetupCommand}" Content="{Binding Loc[Start.FlowOpenSetup]}" Padding="10,4" VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="0,6,6,6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top">
                  <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Loc[Start.FlowStep3]}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Loc[Start.StepPreviewHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding QuickPreviewCommand}" Content="{Binding Loc[Start.FlowRunPreview]}" Padding="10,4" VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="6,6,0,6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top">
                  <TextBlock Text="4" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Loc[Start.FlowStep4]}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding MoveApplyGateText}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="0,6,6,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top">
                  <TextBlock Text="5" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Loc[Start.FlowStep5]}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding MoveApplyGateText}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="6,6,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top">
                  <TextBlock Text="6" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Loc[Start.FlowStep6]}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Loc[Start.StepReportHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding GoToAnalyseCommand}" Content="{Binding Loc[Start.FlowOpenAnalyse]}" Padding="10,4" VerticalAlignment="Center"/>
              </Grid>
            </Border>
          </UniformGrid>
        </StackPanel>
      </Border>

      <!-- GUI-103: Watch-Mode Toggle Button (visible alternative to Ctrl+W) -->
      <ToggleButton IsChecked="{Binding IsWatchModeActive, Mode=OneWay}"
                    Command="{Binding WatchApplyCommand}"
                    HorizontalAlignment="Right" Padding="12,6" Margin="0,0,0,8"
                    MinHeight="44"
                    AutomationProperties.Name="{Binding Loc[Start.WatchToggle]}"
                    ToolTip="{Binding Loc[Start.WatchToggleTip]}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                     VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBlock Text="{Binding Loc[Start.WatchToggle]}" VerticalAlignment="Center"/>
        </StackPanel>
      </ToggleButton>

      <!-- ── GUI-068: Last Run Info ── -->
      <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}"
              Visibility="{Binding HasRunResult, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <TextBlock Text="{Binding Loc[Start.LastRun]}" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="{DynamicResource SpaceBottomSM}"/>
          <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource SpaceRightMD}">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center">
                <Run Text="{Binding DashWinners, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Loc[Start.Winners], Mode=OneWay}"/>
              </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource SpaceRightMD}">
              <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center">
                <Run Text="{Binding DashDupes, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Loc[Start.Dupes], Mode=OneWay}"/>
              </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource SpaceRightMD}">
              <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center">
                <Run Text="{Binding DashJunk, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Loc[Report.Junk], Mode=OneWay}"/>
              </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Text="{Binding DashDuration}" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
            </StackPanel>
          </WrapPanel>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button Command="{Binding OpenReportCommand}" Padding="12,4" Margin="{DynamicResource SpaceRightSM}"
                    AutomationProperties.Name="{Binding Loc[Start.OpenReport]}">
              <TextBlock Text="{Binding Loc[Start.OpenReport]}"/>
            </Button>
            <Button Command="{Binding RollbackCommand}" Padding="12,4"
                    Foreground="{DynamicResource BrushAccentPurple}" BorderBrush="{DynamicResource BrushAccentPurple}"
                    AutomationProperties.Name="{Binding Loc[Start.Undo]}">
              <TextBlock Text="{Binding Loc[Start.Undo]}"/>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>

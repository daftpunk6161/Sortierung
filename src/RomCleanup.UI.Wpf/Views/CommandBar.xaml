<UserControl x:Class="RomCleanup.UI.Wpf.Views.CommandBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:RomCleanup.UI.Wpf.Views"
>
  <!-- ═══ COMMAND BAR (48px Header) ═══════════════════════════════════════
       Logo + Status-Orbs + Phase-Indicator + Profile Selector + Theme Picker
       Layout: DockPanel  Left→Logo+Status  Right→Profile+Report+Theme  ═══ -->
  <Border Background="{DynamicResource BrushSurfaceAlt}"
          BorderBrush="{DynamicResource BrushBorder}"
          BorderThickness="0,0,0,1" Height="48">
    <DockPanel Margin="12,0">

      <!-- ── RIGHT WING ──────────────────────────────────────────────── -->
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

        <!-- Theme Picker Button -->
        <Button Command="{Binding ThemeToggleCommand}" Padding="8,4" Margin="4,0,0,0"
                ToolTip="{Binding ThemeToggleText}"
                AutomationProperties.Name="Theme wechseln"
                AutomationProperties.AcceleratorKey="Ctrl+T" TabIndex="4"
                Background="Transparent" BorderThickness="0" Cursor="Hand">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE790;" FontSize="14"
                       Foreground="{DynamicResource BrushAccentPurple}" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding CurrentThemeLabel}" FontSize="11"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Height="20" Fill="{DynamicResource BrushBorder}"
                   VerticalAlignment="Center" Margin="8,0"/>

        <!-- Report Button -->
        <Button Command="{Binding OpenReportCommand}" Padding="8,4"
                ToolTip="{Binding Loc[Report.OpenReportTip]}"
                AutomationProperties.Name="{Binding Loc[Report.OpenReport]}"
                AutomationProperties.AcceleratorKey="Ctrl+R" TabIndex="3"
                Background="Transparent" BorderThickness="0" Cursor="Hand">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="14"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding Loc[Report.OpenReportLog]}" FontSize="11"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
        </Button>

        <Rectangle Width="1" Height="20" Fill="{DynamicResource BrushBorder}"
                   VerticalAlignment="Center" Margin="8,0"/>

        <!-- Quick Profile Selector -->
        <ComboBox Width="150" Margin="0,0,4,0"
                  ToolTip="{Binding Loc[Profile.QuickSwitch]}" IsEditable="False"
                  SelectedIndex="{Binding QuickProfileIndex, Mode=TwoWay}"
                  AutomationProperties.Name="{Binding Loc[Profile.QuickSwitch]}" TabIndex="2">
          <ComboBoxItem Content="Standard" IsSelected="True"/>
          <ComboBoxItem Content="Disc (CHD)"/>
          <ComboBoxItem Content="Cartridge (ZIP)"/>
          <ComboBoxItem Content="Gemischt"/>
        </ComboBox>
      </StackPanel>

      <!-- ── LEFT WING ──────────────────────────────────────────────── -->
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">

        <!-- Logo + Title -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
          <Border Width="28" Height="28" CornerRadius="7"
                  BorderBrush="{DynamicResource BrushAccentCyan}" BorderThickness="1.5"
                  Background="#0B2230" Margin="0,0,8,0">
            <views:RomulusLogoMark Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="{Binding Loc[App.Title]}" Style="{StaticResource TitleText}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <Rectangle Width="1" Height="20" Fill="{DynamicResource BrushBorder}"
                   VerticalAlignment="Center" Margin="0,0,10,0"/>

        <!-- Status Orbs: Roots / Tools / DAT / Ready -->
        <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"
                 Fill="{Binding RootsStatusLevel, Converter={StaticResource StatusToBrush}}"
                 ToolTip="{Binding Loc[Status.RootsTip]}"/>
        <TextBlock Text="{Binding StatusRoots}" Foreground="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>

        <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"
                 Fill="{Binding ToolsStatusLevel, Converter={StaticResource StatusToBrush}}"
                 ToolTip="{Binding Loc[Status.ToolsTip]}"/>
        <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>

        <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"
                 Fill="{Binding DatStatusLevel, Converter={StaticResource StatusToBrush}}"
                 ToolTip="{Binding Loc[Status.DatTip]}"/>
        <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>

        <Rectangle Width="1" Height="20" Fill="{DynamicResource BrushBorder}"
                   VerticalAlignment="Center" Margin="0,0,10,0"/>

        <!-- Ready indicator (larger) -->
        <Ellipse Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0"
                 Fill="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"
                 ToolTip="{Binding Loc[Status.ReadyTip]}"/>
        <TextBlock Text="{Binding StatusReady}" Foreground="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" FontSize="11"
                   AutomationProperties.Name="{Binding Loc[Status.ReadyLabel]}"
                   AutomationProperties.LiveSetting="Polite"/>

        <Rectangle Width="1" Height="20" Fill="{DynamicResource BrushBorder}"
                   VerticalAlignment="Center" Margin="10,0"/>

        <!-- Runtime -->
        <TextBlock Text="{Binding StatusRuntime}" Foreground="{DynamicResource BrushTextMuted}"
                   VerticalAlignment="Center" FontSize="11"/>

        <Rectangle Width="1" Height="20" Fill="{DynamicResource BrushBorder}"
                   VerticalAlignment="Center" Margin="10,0"/>

        <!-- Phase Indicator (5-step pipeline dots with labels) -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Phase:" Foreground="{DynamicResource BrushTextMuted}"
                     FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <StackPanel Margin="0,0,6,0">
            <Ellipse Width="8" Height="8" HorizontalAlignment="Center"
                     Fill="{Binding PipelinePhase, Converter={StaticResource PhaseBrush}, ConverterParameter=0}"
                     ToolTip="Configure"/>
            <TextBlock Text="Config" FontSize="7" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
          <StackPanel Margin="0,0,6,0">
            <Ellipse Width="8" Height="8" HorizontalAlignment="Center"
                     Fill="{Binding PipelinePhase, Converter={StaticResource PhaseBrush}, ConverterParameter=1}"
                     ToolTip="Preview"/>
            <TextBlock Text="Preview" FontSize="7" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
          <StackPanel Margin="0,0,6,0">
            <Ellipse Width="8" Height="8" HorizontalAlignment="Center"
                     Fill="{Binding PipelinePhase, Converter={StaticResource PhaseBrush}, ConverterParameter=2}"
                     ToolTip="Review"/>
            <TextBlock Text="Review" FontSize="7" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
          <StackPanel Margin="0,0,6,0">
            <Ellipse Width="8" Height="8" HorizontalAlignment="Center"
                     Fill="{Binding PipelinePhase, Converter={StaticResource PhaseBrush}, ConverterParameter=3}"
                     ToolTip="Execute"/>
            <TextBlock Text="Execute" FontSize="7" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
          <StackPanel>
            <Ellipse Width="8" Height="8" HorizontalAlignment="Center"
                     Fill="{Binding PipelinePhase, Converter={StaticResource PhaseBrush}, ConverterParameter=4}"
                     ToolTip="Report"/>
            <TextBlock Text="Report" FontSize="7" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </DockPanel>
  </Border>
</UserControl>

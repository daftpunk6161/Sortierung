<UserControl x:Class="RomCleanup.UI.Wpf.Views.ToolsDatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- Extracted from SettingsView "DAT &amp; Hashes" section -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
    <StackPanel>
      <TextBlock Text="{Binding Loc[Settings.SectionDat]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <CheckBox Content="{Binding Loc[Settings.UseDat]}" Margin="0,0,0,12"
                IsChecked="{Binding UseDat}"
                ToolTip="{Binding Loc[Settings.UseDatTip]}"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="38"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="6"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Content="{Binding Loc[Settings.DatRootLabel]}" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DatRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                AutomationProperties.Name="{Binding Loc[Settings.DatRootName]}"/>
        <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                Command="{Binding BrowseFolderPathCommand}" CommandParameter="Dat"
                AutomationProperties.Name="{Binding Loc[Settings.DatRootBrowse]}"/>
        <Label Grid.Row="2" Grid.Column="0" Content="{Binding Loc[Settings.HashTypeLabel]}" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  SelectedValue="{Binding DatHashType, Mode=TwoWay}"
                  SelectedValuePath="Content"
                  AutomationProperties.Name="{Binding Loc[Settings.HashTypeLabel]}">
          <ComboBoxItem Content="SHA1"/>
          <ComboBoxItem Content="MD5"/>
          <ComboBoxItem Content="CRC32"/>
        </ComboBox>
      </Grid>
      <WrapPanel Margin="0,12,0,0">
        <CheckBox Content="{Binding Loc[Settings.DatFallback]}" Margin="0,0,24,0"
                  IsChecked="{Binding DatFallback}"
                  ToolTip="{Binding Loc[Settings.DatFallbackTip]}"/>
        <CheckBox Content="{Binding Loc[Settings.CrcVerify]}" Margin="0,0,24,0"
                  IsChecked="{Binding CrcVerifyScan}"
                  ToolTip="{Binding Loc[Settings.CrcVerifyTip]}"/>
      </WrapPanel>
      <TextBlock Text="{Binding Loc[Settings.DatPerfNote]}"
                 Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>

      <!-- DAT-Mapping -->
      <TextBlock Text="{Binding Loc[Settings.SectionDatMapping]}" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
      <TextBlock Text="{Binding Loc[Settings.DatMappingDesc]}"
                 Style="{StaticResource CaptionText}" Margin="0,0,0,8" TextWrapping="Wrap"/>
      <DataGrid MinHeight="200" MaxHeight="400"
                ItemsSource="{Binding DatMappings}"
                AutoGenerateColumns="False"
                CanUserAddRows="True" CanUserDeleteRows="True"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"
                AutomationProperties.Name="{Binding Loc[Settings.DatMappingName]}">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="Console" Width="130">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Console}" VerticalAlignment="Center" Margin="4,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
            <DataGridTemplateColumn.CellEditingTemplate>
              <DataTemplate>
                <ComboBox SelectedItem="{Binding Console, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.AllConsoleKeys, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          IsDropDownOpen="True" MaxDropDownHeight="300"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellEditingTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="DAT File" Width="*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="30" Padding="2"
                          Click="OnBrowseDatFile_Click" AutomationProperties.Name="DAT-Datei durchsuchen"/>
                  <TextBlock Text="{Binding DatFile}" VerticalAlignment="Center" Margin="4,0"
                             TextTrimming="CharacterEllipsis" ToolTip="{Binding DatFile}"/>
                </DockPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
            <DataGridTemplateColumn.CellEditingTemplate>
              <DataTemplate>
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="30" Padding="2"
                          Click="OnBrowseDatFile_Click" AutomationProperties.Name="DAT-Datei durchsuchen"/>
                  <TextBox Text="{Binding DatFile, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                </DockPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellEditingTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
      <Button Margin="0,8,0,0" Padding="12,6"
              HorizontalAlignment="Left"
              Command="{Binding AutoDetectDatMappingsCommand}"
              ToolTip="Scannt den DAT-Ordner und ordnet gefundene DAT-Dateien automatisch Konsolen zu."
              AutomationProperties.Name="DAT-Mapping automatisch erkennen">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBlock Text="DATs auto-erkennen" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl x:Class="RomCleanup.UI.Wpf.Views.NavigationRail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- ═══ NAVIGATION RAIL (72px, vertical, left) ═════════════════════════
       5 top-level areas: Mission Control, Library, Config, Tools, System
       Help button pinned to bottom.
       Active-indicator: NavButton style has 3px left Neon-Border + Glow.
       Keyboard: Ctrl+1..5 via InputBindings on MainWindow. ═════════════ -->
  <Border Background="{DynamicResource BrushSurfaceAlt}"
          BorderBrush="{DynamicResource BrushBorder}"
          BorderThickness="0,0,1,0" Width="{DynamicResource NavRailWidth}">
    <DockPanel LastChildFill="False">

      <!-- ── Top nav items ─────────────────────────────────────────── -->
      <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">

        <!-- Mission Control (🏠 Home) -->
        <RadioButton GroupName="Nav"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=MissionControl}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.MissionControl]}" TabIndex="50"
                     AutomationProperties.Name="{Binding Loc[Nav.MissionControl]}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Mission" FontSize="9" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <!-- Library & Review (📊) -->
        <RadioButton GroupName="Nav"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Library}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.Library]}" TabIndex="51"
                     AutomationProperties.Name="{Binding Loc[Nav.Library]}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Library" FontSize="9" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <!-- Config (⚙) -->
        <RadioButton GroupName="Nav"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Config}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.Config]}" TabIndex="52"
                     AutomationProperties.Name="{Binding Loc[Nav.Config]}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Config" FontSize="9" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <!-- Tools (🔧) -->
        <RadioButton GroupName="Nav"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Tools}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.Tools]}" TabIndex="53"
                     AutomationProperties.Name="{Binding Loc[Nav.Tools]}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE90F;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Tools" FontSize="9" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <!-- System (💻) -->
        <RadioButton GroupName="Nav"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=System}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.System]}" TabIndex="54"
                     AutomationProperties.Name="{Binding Loc[Nav.System]}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE770;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="System" FontSize="9" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <!-- ── Bottom: Help shortcut toggle ──────────────────────────── -->
      <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
        <RadioButton GroupName="Nav" IsChecked="False"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Shortcuts.Title]}" TabIndex="55"
                     Command="{Binding Shell.ToggleShortcutSheetCommand}"
                     AutomationProperties.Name="{Binding Loc[Shortcuts.Title]}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE897;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Hilfe" FontSize="9" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>
      </StackPanel>
    </DockPanel>
  </Border>
</UserControl>

<Window x:Class="RomCleanup.UI.Wpf.Views.ConversionReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konvertierung prüfen"
        Width="920"
        Height="540"
        MinWidth="760"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BrushBackground}"
        Foreground="{DynamicResource BrushTextPrimary}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding CountLabel}" Margin="0,6,0,0" Foreground="{DynamicResource BrushWarning}"/>
        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  AlternatingRowBackground="{DynamicResource BrushSurfaceAlt}"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Datei" Binding="{Binding SourcePath}" Width="*" MinWidth="380"/>
                <DataGridTextColumn Header="Ziel" Binding="{Binding TargetExtension}" Width="120"/>
                <DataGridTextColumn Header="Sicherheitsgrund" Binding="{Binding SafetyReason}" Width="260"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Abbrechen"
                    Width="120"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"/>
            <Button Content="Manuell geprüft und fortfahren"
                    Width="250"
                    Background="{DynamicResource BrushWarning}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Command="{Binding ConfirmCommand}"/>
        </StackPanel>
    </Grid>
</Window>

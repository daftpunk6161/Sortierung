<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<!-- ═══ RETRO CRT ════════════════════════════════════════════════════════
     Phosphor green on deep black — 80s terminal vibes. Monochrome-ish
     with amber warning and red danger accents.
     Colours only — templates in _ControlTemplates.xaml. ══════════════════ -->

    <!-- ── Core Surfaces ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushBackground"   Color="#050A05"/>
    <SolidColorBrush x:Key="BrushSurface"      Color="#0C140C"/>
    <SolidColorBrush x:Key="BrushSurfaceAlt"   Color="#081008"/>
    <SolidColorBrush x:Key="BrushSurfaceLight" Color="#142014"/>

    <!-- ── Accent ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushAccentCyan"   Color="#33FF33"/>
    <SolidColorBrush x:Key="BrushAccentPurple" Color="#FFAA00"/>

    <!-- ── Semantic ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDanger"       Color="#FF2222"/>
    <SolidColorBrush x:Key="BrushSuccess"      Color="#33FF33"/>
    <SolidColorBrush x:Key="BrushWarning"      Color="#FFAA00"/>

    <!-- ── Text ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushTextPrimary"  Color="#CCFFCC"/>
    <SolidColorBrush x:Key="BrushTextMuted"    Color="#66AA66"/>
    <SolidColorBrush x:Key="BrushBorder"       Color="#1A3A1A"/>

    <!-- ── Semantic Backgrounds ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDangerBg"  Color="#1A0808"/>
    <SolidColorBrush x:Key="BrushSuccessBg" Color="#081A08"/>
    <SolidColorBrush x:Key="BrushInfoBg"    Color="#081A0A"/>
    <SolidColorBrush x:Key="BrushWarningBg" Color="#1A1408"/>

    <!-- ── Interaction ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushButtonPressed"   Color="#33FF3322"/>
    <SolidColorBrush x:Key="BrushInputSelection"  Color="#33FF3344"/>
    <SolidColorBrush x:Key="BrushBorderHover"     Color="#33AA33"/>
    <SolidColorBrush x:Key="BrushPrimaryBg"       Color="#33FF3333"/>
    <SolidColorBrush x:Key="BrushTextOnAccent"    Color="#000000"/>
    <SolidColorBrush x:Key="BrushPrimaryHover"    Color="#33FF3355"/>
    <SolidColorBrush x:Key="BrushPrimaryActive"   Color="#33FF3377"/>
    <SolidColorBrush x:Key="BrushDangerHover"     Color="#FF222222"/>
    <SolidColorBrush x:Key="BrushScrimOverlay"    Color="#CC000800"/>

</ResourceDictionary>

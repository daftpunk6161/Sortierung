<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
<!-- ═══ DENSITY: COMPACT (×0.75 spacing scale) ═══════════════════════ -->
<!-- Overrides spacing tokens from _DesignTokens.xaml for tighter layout. -->

    <sys:Double x:Key="SpaceXS">3</sys:Double>
    <sys:Double x:Key="SpaceSM">6</sys:Double>
    <sys:Double x:Key="SpaceMD">9</sys:Double>
    <sys:Double x:Key="SpaceLG">12</sys:Double>
    <sys:Double x:Key="SpaceXL">18</sys:Double>
    <sys:Double x:Key="SpaceXXL">24</sys:Double>
    <Thickness x:Key="SpaceBottomXS">0 0 0 3</Thickness>
    <Thickness x:Key="SpaceBottomSM">0 0 0 6</Thickness>
    <Thickness x:Key="SpaceBottomMD">0 0 0 9</Thickness>
    <Thickness x:Key="SpaceBottomLG">0 0 0 12</Thickness>
    <Thickness x:Key="SpaceBottomXL">0 0 0 18</Thickness>
    <Thickness x:Key="PaddingBar">12 6 12 6</Thickness>
    <Thickness x:Key="PaddingSection">12 12 12 12</Thickness>
    <Thickness x:Key="PaddingCard">12 12 12 12</Thickness>
    <Thickness x:Key="SpaceRightSM">0 0 6 0</Thickness>
    <Thickness x:Key="SpaceRightMD">0 0 9 0</Thickness>
    <Thickness x:Key="SpaceDotInline">3 0 3 0</Thickness>
    <Thickness x:Key="SpaceDivider">6 0 6 0</Thickness>
    <Thickness x:Key="SpaceLeftSM">6 0 0 0</Thickness>
    <Thickness x:Key="SpaceRightXS">0 0 3 0</Thickness>
    <Thickness x:Key="SpaceTopLG">0 12 0 0</Thickness>

</ResourceDictionary>

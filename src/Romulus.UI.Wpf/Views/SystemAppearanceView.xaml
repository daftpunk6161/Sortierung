<UserControl x:Class="Romulus.UI.Wpf.Views.SystemAppearanceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- Extracted from SettingsView "Allgemein" section -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
    <StackPanel>
      <TextBlock Text="{Binding Loc[Settings.SectionGeneral]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="130"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="38"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="6"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Content="{Binding Loc[Settings.TrashLabel]}" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TrashRoot, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Margin="{DynamicResource SpaceRightXS}"
                 ToolTip="{Binding Loc[Settings.TrashTip]}"
                 AutomationProperties.Name="{Binding Loc[Settings.TrashName]}"/>
        <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                Command="{Binding BrowseFolderPathCommand}" CommandParameter="Trash"
                AutomationProperties.Name="{Binding Loc[Settings.TrashBrowse]}"/>
        <Label Grid.Row="2" Grid.Column="0" Content="{Binding Loc[Settings.LogLevelLabel]}" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                  SelectedValue="{Binding LogLevel, Mode=TwoWay}"
                  SelectedValuePath="Content"
                  AutomationProperties.Name="{Binding Loc[Settings.LogLevelLabel]}">
          <ComboBoxItem Content="Debug"/>
          <ComboBoxItem Content="Info"/>
          <ComboBoxItem Content="Warning"/>
          <ComboBoxItem Content="Error"/>
        </ComboBox>
      </Grid>
      <WrapPanel Margin="0,12,0,0">
        <!-- TASK-129: Theme-Switcher-Dropdown mit Farbvorschau -->
        <ComboBox Width="200" Margin="0,0,8,4"
                  ItemsSource="{Binding AvailableThemes}"
                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                  AutomationProperties.Name="{Binding Loc[Settings.ThemeName]}"
                  ToolTip="Ctrl+T">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <Rectangle x:Name="ThemeColorPreview" Width="16" Height="16" RadiusX="3" RadiusY="3" Margin="0,0,8,0"
                           Fill="{DynamicResource BrushAccentCyan}" Stroke="{DynamicResource BrushBorder}" StrokeThickness="1"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Command="{Binding ThemeToggleCommand}" Content="{Binding ThemeToggleText}" MinWidth="120" Padding="8,2" Margin="0,0,8,4" AutomationProperties.Name="{Binding Loc[Settings.ThemeName]}"/>
        <ComboBox Width="120" Margin="0,0,8,4"
                  SelectedValuePath="Content"
                  SelectedValue="{Binding Locale, Mode=TwoWay}"
                  AutomationProperties.Name="{Binding Loc[Settings.LocaleName]}"
                  ToolTip="{Binding Loc[Settings.LocaleTip]}">
          <ComboBoxItem Content="de"/>
          <ComboBoxItem Content="en"/>
          <ComboBoxItem Content="fr"/>
        </ComboBox>
        <Button Content="{Binding Loc[Settings.BtnApplyLocale]}" MinWidth="140" Padding="8,2" Margin="0,0,8,4"
                Command="{Binding FeatureCommands[ApplyLocale]}" AutomationProperties.Name="{Binding Loc[Settings.BtnApplyLocale]}"/>
      </WrapPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl x:Class="Romulus.UI.Wpf.Views.DatAuditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Romulus.UI.Wpf.Converters"
>
  <!-- TASK-052: DatAudit-Tab (Read-Only) — DataGrid with status badges, filters, summary bar -->
  <UserControl.Resources>
    <conv:DatAuditStatusToBrushConverter x:Key="StatusToBrush"/>
    <conv:DatAuditStatusToLabelConverter x:Key="StatusToLabel"/>
  </UserControl.Resources>

  <Grid Margin="20,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Summary bar -->
      <RowDefinition Height="Auto"/>  <!-- Filter bar -->
      <RowDefinition Height="*"/>     <!-- DataGrid -->
    </Grid.RowDefinitions>

    <!-- ═══ SUMMARY BAR ═══════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="{DynamicResource BrushSurface}"
            CornerRadius="{DynamicResource RadiusMD}" Padding="16,10" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                     Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,8,0" VerticalAlignment="Center"/>
          <TextBlock Text="DAT Audit" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Summary counters -->
        <WrapPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#00FF88" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Have: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding HaveCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#FFB700" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Wrong Name: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding HaveWrongNameCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#FF0044" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Miss: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding MissCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#9999CC" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Unknown: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding UnknownCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal">
            <Border Width="10" Height="10" Background="#FFD500" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Ambiguous: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding AmbiguousCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
        </WrapPanel>

        <!-- Total + Export -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock VerticalAlignment="Center" Margin="0,0,12,0">
            <Run Text="Gesamt: " Foreground="{DynamicResource BrushTextMuted}"/>
            <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="Bold"/>
          </TextBlock>
          <Button Content="&#xE72D;" FontFamily="Segoe MDL2 Assets" ToolTip="Als CSV exportieren"
                  Command="{Binding ExportCsvCommand}" Width="32" Height="28" Padding="4"
                  AutomationProperties.Name="DatAudit CSV Export"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ FILTER BAR ════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0"
                   Foreground="{DynamicResource BrushTextMuted}"/>
        <ComboBox Width="140" SelectedItem="{Binding SelectedStatusFilter}"
                  ItemsSource="{Binding StatusFilterOptions}"
                  AutomationProperties.Name="DatAudit Status Filter"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
        <TextBlock Text="Konsole:" VerticalAlignment="Center" Margin="0,0,6,0"
                   Foreground="{DynamicResource BrushTextMuted}"/>
        <ComboBox Width="160" SelectedItem="{Binding SelectedConsoleFilter}"
                  ItemsSource="{Binding ConsoleFilterOptions}"
                  AutomationProperties.Name="DatAudit Console Filter"/>
      </StackPanel>

      <TextBox Grid.Column="2"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
               Tag="Suche in Dateiname, Spielname..."
               AutomationProperties.Name="DatAudit Suche"/>
    </Grid>

    <!-- ═══ DATA GRID ════════════════════════════════════════════════ -->
    <DataGrid Grid.Row="2"
              ItemsSource="{Binding EntriesView}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              SelectionMode="Single"
              AlternatingRowBackground="{DynamicResource BrushSurfaceAlt}"
              HeadersVisibility="Column"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling"
              ScrollViewer.CanContentScroll="True"
              AutomationProperties.Name="DatAudit Ergebnisse">
      <DataGrid.Columns>
        <!-- Status badge -->
        <DataGridTemplateColumn Header="Status" Width="110" SortMemberPath="Status" CanUserSort="True">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Border Background="{Binding Status, Converter={StaticResource StatusToBrush}}"
                      CornerRadius="3" Padding="6,2" HorizontalAlignment="Left" Opacity="0.85">
                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToLabel}}"
                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- File name -->
        <DataGridTextColumn Header="Datei" Width="*" MinWidth="240"
                            Binding="{Binding FilePath}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
              <Setter Property="ToolTip" Value="{Binding FilePath}"/>
              <Setter Property="FontFamily" Value="{DynamicResource FontMono}"/>
              <Setter Property="FontSize" Value="12"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- Console -->
        <DataGridTextColumn Header="Konsole" Width="100"
                            Binding="{Binding ConsoleKey}"/>

        <!-- DAT game name -->
        <DataGridTextColumn Header="DAT-Spielname" Width="200"
                            Binding="{Binding DatGameName}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
              <Setter Property="ToolTip" Value="{Binding DatGameName}"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- DAT ROM filename -->
        <DataGridTextColumn Header="DAT-Dateiname" Width="200"
                            Binding="{Binding DatRomFileName}">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
              <Setter Property="ToolTip" Value="{Binding DatRomFileName}"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- Confidence -->
        <DataGridTextColumn Header="Conf." Width="60"
                            Binding="{Binding Confidence, StringFormat={}{0}%}"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- ═══ EMPTY STATE ══════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVis}}"
            Background="{DynamicResource BrushSurface}"
            CornerRadius="{DynamicResource RadiusMD}"
            Padding="40" VerticalAlignment="Center" HorizontalAlignment="Center">
      <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                   HorizontalAlignment="Center" Margin="0,0,0,12"
                   Foreground="{DynamicResource BrushTextMuted}" Opacity="0.5"/>
        <TextBlock Text="Keine DatAudit-Ergebnisse vorhanden."
                   HorizontalAlignment="Center" Foreground="{DynamicResource BrushTextMuted}"/>
        <TextBlock Text="Starte einen Lauf mit aktiviertem DAT-Abgleich um Ergebnisse zu sehen."
                   HorizontalAlignment="Center" Foreground="{DynamicResource BrushTextMuted}"
                   FontSize="11" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

<UserControl x:Class="Romulus.UI.Wpf.Views.ProgressView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="{DynamicResource SpaceBottomMD}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="{Binding Loc[Progress.Title]}" Style="{StaticResource SectionHeader}" FontSize="20"/>
        <TextBlock Text="{Binding BusyHint}" Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
      </StackPanel>
      <Border Grid.Column="1" Style="{StaticResource HeaderChip}" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,6,0"/>
          <TextBlock Text="{Binding Loc[Progress.MinimizeHint]}" Foreground="{DynamicResource BrushTextPrimary}"/>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
      <StackPanel>
        <TextBlock Text="Pipeline" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"/>
        <WrapPanel>
          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=1}"/>
                <TextBlock Text="{Binding Loc[Phase.Preflight]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Konfiguration prüfen" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=2}"/>
                <TextBlock Text="{Binding Loc[Phase.Scan]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Quellen materialisieren" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=3}"/>
                <TextBlock Text="{Binding Loc[Phase.Dedupe]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Kandidaten bewerten" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76"
                  Visibility="{Binding IsMovePhaseApplicable, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=4}"/>
                <TextBlock Text="{Binding Loc[Phase.Move]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Sichere Moves ausführen" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=5}"/>
                <TextBlock Text="{Binding Loc[Phase.Sort]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Zielstruktur aufbauen" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76"
                  Visibility="{Binding IsConvertPhaseApplicable, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=6}"/>
                <TextBlock Text="{Binding Loc[Phase.Convert]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Formate optimieren" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource MetricCard}" Width="150" MinHeight="76">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Border Width="16" Height="16" Margin="0,0,8,0"
                        CornerRadius="3"
                        Background="{Binding CurrentRunState, Converter={StaticResource PhaseBrush}, ConverterParameter=7}"/>
                <TextBlock Text="{Binding Loc[Phase.Done]}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
              </StackPanel>
              <TextBlock Text="Report und Undo bereit" Style="{StaticResource CaptionText}" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>
        </WrapPanel>

        <TextBlock Text="{Binding SkippedPhaseInfoText}" Style="{StaticResource CaptionText}" Margin="0,10,0,0"
                   Visibility="{Binding ShowSkippedPhaseInfo, Converter={StaticResource BoolToVis}}"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomMD}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,16,0">
          <TextBlock Text="{Binding PerfPhase}" FontSize="18" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextPrimary}" Margin="{DynamicResource SpaceBottomXS}"/>
          <TextBlock Text="{Binding PerfFile}" Foreground="{DynamicResource BrushTextMuted}"
                     FontSize="12" TextTrimming="CharacterEllipsis" Margin="{DynamicResource SpaceBottomSM}"/>
          <ProgressBar Height="10" Maximum="100" Value="{Binding Progress}" AutomationProperties.Name="Fortschritt"/>
        </StackPanel>

        <Border Grid.Column="1" Style="{StaticResource AccentHeaderChip}" VerticalAlignment="Stretch">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding ProgressText}" FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Loc[Progress.CancelHint]}" FontSize="12"
                       Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="3" Style="{StaticResource SectionCard}" Padding="12,10">
      <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
          <TextBlock Text="{Binding Loc[Progress.LiveLog]}" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
          <TextBlock DockPanel.Dock="Right" Text="{Binding RunStateDisplayText}" Style="{StaticResource CaptionText}"
                     VerticalAlignment="Center"/>
        </DockPanel>
        <ListBox ItemsSource="{Binding LogEntries}"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 BorderThickness="0" Background="Transparent"
                 AutomationProperties.Name="{Binding Loc[Progress.LiveLog]}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Text}" FontFamily="Consolas" FontSize="11"
                         Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                         TextTrimming="CharacterEllipsis"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>

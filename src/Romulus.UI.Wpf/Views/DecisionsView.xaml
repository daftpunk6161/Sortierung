<UserControl x:Class="Romulus.UI.Wpf.Views.DecisionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- Dedupe Decisions full-screen view — shows winner/loser decisions per game key.
       Data: Run.DedupeGroupItems (populated from DashboardProjection after DryRun/Execute). -->
  <Grid>
    <!-- ═══ HAS DATA STATE ════════════════════════════════════════════ -->
    <DockPanel Visibility="{Binding Run.HasRunData, Converter={StaticResource BoolToVis}}"
               Margin="20,16">

      <!-- ── SUMMARY BAR ──────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurface}"
              CornerRadius="{DynamicResource RadiusMD}" Padding="16,10" Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Title -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="Dedupe Decisions" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Counters -->
          <WrapPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
              <Border Width="10" Height="10" Background="{DynamicResource BrushSuccess}" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock VerticalAlignment="Center">
                <Run Text="Winners: " Foreground="{DynamicResource BrushTextMuted}"/>
                <Run Text="{Binding Run.DashWinners, Mode=OneWay}" FontWeight="SemiBold"/>
              </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
              <Border Width="10" Height="10" Background="{DynamicResource BrushWarning}" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock VerticalAlignment="Center">
                <Run Text="Dupes: " Foreground="{DynamicResource BrushTextMuted}"/>
                <Run Text="{Binding Run.DashDupes, Mode=OneWay}" FontWeight="SemiBold"/>
              </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <Border Width="10" Height="10" Background="{DynamicResource BrushAccentCyan}" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock VerticalAlignment="Center">
                <Run Text="Gruppen: " Foreground="{DynamicResource BrushTextMuted}"/>
                <Run Text="{Binding Run.DedupeGroupItems.Count, Mode=OneWay}" FontWeight="SemiBold"/>
              </TextBlock>
            </StackPanel>
          </WrapPanel>
        </Grid>
      </Border>

      <!-- ── SEARCH BAR ───────────────────────────────────────────── -->
      <Border DockPanel.Dock="Top" Margin="0,0,0,8">
        <TextBox x:Name="txtSearch"
                 Tag="Suche nach GameKey oder Dateiname..."
                 Text="{Binding Run.DecisionSearchText, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.Name="Decisions Suche"/>
      </Border>

      <!-- ── DECISION TREE ────────────────────────────────────────── -->
      <TreeView x:Name="treeDecisions"
                ItemsSource="{Binding Run.DedupeGroupItemsView}"
                BorderThickness="0"
                Background="Transparent"
                AutomationProperties.Name="Dedupe Decisions TreeView"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True">
        <TreeView.ItemTemplate>
          <HierarchicalDataTemplate ItemsSource="{Binding Losers}">
            <StackPanel Orientation="Horizontal" Margin="0,3">
              <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                         Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="{Binding GameKey}" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
              <TextBlock Text=" — " Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
              <TextBlock Text="&#x2605; " Foreground="{DynamicResource BrushSuccess}" VerticalAlignment="Center" FontSize="14"/>
              <TextBlock Text="{Binding Winner.FileName}" Foreground="{DynamicResource BrushSuccess}"
                         VerticalAlignment="Center" FontWeight="Medium"/>
              <Border Background="{DynamicResource BrushSurface}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                      VerticalAlignment="Center">
                <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="11">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="[{0}]  R:{1}  F:{2}  V:{3}  D:{4}  T:{5}">
                      <Binding Path="Winner.Region"/>
                      <Binding Path="Winner.RegionScore"/>
                      <Binding Path="Winner.FormatScore"/>
                      <Binding Path="Winner.VersionScore"/>
                      <Binding Path="Winner.DecisionClass"/>
                      <Binding Path="Winner.EvidenceTier"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Border>
              <Border Background="{DynamicResource BrushSurface}" CornerRadius="4" Padding="4,2" Margin="6,0,0,0"
                      VerticalAlignment="Center">
                <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}">
                  <Run Text="×"/>
                  <Run Text="{Binding Losers.Count, Mode=OneWay}"/>
                  <Run Text=" Dupes"/>
                </TextBlock>
              </Border>
            </StackPanel>
            <HierarchicalDataTemplate.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                  <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                             Foreground="{DynamicResource BrushWarning}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource BrushTextMuted}"
                             VerticalAlignment="Center"/>
                  <Border Background="{DynamicResource BrushSurface}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                          VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Opacity="0.7">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="[{0}]  R:{1}  F:{2}  V:{3}  D:{4}  T:{5}">
                          <Binding Path="Region"/>
                          <Binding Path="RegionScore"/>
                          <Binding Path="FormatScore"/>
                          <Binding Path="VersionScore"/>
                          <Binding Path="DecisionClass"/>
                          <Binding Path="EvidenceTier"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                  </Border>
                </StackPanel>
              </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
          </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>
    </DockPanel>

    <!-- ═══ EMPTY STATE ═══════════════════════════════════════════════ -->
    <StackPanel Visibility="{Binding Run.HasRunData, Converter={StaticResource InverseBoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center">
      <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                 Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
      <TextBlock Text="Keine Dedupe-Entscheidungen" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
      <TextBlock Text="Starte eine Vorschau (F5) um die Dedupe-Entscheidungen zu sehen."
                 Foreground="{DynamicResource BrushTextMuted}" FontSize="12" HorizontalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>

<UserControl x:Class="Romulus.UI.Wpf.Views.ContextPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{DynamicResource BrushSurfaceAlt}"
          BorderBrush="{DynamicResource BrushBorder}"
          BorderThickness="1,0,0,0"
          Width="{DynamicResource ContextWingWidth}"
          Padding="14,14,14,12">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <DockPanel Margin="0,0,0,12">
          <Button DockPanel.Dock="Right" Content="✕" Padding="6,2"
                  Command="{Binding Shell.ToggleContextWingCommand}"
                  Style="{StaticResource HeaderActionButton}"
                  ToolTip="Inspector schließen (Ctrl+I)"
                  AutomationProperties.Name="Inspector schließen"
                  VerticalAlignment="Top"/>
          <StackPanel>
            <TextBlock Text="Inspector" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="{Binding Shell.CurrentWorkspaceBreadcrumb}" Style="{StaticResource CaptionText}"/>
          </StackPanel>
        </DockPanel>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="Arbeitsbereich" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding Shell.CurrentWorkspaceTitle}"
                       Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Shell.CurrentWorkspaceSection}"
                       Style="{StaticResource CaptionText}" Margin="0,2,0,10"/>
            <TextBlock Text="{Binding SelectedWorkflowName}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SelectedRunProfileName}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Foreground="{DynamicResource BrushTextMuted}">
              <Run Text="Modus: "/><Run Text="{Binding CurrentUiModeLabel}"/>
            </TextBlock>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="Status" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource AccentHeaderChip}" Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal">
                <Border Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                        CornerRadius="2"
                        Background="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"/>
                <StackPanel>
                  <TextBlock Text="{Binding StatusReady}" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding StatusRuntime}" Style="{StaticResource CaptionText}"/>
                </StackPanel>
              </StackPanel>
            </Border>
            <WrapPanel>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel Orientation="Horizontal">
                  <Border Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                          CornerRadius="2"
                          Background="{Binding RootsStatusLevel, Converter={StaticResource StatusToBrush}}"/>
                  <TextBlock Text="{Binding StatusRoots}" Foreground="{DynamicResource BrushTextPrimary}"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel Orientation="Horizontal">
                  <Border Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                          CornerRadius="2"
                          Background="{Binding ToolsStatusLevel, Converter={StaticResource StatusToBrush}}"/>
                  <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextPrimary}"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel Orientation="Horizontal">
                  <Border Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                          CornerRadius="2"
                          Background="{Binding DatStatusLevel, Converter={StaticResource StatusToBrush}}"/>
                  <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextPrimary}"/>
                </StackPanel>
              </Border>
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Visibility="{Binding HasRecommendedTools, Converter={StaticResource BoolToVis}}">
          <StackPanel>
            <DockPanel Margin="0,0,0,8">
              <Button DockPanel.Dock="Right"
                      Content="{Binding Loc[Tools.OpenCatalog]}"
                      Command="{Binding GoToToolsCommand}"
                      Padding="8,2"
                      AutomationProperties.Name="{Binding Loc[Tools.OpenCatalog]}"/>
              <TextBlock Text="{Binding Loc[Tools.ContextRecommendedTitle]}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushTextMuted}"/>
            </DockPanel>
            <ItemsControl ItemsSource="{Binding RecommendedToolItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Margin="0,0,0,8"
                          Padding="10,8"
                          HorizontalContentAlignment="Left"
                          Command="{Binding Command}"
                          ToolTip="{Binding MaturityDescription}"
                          AutomationProperties.Name="{Binding DisplayName}">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,8,0"/>
                        <StackPanel>
                          <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
                          <TextBlock Text="{Binding RecommendationReason}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                        </StackPanel>
                      </StackPanel>
                      <TextBlock Text="{Binding MaturityBadgeText}" FontSize="10" FontWeight="SemiBold" Margin="22,6,0,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsGuided}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccentCyan}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushWarning}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=MissionControl}">
          <StackPanel>
            <TextBlock Text="Nächster sinnvoller Schritt" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding Loc[Context.StartHint1]}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Loc[Context.StartHint2]}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Loc[Context.StartHint3]}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
            <Button Content="{Binding Loc[Context.RunPreview]}" Command="{Binding QuickPreviewCommand}"
                    AutomationProperties.Name="{Binding Loc[Context.RunPreview]}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Library}">
          <StackPanel>
            <TextBlock Text="Analyse-Fokus" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4">
              <Run Text="Modus: "/><Run Text="{Binding Run.DashMode}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4">
              <Run Text="Duplikate: "/><Run Text="{Binding Run.DashDupes}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10">
              <Run Text="Junk: "/><Run Text="{Binding Run.DashJunk}"/>
            </TextBlock>
            <Button Content="{Binding Loc[Report.OpenReportLog]}" Command="{Binding OpenReportCommand}"
                    AutomationProperties.Name="{Binding Loc[Report.OpenReportLog]}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Config}">
          <StackPanel>
            <TextBlock Text="Sicherheits-Check" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding MoveApplyGateText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
            <Button Content="{Binding Loc[Context.RunPreview]}" Command="{Binding QuickPreviewCommand}"
                    AutomationProperties.Name="{Binding Loc[Context.RunPreview]}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Tools}">
          <StackPanel>
            <TextBlock Text="Tool-Zustand" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextPrimary}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=System}">
          <StackPanel>
            <TextBlock Text="System-Aktionen" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <Button Content="{Binding Loc[Start.FlowOpenSetup]}" Command="{Binding GoToConfigCommand}" Margin="0,0,0,6"
                    AutomationProperties.Name="{Binding Loc[Start.FlowOpenSetup]}"/>
            <Button Content="{Binding Loc[Start.FlowOpenAnalyse]}" Command="{Binding GoToLibraryCommand}" Margin="0,0,0,6"
                    AutomationProperties.Name="{Binding Loc[Start.FlowOpenAnalyse]}"/>
            <Button Content="{Binding Loc[Report.OpenReportLog]}" Command="{Binding OpenReportCommand}"
                    AutomationProperties.Name="{Binding Loc[Report.OpenReportLog]}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="Move-Sicherheit" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding MoveApplyGateText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>

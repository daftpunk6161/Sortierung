<UserControl x:Class="Romulus.UI.Wpf.Views.LibrarySafetyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- ═══ SAFETY REVIEW VIEW (Library → Safety sub-tab) ══════════════════
       Shows items grouped by sort gate decision: Blocked / Review / Unknown.
       Populated from LastCandidates after each run. ═════════════════════ -->
  <Border Background="{DynamicResource BrushBackground}" Padding="20,16">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="0,0,0,12">
        <TextBlock Text="Safety Review" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
        <TextBlock Foreground="{DynamicResource BrushTextMuted}" FontSize="12"
                   Text="Dateien, die vom Sort-Gate blockiert, zur Überprüfung markiert oder als unbekannt klassifiziert wurden."/>
      </StackPanel>

      <!-- Content: 3-column layout -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Blocked items (red) -->
        <Border Grid.Column="0" Style="{StaticResource SectionCard}" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Border Width="10" Height="10" Background="{DynamicResource BrushDanger}" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
              <TextBlock Text="Blockiert" FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource BrushDanger}"/>
              <TextBlock x:Name="BlockedCount" Margin="6,0,0,0" FontSize="12"
                         Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
            </StackPanel>
            <ListBox x:Name="BlockedList" Grid.Row="1" BorderThickness="0"
                     Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AutomationProperties.Name="Blockierte Dateien">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,2">
                    <TextBlock Text="{Binding FileName}" FontSize="12"
                               Foreground="{DynamicResource BrushTextPrimary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}">
                      <Run Text="{Binding ConsoleKey, Mode=OneWay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding MatchLevel, Mode=OneWay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding Reason, Mode=OneWay}"/>
                    </TextBlock>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <!-- Empty state -->
            <TextBlock Grid.Row="1" Text="Keine blockierten Dateien"
                       Foreground="{DynamicResource BrushTextMuted}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       x:Name="BlockedEmpty"/>
          </Grid>
        </Border>

        <!-- Review items (orange) -->
        <Border Grid.Column="2" Style="{StaticResource SectionCard}" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Border Width="10" Height="10" Background="{DynamicResource BrushWarning}" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
              <TextBlock Text="Überprüfung" FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource BrushWarning}"/>
              <TextBlock x:Name="ReviewCount" Margin="6,0,0,0" FontSize="12"
                         Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
            </StackPanel>
            <ListBox x:Name="ReviewList" Grid.Row="1" BorderThickness="0"
                     Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AutomationProperties.Name="Zur Überprüfung markierte Dateien">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,2">
                    <TextBlock Text="{Binding FileName}" FontSize="12"
                               Foreground="{DynamicResource BrushTextPrimary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}">
                      <Run Text="{Binding ConsoleKey, Mode=OneWay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding MatchLevel, Mode=OneWay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding Reason, Mode=OneWay}"/>
                    </TextBlock>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <!-- Empty state -->
            <TextBlock Grid.Row="1" Text="Keine Dateien zur Überprüfung"
                       Foreground="{DynamicResource BrushTextMuted}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       x:Name="ReviewEmpty"/>
          </Grid>
        </Border>

        <!-- Unknown items (gray) -->
        <Border Grid.Column="4" Style="{StaticResource SectionCard}" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Border Width="10" Height="10" Background="{DynamicResource BrushTextMuted}" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
              <TextBlock Text="Unbekannt" FontWeight="SemiBold" FontSize="14"
                         Foreground="{DynamicResource BrushTextMuted}"/>
              <TextBlock x:Name="UnknownCount" Margin="6,0,0,0" FontSize="12"
                         Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
            </StackPanel>
            <ListBox x:Name="UnknownList" Grid.Row="1" BorderThickness="0"
                     Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AutomationProperties.Name="Unbekannte Dateien">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,2">
                    <TextBlock Text="{Binding FileName}" FontSize="12"
                               Foreground="{DynamicResource BrushTextPrimary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}">
                      <Run Text="{Binding ConsoleKey, Mode=OneWay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding MatchLevel, Mode=OneWay}"/>
                      <Run Text=" · "/>
                      <Run Text="{Binding Reason, Mode=OneWay}"/>
                    </TextBlock>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <!-- Empty state -->
            <TextBlock Grid.Row="1" Text="Keine unbekannten Dateien"
                       Foreground="{DynamicResource BrushTextMuted}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       x:Name="UnknownEmpty"/>
          </Grid>
        </Border>
      </Grid>

      <!-- Global empty state when no run data -->
      <Border Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding Run.HasRunData, Converter={StaticResource InverseBoolToVis}}"
              x:Name="NoRunDataOverlay">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                     Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
          <TextBlock Text="Noch keine Analyse-Daten" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
          <TextBlock Text="Starte eine Vorschau (F5) um die Safety-Übersicht zu füllen."
                     Foreground="{DynamicResource BrushTextMuted}" FontSize="12" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>

<UserControl x:Class="Romulus.UI.Wpf.Views.SubTabBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{DynamicResource BrushSurface}"
          BorderBrush="{DynamicResource BrushBorder}"
          BorderThickness="0,0,0,1"
          Height="{DynamicResource TabBarHeight}">
    <Grid Margin="12,4,12,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <ScrollViewer Grid.Column="0"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    CanContentScroll="False">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=MissionControl}">
            <RadioButton GroupName="SubTab" Content="Dashboard" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowMissionDashboardTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Dashboard}"
                         AutomationProperties.Name="Dashboard"/>
            <RadioButton GroupName="SubTab" Content="Recent Runs" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowMissionRecentRunsTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=RecentRuns}"
                         AutomationProperties.Name="Recent Runs"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Library}">
            <RadioButton GroupName="SubTab" Content="Results" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowLibraryResultsTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Results}"
                         AutomationProperties.Name="Results Dashboard"/>
            <RadioButton GroupName="SubTab" Content="Decisions" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowLibraryDecisionsTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Decisions}"
                         AutomationProperties.Name="Dedupe Decisions"/>
            <RadioButton GroupName="SubTab" Content="Safety" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowLibrarySafetyTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Safety}"
                         AutomationProperties.Name="Safety Review"/>
            <RadioButton GroupName="SubTab" Content="Inbox" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowLibraryInboxTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Inbox}"
                         AutomationProperties.Name="Review Inbox (Quarantine Workflow)"/>
            <RadioButton GroupName="SubTab" Content="DAT Audit" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowLibraryDatAuditTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=DatAudit}"
                         AutomationProperties.Name="DAT Audit Ergebnisse"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Tools}">
            <!-- T-W1-LAYOUT-P7: Pipeline ist jetzt EIN Tools-SubTab; Conversion/Sorting/Batch
                 leben intern in PipelineWorkbenchView. Pipeline-Pill ist Expert-only. -->
            <RadioButton GroupName="SubTab" Content="Pipeline" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowToolsPipelineTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Pipeline}"
                         AutomationProperties.Name="Pipeline Workbench"/>
            <RadioButton GroupName="SubTab" Content="Externe Tools" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowToolsExternalToolsTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=ExternalTools}"
                         AutomationProperties.Name="External Tools"/>
            <RadioButton GroupName="SubTab" Content="Funktionen" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowToolsFeaturesTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Features}"
                         AutomationProperties.Name="Features"/>
            <RadioButton GroupName="SubTab" Content="DAT-Verwaltung" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowToolsDatManagementTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=DatManagement}"
                         AutomationProperties.Name="DAT Catalog Management"/>
            <RadioButton GroupName="SubTab" Content="Policy" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowToolsPolicyTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Policy}"
                         AutomationProperties.Name="Policy Governance"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToVis}, ConverterParameter=System}">
            <RadioButton GroupName="SubTab" Content="Appearance" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowSystemAppearanceTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Appearance}"
                         AutomationProperties.Name="Appearance Settings"/>
            <RadioButton GroupName="SubTab" Content="System" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowSystemAboutTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=About}"
                         AutomationProperties.Name="Audit and System Settings"/>
            <RadioButton GroupName="SubTab" Content="Audit" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowSystemAuditViewerTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=AuditViewer}"
                         AutomationProperties.Name="Audit Viewer (Read-only)"/>
            <!-- T-W1-LAYOUT-P3: Setup-Tabs (Regions/Options/Profiles) leben hier statt unter MissionControl. -->
            <RadioButton GroupName="SubTab" Content="Regions" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowSystemSetupRegionsTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Regions}"
                         AutomationProperties.Name="Region Priority Configuration"/>
            <RadioButton GroupName="SubTab" Content="Options" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowSystemSetupOptionsTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Options}"
                         AutomationProperties.Name="Run Options Configuration"/>
            <RadioButton GroupName="SubTab" Content="Profiles" Style="{StaticResource SubTabPill}"
                         Visibility="{Binding Shell.ShowSystemSetupProfilesTab, Converter={StaticResource BoolToVis}}"
                         IsChecked="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Profiles}"
                         AutomationProperties.Name="Profile Management"/>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="12,0,0,0"
                  Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}">
        <TextBlock Text="{Binding Shell.CurrentWorkspaceBreadcrumb}"
                   Foreground="{DynamicResource BrushTextMuted}"
                   FontSize="11"
                   VerticalAlignment="Center"/>
        <TextBlock Text=" • " Foreground="{DynamicResource BrushTextMuted}" Margin="6,0,6,0" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding StatusReady}"
                   Foreground="{DynamicResource BrushTextPrimary}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>

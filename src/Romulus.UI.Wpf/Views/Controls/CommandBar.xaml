<UserControl x:Class="Romulus.UI.Wpf.Views.CommandBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:Romulus.UI.Wpf.Views">
  <Border Background="{DynamicResource BrushSurfaceAlt}"
          BorderBrush="{DynamicResource BrushBorder}"
          BorderThickness="0,0,0,1"
          Height="{DynamicResource CommandBarHeight}">
    <Grid Margin="16,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
        <Border Width="32" Height="32" CornerRadius="9"
                BorderBrush="{DynamicResource BrushAccentCyan}" BorderThickness="1.5"
                Background="#0B2230" Margin="0,0,10,0">
          <!-- D6 (UX-Redesign Phase 3): Retro-Glow via themenspezifischer EffectAccentGlow-Resource.
               Clean/HighContrast Themes liefern eine transparente Dummy-Effect, Retro-Themes einen
               Neon-DropShadow. ReduceMotion-Trigger setzt Effect explizit zurueck (Barrierefreiheit). -->
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Effect" Value="{DynamicResource EffectAccentGlow}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Shell.ReduceMotion}" Value="True">
                  <Setter Property="Effect" Value="{x:Null}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:RomulusLogoMark Width="26" Height="26"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{Binding Loc[App.Title]}" Style="{StaticResource TitleText}" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding Shell.CurrentWorkspaceBreadcrumb}"
                     Style="{StaticResource CaptionText}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>

      <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
        <Border Style="{StaticResource AccentHeaderChip}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding ReadyStatusLevel, Converter={StaticResource StatusToGlyph}}"
                       FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"/>
            <Border Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                    CornerRadius="2"
                    Background="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"/>
            <StackPanel>
              <TextBlock Text="{Binding StatusReady}" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding StatusRuntime}" Style="{StaticResource CaptionText}"
                         Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource HeaderChip}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding RootsStatusLevel, Converter={StaticResource StatusToGlyph}}"
                       FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{Binding RootsStatusLevel, Converter={StaticResource StatusToBrush}}"/>
            <TextBlock Text="{Binding StatusRoots}" Foreground="{DynamicResource BrushTextPrimary}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource HeaderChip}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding ToolsStatusLevel, Converter={StaticResource StatusToGlyph}}"
                       FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{Binding ToolsStatusLevel, Converter={StaticResource StatusToBrush}}"/>
            <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextPrimary}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource HeaderChip}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding DatStatusLevel, Converter={StaticResource StatusToGlyph}}"
                       FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{Binding DatStatusLevel, Converter={StaticResource StatusToBrush}}"/>
            <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextPrimary}"/>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource HeaderChip}"
                Visibility="{Binding HasSelectedWorkflow, Converter={StaticResource BoolToVis}}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="Workflow:" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding SelectedWorkflowName}" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
        <ComboBox Width="190" Margin="0,0,8,0"
                  ItemsSource="{Binding AvailableRunProfiles}"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding SelectedRunProfileId, Mode=TwoWay}"
                  ToolTip="{Binding Loc[Profile.QuickSwitch]}"
                  AutomationProperties.Name="{Binding Loc[Profile.QuickSwitch]}"
                  Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>

        <Button Style="{StaticResource HeaderActionButton}"
                Command="{Binding ToggleCommandPaletteCommand}"
                ToolTip="{Binding Loc[Tools.CommandSearchTip]}"
                AutomationProperties.Name="{Binding Loc[Tools.CommandSearch]}"
                AutomationProperties.AcceleratorKey="Ctrl+K"
                Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="14"
                       Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding Loc[Tools.CommandSearch]}"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </Button>

        <Button Style="{StaticResource HeaderActionButton}"
                Command="{Binding Shell.ToggleContextWingCommand}"
                ToolTip="{Binding Shell.ContextToggleLabel}"
                AutomationProperties.Name="{Binding Shell.ContextToggleLabel}"
                Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="14"
                       Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,6,0"/>
            <TextBlock Text="Inspector"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </Button>

        <CheckBox Style="{StaticResource ModeTogglePill}"
                  IsChecked="{Binding IsSimpleMode, Mode=TwoWay}"
                  Content="{Binding CurrentUiModeLabel}"
                  ToolTip="UI-Modus wechseln. Aktiv = Einfach, inaktiv = Experte."
                  AutomationProperties.Name="UI-Modus wechseln"
                  AutomationProperties.HelpText="Aktiv = Einfachmodus, inaktiv = Expertenmodus"
                  Margin="0,0,8,0"/>

        <Button Style="{StaticResource HeaderActionButton}"
                Command="{Binding OpenReportCommand}"
                ToolTip="{Binding Loc[Report.OpenReportTip]}"
                AutomationProperties.Name="{Binding Loc[Report.OpenReport]}"
                AutomationProperties.AcceleratorKey="Ctrl+R"
                Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="14"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding Loc[Report.OpenReportLog]}"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </Button>

        <Button Style="{StaticResource HeaderActionButton}"
                Command="{Binding ThemeToggleCommand}"
                ToolTip="{Binding ThemeToggleText}"
                AutomationProperties.Name="Theme wechseln"
                AutomationProperties.AcceleratorKey="Ctrl+T">
          <StackPanel Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE790;" FontSize="14"
                       Foreground="{DynamicResource BrushAccentPurple}" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding CurrentThemeLabel}"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>

<UserControl x:Class="Romulus.UI.Wpf.Views.ToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Resources>
    <DataTemplate x:Key="ToolCardTemplate">
      <Grid Margin="0,0,10,10" Width="320">
        <!-- D7: Card click opens the documentation drawer; the actual tool launch lives
             on the drawer's "Werkzeug starten" button (single execute path). -->
        <Button Padding="12,10"
                HorizontalContentAlignment="Stretch"
                Command="{Binding DataContext.ShowToolDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{Binding MaturityDescription}"
                AutomationProperties.Name="{Binding DisplayName}"
                Tag="{Binding Key}">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Top"
                         Margin="{DynamicResource SpaceRightSM}"/>
              <StackPanel Width="250">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource BrushTextPrimary}"/>
                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}"
                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding RecommendationReason}"
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource BrushAccentCyan}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasRecommendationReason, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding AvailabilityText}"
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource BrushWarning}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasAvailabilityText, Converter={StaticResource BoolToVis}}"/>
              </StackPanel>
            </StackPanel>

            <WrapPanel Margin="0,8,0,0">
              <Border CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource BrushSuccessBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccess}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsGuided}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource BrushWarningBg}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                        <Setter Property="Background" Value="#1A6B21A8"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentPurple}"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                  <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                      <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsGuided}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource BrushWarning}"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource BrushAccentPurple}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Ellipse.Style>
                  </Ellipse>
                  <TextBlock Text="{Binding MaturityBadgeText}" FontSize="9" FontWeight="SemiBold">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsGuided}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource BrushWarning}"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource BrushAccentPurple}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>
              </Border>

              <Border Background="#1A6B21A8" BorderBrush="{DynamicResource BrushAccentPurple}"
                      BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                      Visibility="{Binding IsAdvancedFeature, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Advanced"
                           FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccentPurple}"/>
              </Border>

              <Border Background="{DynamicResource BrushWarningBg}" BorderBrush="{DynamicResource BrushWarning}"
                      BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                      Visibility="{Binding ShowPlannedBadge, Converter={StaticResource BoolToVis}}">
                <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource BrushWarning}">
                  <Run Text="{Binding DataContext.Loc[Tools.BadgePlanned], RelativeSource={RelativeSource AncestorType=Window}}"/>
                  <Run Text=" · Roadmap"/>
                </TextBlock>
              </Border>

              <Border Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                      BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                      Visibility="{Binding RequiresRunResult, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding DataContext.Loc[Tools.BadgeRunResult], RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
              </Border>
            </WrapPanel>
          </StackPanel>
        </Button>

        <Button Width="30" Height="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Command="{Binding DataContext.ToggleToolPinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding Key}"
                Style="{StaticResource HeaderActionButton}"
                ToolTip="{Binding DataContext.Loc[Tools.PinTip], RelativeSource={RelativeSource AncestorType=Window}}"
                AutomationProperties.Name="{Binding DataContext.Loc[Tools.PinTip], RelativeSource={RelativeSource AncestorType=Window}}">
          <Grid>
            <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                       Visibility="{Binding IsPinned, Converter={StaticResource InverseBoolToVis}}"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"
                       Foreground="{DynamicResource BrushAccentCyan}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </Button>

        <Button Width="24" Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,80,0"
                Visibility="{Binding ShowPlannedBadge, Converter={StaticResource BoolToVis}}"
                Command="{Binding DataContext.OpenRoadmapLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding RoadmapLink}"
                Style="{StaticResource HeaderActionButton}"
                ToolTip="Roadmap oeffnen"
                AutomationProperties.Name="Roadmap oeffnen">
          <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                     Foreground="{DynamicResource BrushWarning}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <!-- D7: Info-Button oeffnet Tool-Documentation-Drawer -->
        <Button Width="24" Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,44,0"
                Command="{Binding DataContext.ShowToolDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                Style="{StaticResource HeaderActionButton}"
                ToolTip="Werkzeug-Dokumentation anzeigen"
                AutomationProperties.Name="Werkzeug-Dokumentation anzeigen">
          <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                     Foreground="{DynamicResource BrushAccentCyan}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="ToolListTemplate">
      <Grid Margin="0,0,0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0"
                Padding="8,6"
                HorizontalContentAlignment="Stretch"
                Command="{Binding DataContext.ShowToolDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{Binding MaturityDescription}"
                AutomationProperties.Name="{Binding DisplayName}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="24"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text=" — " Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11"/>
                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                  <Ellipse.Style>
                    <Style TargetType="Ellipse">
                      <Setter Property="Fill" Value="{DynamicResource BrushSuccess}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGuided}" Value="True">
                          <Setter Property="Fill" Value="{DynamicResource BrushWarning}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                          <Setter Property="Fill" Value="{DynamicResource BrushAccentPurple}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding MaturityBadgeText}" FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Advanced" FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushAccentPurple}" VerticalAlignment="Center" Margin="0,0,8,0"
                           Visibility="{Binding IsAdvancedFeature, Converter={StaticResource BoolToVis}}"/>
                <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource BrushWarning}"
                           Visibility="{Binding ShowPlannedBadge, Converter={StaticResource BoolToVis}}">
                  <Run Text="{Binding DataContext.Loc[Tools.BadgePlanned], RelativeSource={RelativeSource AncestorType=Window}}"/>
                  <Run Text=" · Roadmap"/>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Button>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
          <Button Width="24" Height="24"
                  Command="{Binding DataContext.OpenRoadmapLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding RoadmapLink}"
                  Style="{StaticResource HeaderActionButton}"
                  Visibility="{Binding ShowPlannedBadge, Converter={StaticResource BoolToVis}}"
                  ToolTip="Roadmap oeffnen"
                  AutomationProperties.Name="Roadmap oeffnen">
            <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
          <Button Width="24" Height="24"
                  Margin="4,0,0,0"
                  Command="{Binding DataContext.ToggleToolPinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding Key}"
                  Style="{StaticResource HeaderActionButton}"
                  ToolTip="{Binding DataContext.Loc[Tools.PinTip], RelativeSource={RelativeSource AncestorType=Window}}"
                  AutomationProperties.Name="{Binding DataContext.Loc[Tools.PinTip], RelativeSource={RelativeSource AncestorType=Window}}">
            <Grid>
              <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                         Visibility="{Binding IsPinned, Converter={StaticResource InverseBoolToVis}}"
                         Foreground="{DynamicResource BrushTextPrimary}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
              <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                         Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"
                         Foreground="{DynamicResource BrushAccentCyan}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Button>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <Style x:Key="ToolItemsControlStyle" TargetType="ItemsControl">
      <Setter Property="ItemTemplate" Value="{StaticResource ToolCardTemplate}"/>
      <Setter Property="ItemsPanel">
        <Setter.Value>
          <ItemsPanelTemplate>
            <WrapPanel/>
          </ItemsPanelTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding ToolViewMode}" Value="List">
          <Setter Property="ItemTemplate" Value="{StaticResource ToolListTemplate}"/>
          <Setter Property="ItemsPanel">
            <Setter.Value>
              <ItemsPanelTemplate>
                <StackPanel/>
              </ItemsPanelTemplate>
            </Setter.Value>
          </Setter>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200" MinWidth="160" MaxWidth="260"/>
      <ColumnDefinition Width="1"/>
      <ColumnDefinition Width="*"/>
      <!-- D7: dedicated column for tool-doc drawer (auto-collapses when hidden so it never overlaps the tool grid). -->
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{DynamicResource BrushSurface}" Padding="0,12">
      <StackPanel>
        <RadioButton GroupName="ToolsSection" Tag="Empfohlen"
                     Content="{Binding DataContext.Loc[Tools.NavRecommended], RelativeSource={RelativeSource AncestorType=Window}}"
                     Style="{DynamicResource SidebarNavItem}"
                     IsChecked="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Empfohlen}"
                     AutomationProperties.Name="{Binding DataContext.Loc[Tools.NavRecommended], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <RadioButton GroupName="ToolsSection" Tag="Schnellzugriff"
                     Content="{Binding DataContext.Loc[Tools.NavQuickAccess], RelativeSource={RelativeSource AncestorType=Window}}"
                     Style="{DynamicResource SidebarNavItem}"
                     Visibility="{Binding IsSimpleMode, Converter={StaticResource InverseBoolToVis}}"
                     IsChecked="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Schnellzugriff}"
                     AutomationProperties.Name="{Binding DataContext.Loc[Tools.NavQuickAccess], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <RadioButton GroupName="ToolsSection" Tag="Zuletzt verwendet"
                     Content="{Binding DataContext.Loc[Tools.NavRecent], RelativeSource={RelativeSource AncestorType=Window}}"
                     Style="{DynamicResource SidebarNavItem}"
                     Visibility="{Binding IsSimpleMode, Converter={StaticResource InverseBoolToVis}}"
                     IsChecked="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Zuletzt verwendet}"
                     AutomationProperties.Name="{Binding DataContext.Loc[Tools.NavRecent], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <RadioButton GroupName="ToolsSection" Tag="Alle Werkzeuge"
                     Content="{Binding DataContext.Loc[Tools.NavAll], RelativeSource={RelativeSource AncestorType=Window}}"
                     Style="{DynamicResource SidebarNavItem}"
                     Visibility="{Binding IsSimpleMode, Converter={StaticResource InverseBoolToVis}}"
                     IsChecked="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Alle Werkzeuge}"
                     AutomationProperties.Name="{Binding DataContext.Loc[Tools.NavAll], RelativeSource={RelativeSource AncestorType=Window}}"/>
      </StackPanel>
    </Border>

    <Border Grid.Column="1" Background="{DynamicResource BrushBorder}"/>

    <DockPanel Grid.Column="2">
      <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}"
              BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="12,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"
                     Margin="{DynamicResource SpaceRightSM}"/>
          <TextBox Grid.Column="1" Text="{Binding ToolFilterText, UpdateSourceTrigger=PropertyChanged}"
                   MinWidth="200" VerticalAlignment="Center"
                   ToolTip="{Binding DataContext.Loc[Tools.FilterTip], RelativeSource={RelativeSource AncestorType=Window}}"
                   AutomationProperties.Name="{Binding DataContext.Loc[Tools.FilterLabel], RelativeSource={RelativeSource AncestorType=Window}}"/>
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                      Margin="{DynamicResource SpaceLeftSM}">
            <TextBlock Text="{Binding ToolCountLabel}"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11"
                       Margin="0,0,10,0"/>
            <RadioButton GroupName="ToolViewMode" Tag="Grid"
                         Content="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="4,2"
                         IsChecked="{Binding ToolViewMode, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Grid}"
                         Style="{DynamicResource SidebarNavItem}"
                         ToolTip="Kachelansicht"
                         AutomationProperties.Name="Grid View"/>
            <RadioButton GroupName="ToolViewMode" Tag="List"
                         Content="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="4,2"
                         IsChecked="{Binding ToolViewMode, Converter={StaticResource StrEqualsToBool}, ConverterParameter=List}"
                         Style="{DynamicResource SidebarNavItem}"
                         ToolTip="Listenansicht"
                         AutomationProperties.Name="List View"/>
          </StackPanel>
        </Grid>
      </Border>

      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                    Visibility="{Binding IsToolSearchActive, Converter={StaticResource BoolToVis}}">
        <ItemsControl ItemsSource="{Binding ToolItemsView}" Style="{StaticResource ToolItemsControlStyle}">
          <ItemsControl.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" Style="{StaticResource SectionHeader}" Margin="0,16,0,8"/>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ItemsControl.GroupStyle>
        </ItemsControl>
      </ScrollViewer>

      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16"
                    Visibility="{Binding IsToolSearchActive, Converter={StaticResource InverseBoolToVis}}">
        <Grid>
          <StackPanel>
            <WrapPanel Margin="0,0,0,12">
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding AvailableToolCount}" Foreground="{DynamicResource BrushTextPrimary}"
                             FontWeight="Bold" Margin="0,0,6,0"/>
                  <TextBlock Text="{Binding DataContext.Loc[Tools.SummaryAvailable], RelativeSource={RelativeSource AncestorType=Window}}"
                             Foreground="{DynamicResource BrushTextMuted}"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding ProductionToolCount}" Foreground="{DynamicResource BrushSuccess}"
                             FontWeight="Bold" Margin="0,0,6,0"/>
                  <TextBlock Text="{Binding DataContext.Loc[Tools.SummaryProduction], RelativeSource={RelativeSource AncestorType=Window}}"
                             Foreground="{DynamicResource BrushTextMuted}"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding GuidedToolCount}" Foreground="{DynamicResource BrushAccentCyan}"
                             FontWeight="Bold" Margin="0,0,6,0"/>
                  <TextBlock Text="{Binding DataContext.Loc[Tools.SummaryGuided], RelativeSource={RelativeSource AncestorType=Window}}"
                             Foreground="{DynamicResource BrushTextMuted}"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChip}"
                      Visibility="{Binding HasExperimentalTools, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding ExperimentalToolCount}" Foreground="{DynamicResource BrushWarning}"
                             FontWeight="Bold" Margin="0,0,6,0"/>
                  <TextBlock Text="{Binding DataContext.Loc[Tools.SummaryExperimental], RelativeSource={RelativeSource AncestorType=Window}}"
                             Foreground="{DynamicResource BrushTextMuted}"/>
                </StackPanel>
              </Border>
            </WrapPanel>

            <Border Background="#1A00F5FF" BorderBrush="{DynamicResource BrushAccentCyan}" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                    Visibility="{Binding HasRunResult, Converter={StaticResource InverseBoolToVis}}">
              <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding DataContext.QuickPreviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="{Binding DataContext.Loc[Tools.UnlockAction], RelativeSource={RelativeSource AncestorType=Window}}"
                        Padding="10,4"
                        Margin="12,0,0,0"
                        AutomationProperties.Name="{Binding DataContext.Loc[Tools.UnlockAction], RelativeSource={RelativeSource AncestorType=Window}}"/>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                             Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center"
                             Margin="0,0,10,0"/>
                  <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                             Foreground="{DynamicResource BrushTextPrimary}">
                    <Run FontWeight="SemiBold"
                         Text="{Binding DataContext.Loc[Tools.LockedInfo], RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding DataContext.Loc[Tools.LockedAction], RelativeSource={RelativeSource AncestorType=Window}}"/>
                  </TextBlock>
                </StackPanel>
              </DockPanel>
            </Border>

            <!-- Always-on Schnellzugriff card. Hidden in simple mode and on the "Alle Werkzeuge"
                 section, where the dedicated section view already exposes Quick Access via the
                 sidebar (avoids stacking the same content twice). -->
            <Border Margin="0,0,0,12">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SectionCard}">
                  <Setter Property="Visibility" Value="Visible"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSimpleMode}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SelectedToolsSection}" Value="Alle Werkzeuge">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="{Binding DataContext.Loc[Tools.SectionQuickAccess], RelativeSource={RelativeSource AncestorType=Window}}"
                           Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding DataContext.Loc[Tools.SectionQuickAccessDesc], RelativeSource={RelativeSource AncestorType=Window}}"
                           Style="{StaticResource CaptionText}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding QuickAccessItems}" Style="{StaticResource ToolItemsControlStyle}"/>
              </StackPanel>
            </Border>

            <StackPanel Visibility="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Empfohlen}">
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionRecommended], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionRecommendedDesc], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
              <Border Style="{StaticResource SectionCard}" Visibility="{Binding HasRecommendedTools, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding RecommendedToolItems}" Style="{StaticResource ToolItemsControlStyle}"/>
              </Border>
              <Border Style="{StaticResource SectionCard}" Visibility="{Binding HasRecommendedTools, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Text="{Binding DataContext.Loc[Tools.NoRecommended], RelativeSource={RelativeSource AncestorType=Window}}"
                           Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>

            <StackPanel Visibility="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Schnellzugriff}">
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionQuickAccess], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionQuickAccessDesc], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
              <Border Style="{StaticResource SectionCard}">
                <ItemsControl ItemsSource="{Binding QuickAccessItems}" Style="{StaticResource ToolItemsControlStyle}"/>
              </Border>
            </StackPanel>

            <StackPanel Visibility="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Zuletzt verwendet}">
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionRecent], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionRecentDesc], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
              <Border Style="{StaticResource SectionCard}" Visibility="{Binding HasRecentTools, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding RecentToolItems}" Style="{StaticResource ToolItemsControlStyle}"/>
              </Border>
              <Border Style="{StaticResource SectionCard}" Visibility="{Binding HasRecentTools, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Text="{Binding DataContext.Loc[Tools.NoRecent], RelativeSource={RelativeSource AncestorType=Window}}"
                           Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>

            <StackPanel Visibility="{Binding SelectedToolsSection, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Alle Werkzeuge}">
              <TextBlock Text="{Binding DataContext.Loc[Tools.SectionAll], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
              <Border Style="{StaticResource SectionCard}" Margin="0,0,0,8">
                <StackPanel>
                  <TextBlock Text="Core Workflows" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}"/>
                  <TextBlock Text="Empfohlene Kernabläufe für tägliche Arbeit." Style="{StaticResource CaptionText}" Margin="0,2,0,10"/>
                  <ItemsControl ItemsSource="{Binding CoreWorkflowItems}" Style="{StaticResource ToolItemsControlStyle}"/>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}" Margin="0,0,0,8">
                <StackPanel>
                  <TextBlock Text="Maintenance" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}"/>
                  <TextBlock Text="Pflege, Verifikation und Recovery-Werkzeuge." Style="{StaticResource CaptionText}" Margin="0,2,0,10"/>
                  <ItemsControl ItemsSource="{Binding MaintenanceToolItems}" Style="{StaticResource ToolItemsControlStyle}"/>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}" Margin="0,0,0,8"
                      Visibility="{Binding IsSimpleMode, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel>
                  <TextBlock Text="Advanced" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrushTextPrimary}"/>
                  <TextBlock Text="Expertenfunktionen, Automatisierung und Infrastruktur." Style="{StaticResource CaptionText}" Margin="0,2,0,10"/>
                  <ItemsControl ItemsSource="{Binding AdvancedToolItems}" Style="{StaticResource ToolItemsControlStyle}"/>
                </StackPanel>
              </Border>

              <TextBlock Text="{Binding DataContext.Loc[Tools.ConversionRegistryTitle], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource SectionHeader}" Margin="0,20,0,8"/>
              <TextBlock Text="{Binding DataContext.Loc[Tools.ConversionRegistryDesc], RelativeSource={RelativeSource AncestorType=Window}}"
                         Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
              <Border Style="{StaticResource SectionCard}" Visibility="{Binding HasConversionCapabilities, Converter={StaticResource BoolToVis}}">
                <DataGrid ItemsSource="{Binding ConversionCapabilities}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          CanUserSortColumns="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="{DynamicResource BrushBackground}"
                          AlternatingRowBackground="{DynamicResource BrushSurfaceAlt}"
                          Foreground="{DynamicResource BrushTextPrimary}"
                          HeadersVisibility="Column"
                          AutomationProperties.Name="{Binding DataContext.Loc[Tools.ConversionRegistryTitle], RelativeSource={RelativeSource AncestorType=Window}}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Quelle" Binding="{Binding Source}" Width="90"/>
                    <DataGridTextColumn Header="→" Width="30"/>
                    <DataGridTextColumn Header="Ziel" Binding="{Binding Target}" Width="90"/>
                    <DataGridTextColumn Header="Tool" Binding="{Binding Tool}" Width="120"/>
                    <DataGridTextColumn Header="Befehl" Binding="{Binding Command}" Width="100"/>
                    <DataGridTextColumn Header="Verlustfrei" Binding="{Binding LosslessDisplay}" Width="80"/>
                    <DataGridTextColumn Header="Kosten" Binding="{Binding Cost}" Width="60"/>
                    <DataGridTextColumn Header="Konsolen" Binding="{Binding Consoles}" Width="*"/>
                  </DataGrid.Columns>
                </DataGrid>
              </Border>
              <Border Style="{StaticResource SectionCard}" Visibility="{Binding HasConversionCapabilities, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Text="{Binding DataContext.Loc[Tools.ConversionRegistryEmpty], RelativeSource={RelativeSource AncestorType=Window}}"
                           Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </DockPanel>

    <!-- D7 (UX-Redesign Phase 3): Tool-Documentation-Drawer.
         Lives in its own grid column (Column 3) so it never overlaps the tool grid in Column 2.
         When IsToolDocOpen=false the Border collapses and the column shrinks to width 0.
         Single source of truth fuer Tool-Doku (Daten kommen aus dem ToolItem-Modell:
         Description, MaturityDescription, MaturityBadgeText, RecommendationReason,
         AvailabilityText). Kein parallel-Datenpfad. -->
    <Border Grid.Column="3"
            Width="380"
            Background="{DynamicResource BrushSurface}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1,0,0,0"
            Visibility="{Binding DataContext.IsToolDocOpen, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
            DataContext="{Binding SelectedToolDoc}"
            AutomationProperties.Name="Werkzeug-Dokumentation">
      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="20"
                       Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14"
                         Foreground="{DynamicResource BrushTextPrimary}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding Category}" Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="2" Width="28" Height="28" MinHeight="28"
                    Style="{StaticResource HeaderActionButton}"
                    Command="{Binding DataContext.CloseToolDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ToolTip="Schliessen"
                    AutomationProperties.Name="Werkzeug-Dokumentation schliessen">
              <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource BrushTextPrimary}"/>
            </Button>
          </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,14">
          <StackPanel>
            <Border Background="{DynamicResource BrushSuccessBg}" BorderBrush="{DynamicResource BrushSuccess}"
                    BorderThickness="1" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,12">
              <TextBlock Text="{Binding MaturityBadgeText}" FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource BrushSuccess}"/>
            </Border>

            <TextBlock Text="Beschreibung" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,14"/>

            <TextBlock Text="Reifegrad" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding MaturityDescription}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,14"/>

            <TextBlock Text="Empfehlung" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,0,4"
                       Visibility="{Binding HasRecommendationReason, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding RecommendationReason}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,0,14"
                       Visibility="{Binding HasRecommendationReason, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="Verfuegbarkeit" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource BrushWarning}" Margin="0,0,0,4"
                       Visibility="{Binding HasAvailabilityText, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding AvailabilityText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushWarning}" Margin="0,0,0,14"
                       Visibility="{Binding HasAvailabilityText, Converter={StaticResource BoolToVis}}"/>

            <Button Content="Werkzeug starten" Padding="12,8" MinHeight="40"
                    Margin="0,8,0,0"
                    Command="{Binding Command}"
                    Background="{DynamicResource BrushAccentCyan}"
                    Foreground="{DynamicResource BrushBackground}"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Left"
                    AutomationProperties.Name="Werkzeug starten"/>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>

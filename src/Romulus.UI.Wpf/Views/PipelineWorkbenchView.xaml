<UserControl x:Class="Romulus.UI.Wpf.Views.PipelineWorkbenchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
    <StackPanel>
      <TextBlock Text="Pipeline Workbench" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
      <TextBlock Text="Conversion, Sorting und Batch-Aktionen aus einem Bereich."
                 Style="{StaticResource CaptionText}" Margin="0,0,0,16"/>

      <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Conversion" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
          <TextBlock Text="Stepper-Flow: Preview -> Review -> Execute" Style="{StaticResource CaptionText}" Margin="0,6,0,12"/>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Border Style="{StaticResource HeaderChip}">
              <StackPanel Orientation="Horizontal">
                <Border Width="18" Height="18" CornerRadius="3" Background="{DynamicResource BrushAccentCyan}" Margin="0,0,6,0">
                  <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                </Border>
                <TextBlock Text="Preview" VerticalAlignment="Center" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource HeaderChip}">
              <StackPanel Orientation="Horizontal">
                <Border Width="18" Height="18" CornerRadius="3" Background="{DynamicResource BrushWarning}" Margin="0,0,6,0">
                  <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                </Border>
                <TextBlock Text="Review" VerticalAlignment="Center" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource HeaderChip}">
              <StackPanel Orientation="Horizontal">
                <Border Width="18" Height="18" CornerRadius="3" Background="{DynamicResource BrushDanger}" Margin="0,0,6,0">
                  <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                </Border>
                <TextBlock Text="Execute" VerticalAlignment="Center" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <Expander Header="1) Preview: Plan aufbauen" IsExpanded="True" Margin="0,0,0,8">
            <StackPanel Margin="0,10,0,0">
              <TextBlock Text="Empfehlung: zuerst Safe Preview starten, um Risiko und Umfang zu sehen."
                         Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
              <Button Command="{Binding QuickPreviewCommand}" Content="Safe Preview starten" MinWidth="180"/>
            </StackPanel>
          </Expander>

          <Expander Header="2) Review: Entscheidungen pruefen" IsExpanded="False" Margin="0,0,0,8">
            <StackPanel Margin="0,10,0,0">
              <TextBlock Text="Pruefe im Library-Bereich Decisions und Safety, bevor du execute ausloest."
                         Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
              <WrapPanel>
                <Button Command="{Binding GoToLibraryCommand}" Content="Library oeffnen" Margin="0,0,8,0" MinWidth="140"/>
                <Button Command="{Binding OpenReportCommand}" Content="Report oeffnen" MinWidth="140"/>
              </WrapPanel>
            </StackPanel>
          </Expander>

          <Expander Header="3) Execute: Conversion anwenden" IsExpanded="False">
            <StackPanel Margin="0,10,0,0">
              <TextBlock Text="Execute verwendet einen Danger-Dialog mit Tipp-Bestaetigung."
                         Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
              <WrapPanel>
                <Button Command="{Binding PresetConvertCommand}" Content="Preset: Convert" Margin="0,0,8,8" MinWidth="160"/>
                <Button Command="{Binding ConvertOnlyCommand}" Content="Convert Only starten" Margin="0,0,8,8" MinWidth="170"/>
              </WrapPanel>
            </StackPanel>
          </Expander>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Sorting" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
          <TextBlock Text="Starte geordnete Sortierung mit Preview oder Preset." Style="{StaticResource CaptionText}" Margin="0,6,0,12"/>
          <WrapPanel>
            <Button Command="{Binding PresetFullSortCommand}" Content="Preset: Full Sort" Margin="0,0,8,8" MinWidth="160"/>
            <Button Command="{Binding QuickPreviewCommand}" Content="Safe Preview" Margin="0,0,8,8" MinWidth="140"/>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Batch" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
          <TextBlock Text="Fuehre Batch-Lauf aus und oeffne direkt danach die Ergebnisse." Style="{StaticResource CaptionText}" Margin="0,6,0,12"/>
          <WrapPanel>
            <Button Command="{Binding RunCommand}" Content="Pipeline ausfuehren" Margin="0,0,8,8" MinWidth="170"/>
            <Button Command="{Binding OpenReportCommand}" Content="Report oeffnen" Margin="0,0,8,8" MinWidth="140"/>
          </WrapPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>

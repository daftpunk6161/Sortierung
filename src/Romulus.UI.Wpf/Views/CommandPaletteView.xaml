<UserControl x:Class="Romulus.UI.Wpf.Views.CommandPaletteView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- ═══ COMMAND PALETTE OVERLAY (Ctrl+K) ═══════════════════════════════
       Fuzzy search bar for all registered palette commands.
       Overlay pattern: semi-transparent backdrop + centered panel. ═══════ -->
  <Grid>
    <!-- Backdrop (click to dismiss) -->
    <Button Command="{Binding CommandPalette.CloseCommand}"
            Background="{DynamicResource BrushScrimOverlay}"
            BorderThickness="0"
            Padding="0"
            Focusable="False"
            IsHitTestVisible="True"
            AutomationProperties.Name="Command Palette schließen">
      <Button.Template>
        <ControlTemplate TargetType="Button">
          <Border Background="Transparent"/>
        </ControlTemplate>
      </Button.Template>
    </Button>

    <!-- Palette panel -->
    <Border Background="{DynamicResource BrushSurface}"
            BorderBrush="{DynamicResource BrushAccentCyan}"
            BorderThickness="2" CornerRadius="12" Padding="0"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Margin="0,80,0,0" MinWidth="480" MaxWidth="560"
            AutomationProperties.Name="Command Palette"
            Style="{StaticResource OverlayFadeIn}">
      <StackPanel>
        <!-- Search input -->
        <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBox x:Name="SearchBox" Grid.Column="1"
                     Text="{Binding CommandPalette.SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent" BorderThickness="0" FontSize="15"
                     Foreground="{DynamicResource BrushTextPrimary}"
                     CaretBrush="{DynamicResource BrushAccentCyan}"
                     AutomationProperties.Name="Befehl suchen">
              <TextBox.InputBindings>
                <KeyBinding Key="Down" Command="{Binding CommandPalette.MoveDownCommand}"/>
                <KeyBinding Key="Up" Command="{Binding CommandPalette.MoveUpCommand}"/>
                <KeyBinding Key="Enter" Command="{Binding CommandPalette.ExecuteCommand}"/>
                <KeyBinding Key="Escape" Command="{Binding CommandPalette.CloseCommand}"/>
              </TextBox.InputBindings>
            </TextBox>
          </Grid>
        </Border>

        <!-- Results list -->
        <ListBox ItemsSource="{Binding CommandPalette.Results}"
                 SelectedIndex="{Binding CommandPalette.SelectedIndex}"
                 MaxHeight="340" BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 AutomationProperties.Name="Suchergebnisse">
          <ListBox.InputBindings>
            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding CommandPalette.ExecuteCommand}"/>
          </ListBox.InputBindings>
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="16,8"/>
              <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                      <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushAccentCyan}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BrushBackground}"/>
                      </Trigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushSurfaceAlt}"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding Shortcut}"
                           FontSize="11" Opacity="0.6" VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
              </DockPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Empty hint -->
        <TextBlock Text="Kein Befehl gefunden"
                   Foreground="{DynamicResource BrushTextMuted}" FontSize="12"
                   HorizontalAlignment="Center" Margin="16,12"
                   Visibility="{Binding CommandPalette.Results.Count, Converter={StaticResource InverseBoolToVis}}"/>

        <!-- Footer -->
        <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="16,6">
          <TextBlock FontSize="11" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center">
            <Run FontWeight="Bold" Text="↑↓"/><Run Text=" navigieren  "/>
            <Run FontWeight="Bold" Text="Enter"/><Run Text=" ausführen  "/>
            <Run FontWeight="Bold" Text="Esc"/><Run Text=" schließen"/>
          </TextBlock>
        </Border>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

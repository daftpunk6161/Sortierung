<UserControl x:Class="Romulus.UI.Wpf.Views.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Romulus.UI.Wpf.Helpers">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,24,24,28">
      <TextBlock Text="{Binding RootDropAnnouncementText}"
                 Visibility="{Binding HasRootDropAnnouncement, Converter={StaticResource BoolToVis}}"
                 AutomationProperties.LiveSetting="Assertive"/>

      <Border x:Name="heroDropZone" AllowDrop="True"
              helpers:RootsDragDropHelper.Enabled="True"
              MinHeight="180"
              CornerRadius="{DynamicResource RadiusXL}"
              Margin="{DynamicResource SpaceBottomLG}"
              Background="{DynamicResource BrushSurface}"
              BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="2"
              Cursor="Hand"
              AutomationProperties.Name="{Binding Loc[Start.DropZoneLabel]}">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Shell.SelectedSubTab}" Value="RecentRuns">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding IsRootDropTargetActive}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
                <Setter Property="BorderThickness" Value="3"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{Binding HasNoRoots, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"
                       Margin="{DynamicResource SpaceBottomSM}" Opacity="0.7"/>
            <TextBlock Text="{Binding Loc[Start.DropHero]}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                       Margin="{DynamicResource SpaceBottomXS}"/>
            <TextBlock Text="{Binding Loc[Start.DropHeroSub]}" Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center" TextAlignment="Center"/>
            <Button Command="{Binding AddRootCommand}" Content="{Binding Loc[Start.BrowseButton]}"
                    Margin="0,14,0,0" Padding="20,8" HorizontalAlignment="Center"
                    AutomationProperties.Name="{Binding Loc[Start.BrowseButton]}"/>
          </StackPanel>

          <Grid Visibility="{Binding HasNoRoots, Converter={StaticResource InverseBoolToVis}}"
                Margin="22,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.5*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
              <DockPanel Margin="{DynamicResource SpaceBottomSM}">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                  <Button Command="{Binding AddRootCommand}" Content="{Binding Loc[Sort.AddRoot]}"
                          Margin="{DynamicResource SpaceRightXS}" Padding="12,6"
                          AutomationProperties.Name="{Binding Loc[Sort.AddRootTip]}"/>
                  <Button Command="{Binding RemoveRootCommand}" Content="{Binding Loc[Sort.RemoveRoot]}"
                          Padding="12,6" AutomationProperties.Name="{Binding Loc[Sort.RemoveRootTip]}"/>
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="{Binding Loc[Start.RootsConfigured]}" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource BrushTextPrimary}"/>
                  <TextBlock Text="Dropzone bleibt aktiv. Weitere Quellen können direkt hinzugefügt werden."
                             Style="{StaticResource CaptionText}"/>
                </StackPanel>
              </DockPanel>

              <ListBox ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedRoot}"
                       MaxHeight="160" AllowDrop="True"
                       helpers:RootsDragDropHelper.Enabled="True"
                       VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                       AutomationProperties.Name="{Binding Loc[Sort.RootsListName]}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                 Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center"
                                 Margin="{DynamicResource SpaceRightSM}"/>
                      <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.InputBindings>
                  <KeyBinding Key="Delete" Command="{Binding RemoveRootCommand}"/>
                </ListBox.InputBindings>
              </ListBox>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0">
              <StackPanel>
                <TextBlock Text="Aktive Konfiguration" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding SelectedWorkflowName}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SelectedRunProfileName}" Foreground="{DynamicResource BrushTextPrimary}" Margin="0,2,0,8"/>
                <TextBlock Text="{Binding MoveApplyGateText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"/>
                <WrapPanel>
                  <Button Command="{Binding GoToSetupCommand}" Content="{Binding Loc[Start.FlowOpenSetup]}"
                          Margin="{DynamicResource SpaceRightXS}"
                          AutomationProperties.Name="{Binding Loc[Start.FlowOpenSetup]}"/>
                  <Button Command="{Binding QuickPreviewCommand}" Content="{Binding Loc[Start.FlowRunPreview]}"
                          AutomationProperties.Name="{Binding Loc[Start.FlowRunPreview]}"/>
                </WrapPanel>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </Border>

      <Grid Visibility="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Dashboard}">
        <UniformGrid Margin="{DynamicResource SpaceBottomMD}">
          <UniformGrid.Style>
            <Style TargetType="UniformGrid">
              <Setter Property="Columns" Value="2"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Shell.IsCompactNav}" Value="True">
                  <Setter Property="Columns" Value="1"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </UniformGrid.Style>

          <Border Style="{StaticResource SectionCard}" Margin="0,0,12,0">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Start.WhatToDo]}" Style="{StaticResource SectionHeader}"/>
              <WrapPanel Margin="{DynamicResource SpaceBottomMD}">
                <RadioButton GroupName="Intent" Cursor="Hand"
                             IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=SafeDryRun}"
                             Command="{Binding PresetSafeDryRunCommand}"
                             Style="{StaticResource {x:Type RadioButton}}"
                             AutomationProperties.Name="{Binding Loc[Start.IntentClean]}">
                  <Border Style="{StaticResource MetricCard}" Width="220" MinHeight="128">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                 Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center"
                                 Margin="{DynamicResource SpaceBottomSM}"/>
                      <TextBlock Text="{Binding Loc[Start.IntentClean]}" FontSize="15" FontWeight="SemiBold"
                                 Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                                 Margin="{DynamicResource SpaceBottomXS}"/>
                      <TextBlock Text="{Binding Loc[Start.IntentCleanDesc]}" Style="{StaticResource CaptionText}"
                                 HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </RadioButton>

                <RadioButton GroupName="Intent" Cursor="Hand"
                             IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=FullSort}"
                             Command="{Binding PresetFullSortCommand}"
                             Style="{StaticResource {x:Type RadioButton}}"
                             AutomationProperties.Name="{Binding Loc[Start.IntentSort]}">
                  <Border Style="{StaticResource MetricCard}" Width="220" MinHeight="128">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                 Foreground="{DynamicResource BrushAccentCyan}" HorizontalAlignment="Center"
                                 Margin="{DynamicResource SpaceBottomSM}"/>
                      <TextBlock Text="{Binding Loc[Start.IntentSort]}" FontSize="15" FontWeight="SemiBold"
                                 Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                                 Margin="{DynamicResource SpaceBottomXS}"/>
                      <TextBlock Text="{Binding Loc[Start.IntentSortDesc]}" Style="{StaticResource CaptionText}"
                                 HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </RadioButton>

                <RadioButton GroupName="Intent" Cursor="Hand"
                             IsChecked="{Binding ActivePreset, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Convert}"
                             Command="{Binding PresetConvertCommand}"
                             Style="{StaticResource {x:Type RadioButton}}"
                             AutomationProperties.Name="{Binding Loc[Start.IntentConvert]}">
                  <Border Style="{StaticResource MetricCard}" Width="220" MinHeight="128">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                 Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center"
                                 Margin="{DynamicResource SpaceBottomSM}"/>
                      <TextBlock Text="{Binding Loc[Start.IntentConvert]}" FontSize="15" FontWeight="SemiBold"
                                 Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center"
                                 Margin="{DynamicResource SpaceBottomXS}"/>
                      <TextBlock Text="{Binding Loc[Start.IntentConvertDesc]}" Style="{StaticResource CaptionText}"
                                 HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </RadioButton>
              </WrapPanel>

              <Button Command="{Binding DashboardPrimaryCommand}"
                      Height="56"
                      HorizontalAlignment="Stretch"
                      Margin="{DynamicResource SpaceBottomSM}"
                      Style="{StaticResource PrimaryButton}"
                      AutomationProperties.Name="{Binding DashboardPrimaryActionText}"
                      AutomationProperties.AcceleratorKey="{Binding DashboardPrimaryActionAcceleratorKey}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock FontFamily="Segoe MDL2 Assets" Text="{Binding DashboardPrimaryActionIcon}" FontSize="22" VerticalAlignment="Center"
                             Margin="{DynamicResource SpaceRightSM}"/>
                  <TextBlock Text="{Binding DashboardPrimaryActionText}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <TextBlock Text="{Binding DashboardPrimaryActionHintText}"
                         Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource SectionCard}" Margin="12,0,0,0">
            <StackPanel>
              <TextBlock Text="Aktive Konfiguration" Style="{StaticResource SectionHeader}"/>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedWorkflowName}" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding SelectedWorkflowDescription}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedRunProfileName}" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding SelectedRunProfileDescription}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <TextBlock Text="{Binding MoveApplyGateText}" TextWrapping="Wrap"
                         Foreground="{DynamicResource BrushTextPrimary}" Margin="0,4,0,12"/>
              <WrapPanel>
                <Button Command="{Binding GoToSetupCommand}" Content="{Binding Loc[Start.FlowOpenSetup]}"
                        Margin="{DynamicResource SpaceRightXS}"
                        AutomationProperties.Name="{Binding Loc[Start.FlowOpenSetup]}"/>
                <Button Command="{Binding GoToAnalyseCommand}" Content="{Binding Loc[Start.FlowOpenAnalyse]}"
                        AutomationProperties.Name="{Binding Loc[Start.FlowOpenAnalyse]}"/>
              </WrapPanel>
            </StackPanel>
          </Border>
        </UniformGrid>
      </Grid>

      <Grid Visibility="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Dashboard}">
        <UniformGrid Margin="{DynamicResource SpaceBottomMD}">
          <UniformGrid.Style>
            <Style TargetType="UniformGrid">
              <Setter Property="Columns" Value="2"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Shell.IsCompactNav}" Value="True">
                  <Setter Property="Columns" Value="1"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </UniformGrid.Style>

          <Border Style="{StaticResource SectionCard}" Margin="0,0,12,0">
            <StackPanel>
              <TextBlock Text="{Binding Loc[Start.FlowTitle]}" Style="{StaticResource SectionHeader}"/>
              <TextBlock Text="{Binding Loc[Start.FlowDesc]}" Style="{StaticResource CaptionText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

              <Border Style="{StaticResource HeaderChip}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Border Width="26" Height="26" CornerRadius="4" Background="{DynamicResource BrushAccentCyan}" Margin="0,0,10,0">
                    <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Loc[Start.FlowStep1]}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Loc[Start.StepRootsHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding Roots.Count}" Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                </Grid>
              </Border>

              <Border Style="{StaticResource HeaderChip}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Border Width="26" Height="26" CornerRadius="4" Background="{DynamicResource BrushAccentCyan}" Margin="0,0,10,0">
                    <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Loc[Start.FlowStep2]}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Loc[Start.StepSetupHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                  </StackPanel>
                  <Button Grid.Column="2" Command="{Binding GoToSetupCommand}" Content="{Binding Loc[Start.FlowOpenSetup]}" Padding="10,4" VerticalAlignment="Center"/>
                </Grid>
              </Border>

              <Border Style="{StaticResource HeaderChip}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Border Width="26" Height="26" CornerRadius="4" Background="{DynamicResource BrushAccentCyan}" Margin="0,0,10,0">
                    <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Loc[Start.FlowStep3]}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Loc[Start.StepPreviewHint]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                  </StackPanel>
                  <Button Grid.Column="2" Command="{Binding QuickPreviewCommand}" Content="{Binding Loc[Start.FlowRunPreview]}" Padding="10,4" VerticalAlignment="Center"/>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource SectionCard}" Margin="12,0,0,0">
            <StackPanel>
              <TextBlock Text="Review &amp; Apply" Style="{StaticResource SectionHeader}"/>
              <TextBlock Text="{Binding MoveApplyGateText}" TextWrapping="Wrap"
                         Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,12"/>
              <Border Style="{StaticResource HeaderChip}">
                <StackPanel>
                  <TextBlock Text="{Binding Loc[Start.FlowStep4]}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Loc[Start.FlowStep5]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Loc[Start.FlowStep6]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
              </Border>
              <WrapPanel>
                <Button Command="{Binding GoToAnalyseCommand}" Content="{Binding Loc[Start.FlowOpenAnalyse]}"
                        Margin="{DynamicResource SpaceRightXS}"
                        AutomationProperties.Name="{Binding Loc[Start.FlowOpenAnalyse]}"/>
                <Button Command="{Binding OpenReportCommand}" Content="{Binding Loc[Start.OpenReport]}"
                        AutomationProperties.Name="{Binding Loc[Start.OpenReport]}"/>
              </WrapPanel>
            </StackPanel>
          </Border>
        </UniformGrid>
      </Grid>

      <Border Style="{StaticResource SectionCard}"
              Margin="{DynamicResource SpaceBottomMD}"
              Visibility="{Binding HasRecommendedTools, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <DockPanel Margin="{DynamicResource SpaceBottomSM}">
            <Button DockPanel.Dock="Right"
                    Command="{Binding GoToToolsCommand}"
                    Content="{Binding Loc[Tools.OpenCatalog]}"
                    Padding="10,4"
                    AutomationProperties.Name="{Binding Loc[Tools.OpenCatalog]}"/>
            <StackPanel>
              <TextBlock Text="{Binding Loc[Tools.StartRecommendedTitle]}" Style="{StaticResource SectionHeader}"/>
              <TextBlock Text="{Binding Loc[Tools.StartRecommendedDesc]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
            </StackPanel>
          </DockPanel>

          <ItemsControl ItemsSource="{Binding RecommendedToolItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Margin="0,0,10,10"
                        Padding="12,10"
                        MinWidth="220"
                        MaxWidth="280"
                        HorizontalContentAlignment="Left"
                        Command="{Binding Command}"
                        ToolTip="{Binding MaturityDescription}"
                        AutomationProperties.Name="{Binding DisplayName}">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                 Foreground="{DynamicResource BrushAccentCyan}" Margin="{DynamicResource SpaceRightSM}"/>
                      <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="{Binding RecommendationReason}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="220"/>
                      </StackPanel>
                    </StackPanel>
                    <WrapPanel Margin="0,8,0,0">
                      <Border CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BrushSuccessBg}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccess}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsGuided}" Value="True">
                                <Setter Property="Background" Value="#1A00F5FF"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentCyan}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BrushWarningBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding MaturityBadgeText}" FontSize="9" FontWeight="SemiBold">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGuided}" Value="True">
                                  <Setter Property="Foreground" Value="{DynamicResource BrushAccentCyan}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                                  <Setter Property="Foreground" Value="{DynamicResource BrushWarning}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                    </WrapPanel>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Margin="{DynamicResource SpaceBottomMD}">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource SectionCard}">
            <Setter Property="Visibility" Value="{Binding HasRunResult, Converter={StaticResource BoolToVis}}"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Shell.SelectedSubTab}" Value="RecentRuns">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <DockPanel Margin="{DynamicResource SpaceBottomSM}">
            <TextBlock Text="{Binding Loc[Start.LastRun]}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
            <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Center">
              <Button Command="{Binding OpenReportCommand}" Padding="12,4" Margin="{DynamicResource SpaceRightXS}"
                      AutomationProperties.Name="{Binding Loc[Start.OpenReport]}">
                <TextBlock Text="{Binding Loc[Start.OpenReport]}"/>
              </Button>
              <Button Command="{Binding RollbackCommand}" Padding="12,4"
                      Foreground="{DynamicResource BrushAccentPurple}" BorderBrush="{DynamicResource BrushAccentPurple}"
                      AutomationProperties.Name="{Binding Loc[Start.Undo]}">
                <TextBlock Text="{Binding Loc[Start.Undo]}"/>
              </Button>
            </WrapPanel>
          </DockPanel>

          <WrapPanel Margin="{DynamicResource SpaceBottomSM}">
            <Border Style="{StaticResource MetricCard}" MinWidth="160">
              <StackPanel>
                <TextBlock Text="{Binding Loc[Start.Winners], Mode=OneWay}" Style="{StaticResource CaptionText}"/>
                <TextBlock Text="{Binding Run.DashWinners, Mode=OneWay}" Foreground="{DynamicResource BrushSuccess}" FontSize="22" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinWidth="160">
              <StackPanel>
                <TextBlock Text="{Binding Loc[Start.Dupes], Mode=OneWay}" Style="{StaticResource CaptionText}"/>
                <TextBlock Text="{Binding Run.DashDupes, Mode=OneWay}" Foreground="{DynamicResource BrushWarning}" FontSize="22" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinWidth="160">
              <StackPanel>
                <TextBlock Text="{Binding Loc[Report.Junk], Mode=OneWay}" Style="{StaticResource CaptionText}"/>
                <TextBlock Text="{Binding Run.DashJunk, Mode=OneWay}" Foreground="{DynamicResource BrushDanger}" FontSize="22" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCard}" MinWidth="160">
              <StackPanel>
                <TextBlock Text="Dauer" Style="{StaticResource CaptionText}"/>
                <TextBlock Text="{Binding Run.DashDuration}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="22" FontWeight="Bold"/>
              </StackPanel>
            </Border>
          </WrapPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>

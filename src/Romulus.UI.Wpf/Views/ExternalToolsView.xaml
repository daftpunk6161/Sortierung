<UserControl x:Class="Romulus.UI.Wpf.Views.ExternalToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
    <StackPanel MaxWidth="900">

      <!-- Header -->
      <TextBlock Text="{Binding Loc[Tools.ExternalToolsHeader]}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding Loc[Tools.ExternalToolsDesc]}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,16"/>

      <!-- Tool paths grid -->
      <Border Style="{StaticResource SectionCard}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="38"/>
            <ColumnDefinition Width="100"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- chdman -->
          <Label Grid.Row="0" Grid.Column="0" Content="chdman" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox Grid.Row="0" Grid.Column="1"
                   Text="{Binding ToolChdman, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                   Margin="{DynamicResource SpaceRightXS}"
                   ToolTip="MAME CHD-Konverter – für CHD-Konvertierung benötigt"
                   AutomationProperties.Name="chdman-Pfad"/>
          <Button Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                  Command="{Binding BrowseToolPathCommand}" CommandParameter="Chdman"
                  ToolTip="chdman-Pfad auswählen"
                  AutomationProperties.Name="chdman durchsuchen"/>
          <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ChdmanStatusText}"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

          <!-- dolphintool -->
          <Label Grid.Row="2" Grid.Column="0" Content="dolphintool" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox Grid.Row="2" Grid.Column="1"
                   Text="{Binding ToolDolphin, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                   Margin="{DynamicResource SpaceRightXS}"
                   ToolTip="Dolphin RVZ-Konverter – für RVZ-Konvertierung benötigt"
                   AutomationProperties.Name="dolphintool-Pfad"/>
          <Button Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                  Command="{Binding BrowseToolPathCommand}" CommandParameter="Dolphin"
                  ToolTip="dolphintool-Pfad auswählen"
                  AutomationProperties.Name="dolphintool durchsuchen"/>
          <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DolphinStatusText}"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

          <!-- 7-Zip -->
          <Label Grid.Row="4" Grid.Column="0" Content="7-Zip (7z)" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox Grid.Row="4" Grid.Column="1"
                   Text="{Binding Tool7z, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                   Margin="{DynamicResource SpaceRightXS}"
                   ToolTip="7-Zip – für Archiv-Extraktion und -Kompression benötigt"
                   AutomationProperties.Name="7-Zip-Pfad"/>
          <Button Grid.Row="4" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                  Command="{Binding BrowseToolPathCommand}" CommandParameter="7z"
                  ToolTip="7-Zip-Pfad auswählen"
                  AutomationProperties.Name="7-Zip durchsuchen"/>
          <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding SevenZipStatusText}"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

          <!-- psxtract -->
          <Label Grid.Row="6" Grid.Column="0" Content="psxtract" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox Grid.Row="6" Grid.Column="1"
                   Text="{Binding ToolPsxtract, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                   Margin="{DynamicResource SpaceRightXS}"
                   ToolTip="PS3/PSP-Extraktor – für PSN-Extraktion benötigt"
                   AutomationProperties.Name="psxtract-Pfad"/>
          <Button Grid.Row="6" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                  Command="{Binding BrowseToolPathCommand}" CommandParameter="Psxtract"
                  ToolTip="psxtract-Pfad auswählen"
                  AutomationProperties.Name="psxtract durchsuchen"/>
          <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding PsxtractStatusText}"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

          <!-- ciso -->
          <Label Grid.Row="8" Grid.Column="0" Content="ciso" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox Grid.Row="8" Grid.Column="1"
                   Text="{Binding ToolCiso, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                   Margin="{DynamicResource SpaceRightXS}"
                   ToolTip="CSO-Kompressor – für CSO-Konvertierung benötigt"
                   AutomationProperties.Name="ciso-Pfad"/>
          <Button Grid.Row="8" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                  Command="{Binding BrowseToolPathCommand}" CommandParameter="Ciso"
                  ToolTip="ciso-Pfad auswählen"
                  AutomationProperties.Name="ciso durchsuchen"/>
          <TextBlock Grid.Row="8" Grid.Column="3" Text="{Binding CisoStatusText}"
                     Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>
        </Grid>
      </Border>

      <!-- Auto-Detect button -->
      <Button Content="{Binding Loc[Settings.BtnAutoDetect]}" Command="{Binding FeatureCommands[AutoFindTools]}"
              ToolTip="{Binding Loc[Settings.AutoDetectTip]}"
              Width="220" HorizontalAlignment="Left" Margin="0,12,0,0"
              AutomationProperties.Name="{Binding Loc[Settings.AutoDetectTip]}">
        <Button.ContentTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </Button.ContentTemplate>
      </Button>

      <!-- Info text -->
      <Border Background="#1A00F5FF" BorderBrush="{DynamicResource BrushAccentCyan}" BorderThickness="1"
              CornerRadius="6" Padding="12,10" Margin="0,16,0,0">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                     Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}"
                     Text="{Binding Loc[Tools.ExternalToolsInfo]}"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>

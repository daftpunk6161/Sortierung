<UserControl x:Class="Romulus.UI.Wpf.Views.DatCatalogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Romulus.UI.Wpf.ViewModels"
>
  <!-- DAT Catalog Management View (ADR-0020) -->
  <Grid Margin="20,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Summary bar -->
      <RowDefinition Height="Auto"/>  <!-- Filter bar -->
      <RowDefinition Height="*"/>     <!-- DataGrid -->
      <RowDefinition Height="Auto"/>  <!-- Action bar -->
    </Grid.RowDefinitions>

    <!-- ═══ SUMMARY BAR ═══════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="{DynamicResource BrushSurface}"
            CornerRadius="{DynamicResource RadiusMD}" Padding="16,10" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                     Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,8,0" VerticalAlignment="Center"/>
          <TextBlock Text="DAT-Verwaltung" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Summary counters -->
        <WrapPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#00FF88" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Installiert: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding InstalledCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#FF0044" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Fehlend: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding MissingCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
            <Border Width="10" Height="10" Background="#FFB700" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Veraltet: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding StaleCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Orientation="Horizontal">
            <Border Width="10" Height="10" Background="#9999CC" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
              <Run Text="Auto: " Foreground="{DynamicResource BrushTextMuted}"/>
              <Run Text="{Binding AutoCount, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
          </StackPanel>
        </WrapPanel>

        <!-- Total + Refresh -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock VerticalAlignment="Center" Margin="0,0,12,0">
            <Run Text="Gesamt: " Foreground="{DynamicResource BrushTextMuted}"/>
            <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="Bold"/>
          </TextBlock>
          <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" ToolTip="Katalog neu scannen"
                  Command="{Binding RefreshCommand}" Width="32" Height="28" Padding="4"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  AutomationProperties.Name="DAT Katalog Refresh"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ FILTER BAR ════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
        <TextBlock Text="Gruppe:" VerticalAlignment="Center" Margin="0,0,6,0"
                   Foreground="{DynamicResource BrushTextMuted}"/>
        <ComboBox Width="150" SelectedItem="{Binding SelectedGroupFilter}"
                  ItemsSource="{Binding GroupFilterOptions}"
                  AutomationProperties.Name="Gruppenfilter"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,6,0"
                   Foreground="{DynamicResource BrushTextMuted}"/>
        <ComboBox Width="130" SelectedItem="{Binding SelectedStatusFilter}"
                  ItemsSource="{Binding StatusFilterOptions}"
                  AutomationProperties.Name="Statusfilter"/>
      </StackPanel>

      <TextBox Grid.Column="2"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
               Margin="0,0,12,0"
               AutomationProperties.Name="DAT Katalog Suche"/>

      <TextBlock Grid.Column="3" Text="{Binding StatusText}" VerticalAlignment="Center"
                 Foreground="{DynamicResource BrushTextMuted}" FontSize="11"
                 MaxWidth="300" TextTrimming="CharacterEllipsis"/>
    </Grid>

    <!-- ═══ DATAGRID ═════════════════════════════════════════════════ -->
    <DataGrid Grid.Row="2"
              ItemsSource="{Binding EntriesView}"
              AutoGenerateColumns="False"
              IsReadOnly="False"
              CanUserSortColumns="True"
              CanUserReorderColumns="False"
              SelectionMode="Extended"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              RowHeight="30"
              AutomationProperties.Name="DAT Katalog Grid">
      <DataGrid.Columns>
        <!-- Selection checkbox -->
        <DataGridTemplateColumn Width="36" CanUserSort="False">
          <DataGridTemplateColumn.HeaderTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding DataContext.SelectAll, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        ToolTip="Alle auswählen"/>
            </DataTemplate>
          </DataGridTemplateColumn.HeaderTemplate>
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- System name -->
        <DataGridTextColumn Header="System" Binding="{Binding System}" Width="*" IsReadOnly="True">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
              <Setter Property="Margin" Value="4,0"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- Group -->
        <DataGridTextColumn Header="Gruppe" Binding="{Binding Group}" Width="110" IsReadOnly="True">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="Margin" Value="4,0"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- Console Key -->
        <DataGridTextColumn Header="Konsole" Binding="{Binding ConsoleKey}" Width="90" IsReadOnly="True">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
              <Setter Property="Margin" Value="4,0"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- Status badge -->
        <DataGridTemplateColumn Header="Status" Width="110" SortMemberPath="Status">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="#33999999"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Status}" Value="Installed">
                        <Setter Property="Background" Value="#3300FF88"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Status}" Value="Missing">
                        <Setter Property="Background" Value="#33FF0044"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Status}" Value="Stale">
                        <Setter Property="Background" Value="#33FFB700"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusDisplay}" FontSize="11" FontWeight="Medium"
                           VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Installed">
                          <Setter Property="Foreground" Value="#00FF88"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Missing">
                          <Setter Property="Foreground" Value="#FF0044"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Stale">
                          <Setter Property="Foreground" Value="#FFB700"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- Download strategy / action hint -->
        <DataGridTextColumn Header="Aktion" Binding="{Binding ActionDisplay}" Width="140" IsReadOnly="True">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
              <Setter Property="FontSize" Value="11"/>
              <Setter Property="Margin" Value="4,0"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>

        <!-- Installed date -->
        <DataGridTextColumn Header="Datum" Binding="{Binding InstalledDateDisplay}" Width="90" IsReadOnly="True">
          <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
              <Setter Property="FontSize" Value="11"/>
              <Setter Property="Margin" Value="4,0"/>
            </Style>
          </DataGridTextColumn.ElementStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>

    <!-- ═══ ACTION BAR ═══════════════════════════════════════════════ -->
    <Border Grid.Row="3" Margin="0,12,0,0" Padding="0,8,0,0"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Ausgewählte entfernen"
                  Command="{Binding RemoveSelectedCommand}"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  Style="{StaticResource DangerButton}"
                  Margin="0,0,8,0" Padding="12,6"
                  AutomationProperties.Name="Ausgewählte DAT-Einträge aus Katalog entfernen"/>
          <Button Content="Ausgewählte herunterladen"
                  Command="{Binding DownloadSelectedCommand}"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  Margin="0,0,8,0" Padding="12,6"
                  AutomationProperties.Name="Ausgewählte DATs herunterladen"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
          <Button Content="Alle Auto-DATs aktualisieren"
                  Command="{Binding UpdateAutoCommand}"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  Style="{StaticResource PrimaryButton}"
                  Margin="0,0,8,0" Padding="12,6"
                  AutomationProperties.Name="Alle automatisch downloadbaren DATs aktualisieren"/>
          <Button Content="DATs importieren"
                  Command="{Binding ImportDatsCommand}"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  Padding="12,6"
                  AutomationProperties.Name="DAT-Dateien aus Ordner importieren"/>
          <Button Content="＋ Hinzufügen"
                  Command="{Binding AddDatCommand}"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  Margin="8,0,0,0" Padding="12,6"
                  AutomationProperties.Name="Eigenen DAT-Eintrag hinzufügen"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Busy overlay -->
    <Border Grid.Row="0" Grid.RowSpan="4"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
            Background="#80000000" CornerRadius="{DynamicResource RadiusMD}"
            IsHitTestVisible="False">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,8"/>
        <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center"
                   Foreground="White" FontSize="12"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

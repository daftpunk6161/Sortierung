<UserControl x:Class="Romulus.UI.Wpf.Views.NavigationRail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{DynamicResource BrushSurfaceAlt}"
          BorderBrush="{DynamicResource BrushBorder}"
          BorderThickness="0,0,1,0"
          Width="{DynamicResource NavRailWidth}">
    <DockPanel LastChildFill="False">
      <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
        <RadioButton GroupName="Nav"
                     Visibility="{Binding Shell.ShowMissionControlNav, Converter={StaticResource BoolToVis}}"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=MissionControl}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.MissionControl]}"
                     TabIndex="50"
                     AutomationProperties.Name="{Binding Loc[Nav.MissionControl]}">
          <StackPanel HorizontalAlignment="Center" MaxWidth="72">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Mission Control" FontSize="10.5" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,4,0,0" Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <RadioButton GroupName="Nav"
                     Visibility="{Binding Shell.ShowLibraryNav, Converter={StaticResource BoolToVis}}"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Library}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.Library]}"
                     TabIndex="51"
                     AutomationProperties.Name="{Binding Loc[Nav.Library]}">
          <StackPanel HorizontalAlignment="Center" MaxWidth="72">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Library" FontSize="10.5" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,4,0,0" Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <RadioButton GroupName="Nav"
                     Visibility="{Binding Shell.ShowConfigNav, Converter={StaticResource BoolToVis}}"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Config}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.Config]}"
                     TabIndex="52"
                     AutomationProperties.Name="{Binding Loc[Nav.Config]}">
          <StackPanel HorizontalAlignment="Center" MaxWidth="72">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Konfig." FontSize="10.5" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,4,0,0" Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <RadioButton GroupName="Nav"
                     Visibility="{Binding Shell.ShowToolsNav, Converter={StaticResource BoolToVis}}"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=Tools}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.Tools]}"
                     TabIndex="53"
                     AutomationProperties.Name="{Binding Loc[Nav.Tools]}">
          <StackPanel HorizontalAlignment="Center" MaxWidth="72">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE90F;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Werkzeuge" FontSize="10.5" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,4,0,0" Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>

        <RadioButton GroupName="Nav"
                     Visibility="{Binding Shell.ShowSystemNav, Converter={StaticResource BoolToVis}}"
                     IsChecked="{Binding Shell.SelectedNavTag, Converter={StaticResource StrEqualsToBool}, ConverterParameter=System}"
                     Style="{StaticResource NavButton}"
                     ToolTip="{Binding Loc[Nav.System]}"
                     TabIndex="54"
                     AutomationProperties.Name="{Binding Loc[Nav.System]}">
          <StackPanel HorizontalAlignment="Center" MaxWidth="72">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE770;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="System" FontSize="10.5" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,4,0,0" Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </RadioButton>
      </StackPanel>

      <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
        <Button Style="{StaticResource HeaderActionButton}"
                Command="{Binding Shell.ToggleShortcutSheetCommand}"
                ToolTip="{Binding Loc[Shortcuts.Title]}"
                AutomationProperties.Name="{Binding Loc[Shortcuts.Title]}"
                TabIndex="55"
                Margin="8,0">
          <StackPanel HorizontalAlignment="Center" MaxWidth="72">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE897;" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock Text="Shortcuts" FontSize="10.5" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,4,0,0" Foreground="{DynamicResource BrushTextMuted}"
                       Visibility="{Binding Shell.IsCompactNav, Converter={StaticResource InverseBoolToVis}}"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </DockPanel>
  </Border>
</UserControl>

<UserControl x:Class="Romulus.UI.Wpf.Views.LibraryReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
>
  <!-- Extracted from ResultView "Report-Vorschau" section -->
  <Grid>
    <DockPanel Background="{DynamicResource BrushBackground}"
               Visibility="{Binding Run.HasRunData, Converter={StaticResource BoolToVis}}">
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,16,20,8">
        <TextBlock Text="{Binding Loc[Result.ReportPreviewHeader]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceRightSM}"/>
        <Button x:Name="btnRefreshReportPreview" Width="120" Height="28" Content="{Binding Loc[Result.Refresh]}"
                AutomationProperties.Name="{Binding Loc[Result.RefreshReportTip]}"/>
      </StackPanel>
      <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="1" CornerRadius="6" Padding="8" Margin="20,0,20,8">
        <StackPanel>
          <TextBlock Text="{Binding Loc[Result.ErrorSummary]}" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomXS}"/>
          <ListBox MinHeight="60"
                   ItemsSource="{Binding ErrorSummaryItems}"
                   Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushWarning}"
                   BorderThickness="0" FontSize="12"
                   VirtualizingPanel.IsVirtualizing="True"
                   VirtualizingPanel.VirtualizationMode="Recycling"
                   ScrollViewer.CanContentScroll="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   AutomationProperties.Name="{Binding Loc[Result.ErrorSummary]}"
                   AutomationProperties.LiveSetting="Assertive">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{DynamicResource BrushTextPrimary}"/>
                  <Button Content="Vollständigen Report öffnen"
                          Command="{Binding DataContext.OpenReportCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                          Margin="0,4,0,0"
                          HorizontalAlignment="Left"
                          Padding="8,2"
                          Visibility="Collapsed"
                          AutomationProperties.Name="Vollständigen Report öffnen">
                    <Button.Style>
                      <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Code}" Value="RUN-TRUNC">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>
                  </Button>
                  <TextBlock FontSize="10" Opacity="0.8" Foreground="{DynamicResource BrushTextMuted}">
                    <Run Text="Code: "/>
                    <Run Text="{Binding Code}"/>
                  </TextBlock>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
      <wv2:WebView2 x:Name="webReportPreview" Margin="20,0,20,16" MinHeight="80"
                   AutomationProperties.Name="{Binding Loc[Result.ReportPreviewLabel]}"
                   AutomationProperties.HelpText="{Binding Loc[Result.ReportPreviewHelp]}"/>
    </DockPanel>

    <!-- Empty state: no report yet -->
    <StackPanel Visibility="{Binding Run.HasRunData, Converter={StaticResource InverseBoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center">
      <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                 Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
      <TextBlock Text="Kein Report verfügbar" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
      <TextBlock Text="Starte eine Vorschau (F5) um den Report zu generieren."
                 Foreground="{DynamicResource BrushTextMuted}" FontSize="12" HorizontalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>

<Window x:Class="Romulus.UI.Wpf.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Eingabe"
    Width="440" Height="200"
    MinWidth="300" MinHeight="150"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    WindowStyle="SingleBorderWindow"
    FontFamily="Segoe UI" FontSize="13"
    Background="{DynamicResource BrushBackground}"
    Foreground="{DynamicResource BrushTextPrimary}"
    UseLayoutRounding="True"
    FocusManager.FocusedElement="{Binding ElementName=txtInput}">

  <Window.InputBindings>
    <KeyBinding Key="Escape" Command="Close"/>
  </Window.InputBindings>
  <Window.CommandBindings>
    <CommandBinding Command="Close" Executed="OnCloseCommand"/>
  </Window.CommandBindings>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Prompt -->
    <TextBlock x:Name="txtPrompt" Grid.Row="0" TextWrapping="Wrap"
               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,12"/>

    <!-- Input -->
    <TextBox x:Name="txtInput" Grid.Row="1" Padding="8,6" FontFamily="Consolas"
             Background="{DynamicResource BrushSurface}" Foreground="{DynamicResource BrushTextPrimary}"
             BorderBrush="{DynamicResource BrushBorder}" CaretBrush="{DynamicResource BrushAccentCyan}"
             AutomationProperties.Name="{Binding ElementName=txtPrompt, Path=Text}"/>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"
              AutomationProperties.Name="OK"/>
      <Button Content="Abbrechen" Width="100" IsCancel="True" Click="OnCancel"
              AutomationProperties.Name="Abbrechen"/>
    </StackPanel>
  </Grid>
</Window>

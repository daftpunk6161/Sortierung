<Application x:Class="Romulus.UI.Wpf.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Romulus.UI.Wpf.Converters"
    ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Themes/_DesignTokens.xaml"/>
        <ResourceDictionary Source="Themes/_ControlTemplates.xaml"/>
        <ResourceDictionary Source="Themes/SynthwaveDark.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      <!-- GUI-086: Shared converters (centralized from View.Resources) -->
      <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
      <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
      <conv:InverseBoolConverter x:Key="InverseBool"/>
      <conv:StatusLevelToBrushConverter x:Key="StatusToBrush"/>
      <conv:LogLevelToBrushConverter x:Key="LogLevelToBrush"/>
      <conv:StepActiveBrushConverter x:Key="StepToBrush"/>
      <conv:PipelinePhaseBrushConverter x:Key="PhaseBrush"/>
      <conv:StringEqualsToVisibilityConverter x:Key="StrEqualsToVis"/>
      <conv:StringEqualsToBoolConverter x:Key="StrEqualsToBool"/>
      <conv:PhaseDetailConverter x:Key="PhaseDetail"/>
      <conv:FractionToWidthConverter x:Key="FractionToWidth"/>
      <conv:FractionToGridLengthConverter x:Key="FractionToGridLength"/>
      <conv:IntToVisibilityConverter x:Key="IntToVis"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>

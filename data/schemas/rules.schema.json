{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://romulus.local/schemas/rules.schema.json",
  "type": "object",
  "$defs": {
    "regionKey": {
      "type": "string",
      "enum": [
        "EU", "US", "JP", "WORLD", "UNKNOWN",
        "AU", "NZ", "BR", "ASIA", "SCAN", "KR", "CN",
        "FR", "DE", "ES", "IT", "NL", "SE", "RU", "PL", "CA",
        "LATAM", "TR", "AE"
      ]
    }
  },
  "required": ["RegionOrdered", "Region2Letter", "regionTokenMap"],
  "properties": {
    "LangPattern": { "type": "string" },
    "RegionOrdered": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["Key", "Pattern"],
        "properties": {
          "Key": { "$ref": "#/$defs/regionKey" },
          "Pattern": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "Region2Letter": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["Key", "Pattern"],
        "properties": {
          "Key": { "$ref": "#/$defs/regionKey" },
          "Pattern": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "regionTokenMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/regionKey" }
    },
    "languageCodes": { "type": "array", "items": { "type": "string" } },
    "euLanguageCodes": { "type": "array", "items": { "type": "string" } },
    "MultiRegionPattern": { "type": "string" },
    "JunkPatterns": { "type": "array", "items": { "type": "string" } },
    "AggressiveJunkPatterns": { "type": "array", "items": { "type": "string" } },
    "BiosPatterns": { "type": "array", "items": { "type": "string" } },
    "VersionPatterns": { "type": "array", "items": { "type": "string" } },
    "VersionScoring": { "type": "object" },
    "FormatScoring": { "type": "object" }
  },
  "additionalProperties": true
}

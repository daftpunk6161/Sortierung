{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://romcleanup.local/schemas/consoles.schema.json",
  "type": "object",
  "required": ["consoles"],
  "properties": {
    "_meta": {
      "type": "object",
      "additionalProperties": true
    },
    "consoles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "displayName",
          "discBased",
          "uniqueExts",
          "ambigExts",
          "folderAliases"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "discBased": {
            "type": "boolean"
          },
          "uniqueExts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ambigExts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "folderAliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hints": {
            "type": "object",
            "additionalProperties": true
          },
          "conversionPolicy": {
            "type": "string",
            "enum": ["Auto", "ArchiveOnly", "ManualOnly", "None"],
            "default": "None"
          },
          "preferredConversionTarget": {
            "type": ["string", "null"]
          },
          "alternativeTargets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

# ── .NET Build Artifacts ──
**/bin/
**/obj/
*.nupkg
*.snupkg

# ── Publish / Release Outputs (built by .github/workflows/release.yml, never committed) ──
dist/

# ── Generated Test & Coverage Artifacts ──
coverage.xml
test-err.txt
test-out.txt
_test_results.txt
test-output.txt
TestResults/
**/TestResults/

# ── Reports: all generated, never commit ──
reports/

# ── Audit-Logs: runtime-generated, never commit ──
audit-logs/

# ── Local artifacts / scratch directories (never committed) ──
artifacts/
.tmp/
tools/

# ── Local dev logs at root ──
*.log

# ── Node leftovers (Romulus uses no Node toolchain) ──
node_modules/
package.json
package-lock.json

# ── Generated docs ──
docs/openapi.generated.json
docs/archive/

# ── Editor / OS ──
.vs/
*.suo
*.user
Thumbs.db
Desktop.ini
.DS_Store

w4de_*.txt



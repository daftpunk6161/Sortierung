{
    "files.watcherExclude": {
        "**/reports/**": true,
        "**/audit-logs/archive/**": true,
        "**/PBP/**": true,
        "**/coverage.xml": true
    },
    "files.exclude": {
        "**/reports/**": true,
        "**/audit-logs/archive/**": true
    },
    "search.exclude": {
        "**/reports/**": true,
        "**/audit-logs/archive/**": true
    },
    "markiscodecoverage.searchCriteria": "src/**/TestResults/**/coverage.info",
    "markiscodecoverage.coverageThreshold": 34,
    "markiscodecoverage.enableOnStartup": true,
    "markiscodecoverage.enableDecorations": false,
    "chat.agent.maxRequests": 1500,
    "pester.runTestsInNewProcess": true,
    "pester.autoDebugOnSave": false,
    "pester.autoRunOnSave": false,
    "pester.autoDiscoverOnOpen": false,
    "pester.testFilePath": [],
    "pester.suppressCodeLensNotice": true,
    "pester.codeLens": false,
    "dotnet.testWindow.disableAutoDiscovery": true,
    "dotnet.testWindow.disableBuildOnRefresh": true,
    "dotnet.testWindow.disableBuildOnRun": true,
    "dotnet.codeLens.enableTestsCodeLens": false,
    "terminal.integrated.scrollback": 2000,
    "powershell.scriptAnalysis.settingsPath": "",
    "powershell.enableReferencesCodeLens": false,
    "github.copilot.chat.agent.autoFix": true,
    "github.copilot.chat.anthropic.tools.websearch.enabled": true,
    "github.copilot.chat.anthropic.tools.websearch.maxUses": 20,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.copilotMemory.enabled": true,
    "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
    "github.copilot.chat.localeOverride": "de",
    "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": false,
    "github.copilot.chat.switchAgent.enabled": false,
    "github.copilot.enable": {
        "powershell": true,
        "markdown": true,
        "c#": true
    },
    "chat.agentSessionProjection.enabled": true,
    "chat.requestQueuing.defaultAction": "steer",
    "chat.tips.enabled": true,
    "chat.useClaudeHooks": true,
    "chat.viewProgressBadge.enabled": true,
    "markdown.validate.enabled": false,
    "codium.codeCompletion.enable": true,
    "github-actions.workflows.pinned.workflows": [
        "dynamic/copilot-pull-request-reviewer/copilot-pull-request-reviewer"
    ],
    "chat.planAgent.defaultModel": "Claude Sonnet 4.6 (copilot)",
    "chat.agent.thinkingStyle": "collapsedPreview",
    "chat.viewSessions.orientation": "stacked",
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true
    },
    "chat.mcp.gallery.enabled": true,
    "chat.mcp.assisted.nuget.enabled": true,
    "chat.includeReferencedInstructions": true,
    "chat.useNestedAgentsMdFiles": true
}
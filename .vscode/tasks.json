			}
		},
		{
			"label": "tests: smoke-wpf",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-Command",
				"Invoke-Pester -Path './archive/powershell/dev/tests/integration/WpfSmoke.Tests.ps1' -Output Detailed"
			],
			"group": "test"
		},
		{
			"label": "tests: smoke-wpf",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-Command",
				"& { Invoke-Pester -Path './archive/powershell/dev/tests/integration/WpfSmoke.Tests.ps1' -Output Detailed }"
			],
			"group": "test"
		},
		{
			"label": "tests: smoke-wpf",
			"type": "shell",
			"command": "Invoke-Pester",
			"args": [
				"-Path",
				"./archive/powershell/dev/tests/integration/WpfSmoke.Tests.ps1",
				"-Output",
				"Detailed"
			],
			"group": "test"
		},
		{
			"label": "tests: smoke wpf quick",
			"type": "shell",
			"command": "Invoke-Pester -Path \"./archive/powershell/dev/tests/integration/WpfSmoke.Tests.ps1\" -Output Detailed",
			"group": "test"
		},
		{
			"label": "Build Solution",
			"type": "shell",
			"command": "dotnet build src/Romulus.sln",
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"

		}
	]
}
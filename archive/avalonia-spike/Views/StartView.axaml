<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Romulus.UI.Avalonia.ViewModels"
             x:Class="Romulus.UI.Avalonia.Views.StartView"
             x:DataType="vm:StartViewModel">
  <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12" Margin="16">
    <TextBlock Text="Start" FontSize="24" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="{Binding DropHint}" Opacity="0.75" />

    <Border Grid.Row="2" Padding="14" CornerRadius="8" BorderBrush="#D0D7DE" BorderThickness="1">
      <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto" RowSpacing="10" ColumnSpacing="10">
        <TextBlock Text="Quellen" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="Root hinzufügen" Command="{Binding AddRootCommand}" />
          <Button Content="Roots importieren" Command="{Binding ImportRootsCommand}" />
          <Button Content="Root entfernen" Command="{Binding RemoveRootCommand}" />
        </StackPanel>

        <ListBox Grid.Row="1" Grid.ColumnSpan="2"
                 ItemsSource="{Binding Roots}"
                 SelectedItem="{Binding SelectedRoot}"
                 MinHeight="220" />
      </Grid>
    </Border>

    <Button Grid.Row="3"
            HorizontalAlignment="Left"
            Content="Preview starten"
            Command="{Binding RequestPreviewCommand}" />
  </Grid>
</UserControl>
